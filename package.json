{
  "name": "ignitionsim",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "description": "IgnitionSim.com — the engineer's guide to sim hardware. Compatibility-checked builds, honest gear reviews, and restock alerts for racing, flight, space, marine, and golf sim rigs.",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build && node scripts/prune-unverified-gear-images.mjs",
    "preview": "astro preview",
    "images": "node scripts/fetch-images.mjs",
    "product-images": "node scripts/fetch-real-product-images.mjs",
    "art": "node scripts/make-real-product-collages.mjs",
    "og": "node scripts/make-og-cards.mjs",
    "track": "node scripts/track.mjs",
    "diff": "node scripts/diff-events.mjs"
  },
  "dependencies": {
    "@astrojs/sitemap": "3.7.3",
    "astro": "5.18.2",
    "sharp": "0.33.5"
  }
}
