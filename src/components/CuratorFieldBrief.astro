---
import conversations from '../data/crew-conversations.json';
import editorialSurfaces from '../data/editorial-surfaces.json';
import { crewSlug } from '../lib/crew';

interface Proof {
  image: string;
  name: string;
  href: string;
}
interface Props {
  entry: any;
  person: any;
  proof?: Proof | null;
}
const { entry, person, proof = null } = Astro.props as Props;
const slug = entry.id.split('/').pop() || entry.id;
const first = String(person.name || 'the crew').split(' ')[0];
const personSlug = crewSlug(person);
const scenes = ((editorialSurfaces as any).curatorActions?.[personSlug] || []) as any[];
const seed = [...slug].reduce((sum, char) => sum + char.charCodeAt(0), 0);
const scene = scenes[seed % Math.max(scenes.length, 1)] || { image: person.scene, alt: person.sceneAlt, task: person.currentObsession };
const conversation = (conversations as any)[personSlug] || {};
const steps = (conversation.diagnostic?.steps || []).slice(0, 3);
const warning = person.hillsToDieOn?.[seed % Math.max(person.hillsToDieOn?.length || 0, 1)] || person.favoriteWarning;
---

<aside class="curator-field-brief" data-bay={entry.data.bay}>
  <div class="cfb-scene">
    <img src={scene.image} alt={scene.alt} loading="lazy" decoding="async" />
    <span>AI editorial scene · real product proof stays real</span>
  </div>
  <div class="cfb-copy">
    <span class="lbl lbl-accent">Bench interruption · {person.handle}</span>
    <h2>{scene.task}</h2>
    <blockquote>&ldquo;{warning}&rdquo;</blockquote>
    <p>{person.benchMove}</p>
    {steps.length > 0 && (
      <ol aria-label={`${first}'s quick diagnostic`}>
        {steps.map((step: string, index: number) => <li><b>{index + 1}</b><span>{step}</span></li>)}
      </ol>
    )}
    <div class="cfb-actions">
      <button class="btn btn-primary" type="button" data-open-crew-chat data-crew-question="page_verdict">Ask {first} about this build</button>
      <a class="btn" href={`/curator/${personSlug}`}>Open {first}'s bench</a>
    </div>
    {proof && (
      <a class="cfb-proof" href={proof.href}>
        <img src={proof.image} alt={proof.name} loading="lazy" decoding="async" />
        <span><small>Real product proof</small><b>{proof.name}</b><em>Inspect the hardware</em></span>
      </a>
    )}
  </div>
</aside>

<style>
  .curator-field-brief { max-width: 1080px; margin: 28px auto 36px; display: grid; grid-template-columns: 1.08fr .92fr; min-height: 520px; overflow: hidden; border: 2px solid #101820; border-radius: 24px; color: #fff; background: #101820; box-shadow: 0 13px 0 color-mix(in srgb, var(--accent) 24%, rgba(16,24,32,.16)), 0 36px 80px rgba(16,24,32,.18); }
  .cfb-scene { position: relative; min-height: 520px; overflow: hidden; }
  .cfb-scene::after { content: ""; position: absolute; inset: 0; background: linear-gradient(90deg, transparent 55%, rgba(16,24,32,.34)), linear-gradient(180deg, transparent 65%, rgba(16,24,32,.6)); pointer-events: none; }
  .cfb-scene img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .cfb-scene > span { position: absolute; z-index: 1; left: 14px; bottom: 14px; padding: 7px 9px; color: #fff; background: rgba(16,24,32,.84); font-family: var(--font-mono); font-size: .5rem; letter-spacing: .07em; text-transform: uppercase; }
  .cfb-copy { align-self: center; min-width: 0; padding: 30px; }
  .cfb-copy h2 { margin-top: 10px; color: #fff; font-size: clamp(1.7rem, 3vw, 2.7rem); line-height: .98; text-transform: uppercase; }
  .cfb-copy blockquote { margin: 18px 0 10px; color: #fff; font-family: var(--font-disp); font-size: 1.15rem; line-height: 1.34; }
  .cfb-copy > p { color: rgba(255,255,255,.72); line-height: 1.55; }
  .cfb-copy ol { display: grid; gap: 8px; margin: 18px 0 0; padding: 0; list-style: none; }
  .cfb-copy li { display: grid; grid-template-columns: 28px minmax(0,1fr); gap: 9px; align-items: start; padding: 9px; color: #101820; background: rgba(255,255,255,.94); border-left: 3px solid var(--accent); }
  .cfb-copy li b { display: grid; place-items: center; width: 24px; height: 24px; color: #101820; background: var(--accent); font-family: var(--font-mono); font-size: .64rem; }
  .cfb-copy li span { padding-top: 2px; font-size: .78rem; line-height: 1.35; }
  .cfb-actions { display: flex; flex-wrap: wrap; gap: 9px; margin-top: 18px; }
  .cfb-actions .btn { min-height: 44px; }
  .cfb-proof { display: grid; grid-template-columns: 74px 1fr; gap: 11px; align-items: center; margin-top: 17px; padding: 9px; color: #101820; background: #fff; border: 1px solid rgba(255,255,255,.26); text-decoration: none; }
  .cfb-proof img { width: 74px; height: 64px; object-fit: contain; background: #f4f6f7; }
  .cfb-proof span { min-width: 0; }
  .cfb-proof small, .cfb-proof em { display: block; color: var(--accent); font-family: var(--font-mono); font-size: .5rem; font-style: normal; font-weight: 900; letter-spacing: .06em; text-transform: uppercase; }
  .cfb-proof b { display: block; margin: 3px 0; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
  @media (max-width: 820px) {
    .curator-field-brief { grid-template-columns: 1fr; min-height: 0; border-radius: 18px; }
    .cfb-scene { min-height: 330px; }
    .cfb-copy { padding: 24px 20px; }
  }
  @media (max-width: 480px) {
    .cfb-scene { min-height: 270px; }
    .cfb-actions { display: grid; }
    .cfb-actions .btn { width: 100%; }
  }
</style>
