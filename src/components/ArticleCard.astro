---
interface Props {
  href: string;
  title: string;
  excerpt?: string;
  type?: string;
  image?: string;
  imageAlt?: string;
  meta?: string;
}
import { getArticleCardArt, getBayFromHref } from '../lib/articleArt';
const { href, title, excerpt, type, image, imageAlt, meta } = Astro.props;
const typeLabel = (type || '').replace(/-/g, ' ');
const bay = getBayFromHref(href);
const art = getArticleCardArt(href);
const cardImage = art?.image || image;
const cardAlt = art?.alt || imageAlt || title;
const cardLabel = art?.label || 'Real product photo';
---
<a class="card article-world-card" data-bay={bay} href={href}>
  {cardImage && (
    <div class="cimg">
      <span class="world-chip">{cardLabel}</span>
      <img src={cardImage} alt={cardAlt} loading="lazy" decoding="async" />
    </div>
  )}
  <div class="cbody">
    {type && <span class="ctype">{typeLabel}</span>}
    <h3>{title}</h3>
    {excerpt && <p class="cexc">{excerpt}</p>}
    {meta && <span class="cmeta">{meta}</span>}
  </div>
</a>

<style>
  .card { color: inherit; }
  .article-world-card {
    --world-a: #ff5e1a;
    --world-b: #101820;
    --world-ink: #101820;
    border: 0;
    border-radius: 24px 24px 18px 18px;
    background:
      radial-gradient(480px 280px at 88% 0%, color-mix(in srgb, var(--world-a) 18%, transparent), transparent 70%),
      linear-gradient(145deg, #ffffff, #f6f8fb 54%, color-mix(in srgb, var(--world-a) 8%, #fff));
    box-shadow: 0 12px 0 rgba(16,24,32,.13), 0 32px 64px rgba(16,24,32,.13);
    overflow: hidden;
  }
  .article-world-card[data-bay="racing"] { --world-a: #ff4b16; --world-b: #111827; --world-ink: #3b1107; }
  .article-world-card[data-bay="golf"] { --world-a: #10b981; --world-b: #eab308; --world-ink: #073b28; }
  .article-world-card[data-bay="flight"] { --world-a: #0ea5e9; --world-b: #38bdf8; --world-ink: #082f49; }
  .article-world-card[data-bay="space"] { --world-a: #d946ef; --world-b: #22d3ee; --world-ink: #3b0764; }
  .article-world-card[data-bay="marine"] { --world-a: #14b8a6; --world-b: #0f766e; --world-ink: #042f2e; }
  .article-world-card:hover {
    transform: translateY(-6px);
    box-shadow: 0 14px 0 rgba(16,24,32,.16), 0 34px 72px color-mix(in srgb, var(--world-a) 20%, transparent);
  }
  .article-world-card .cimg {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 330px;
    padding: 34px 28px 30px;
    overflow: hidden;
    background:
      radial-gradient(420px 230px at 70% 18%, color-mix(in srgb, var(--world-a) 27%, transparent), transparent 72%),
      radial-gradient(460px 220px at 12% 100%, color-mix(in srgb, var(--world-b) 14%, transparent), transparent 70%),
      linear-gradient(135deg, color-mix(in srgb, var(--world-a) 11%, #fff), #fff 46%, color-mix(in srgb, var(--world-b) 12%, #fff)),
      repeating-linear-gradient(90deg, rgba(16,24,32,.05) 0 1px, transparent 1px 32px);
    border-bottom: 2px solid color-mix(in srgb, var(--world-a) 22%, rgba(16,24,32,.12));
  }
  .article-world-card .cimg::before {
    content: "";
    position: absolute;
    inset: auto 9% 22px 9%;
    height: 24%;
    border-radius: 999px;
    background:
      linear-gradient(90deg, color-mix(in srgb, var(--world-a) 22%, transparent), color-mix(in srgb, var(--world-b) 16%, transparent));
    filter: blur(20px);
    transform: perspective(500px) rotateX(58deg);
  }
  .article-world-card .cimg::after {
    content: "";
    position: absolute;
    inset: 14px;
    border: 1px solid color-mix(in srgb, var(--world-a) 16%, transparent);
    border-radius: 18px;
    pointer-events: none;
  }
  .article-world-card .cimg img {
    position: relative;
    z-index: 1;
    width: min(100%, 360px);
    height: 260px;
    object-fit: contain;
    mix-blend-mode: multiply;
    filter: drop-shadow(0 26px 30px rgba(16,24,32,.28));
    transition: transform .45s ease;
  }
  .article-world-card:hover .cimg img { transform: scale(1.08) rotate(-1deg); }
  .world-chip {
    position: absolute;
    left: 18px;
    top: 18px;
    z-index: 2;
    padding: 8px 11px;
    border-radius: 10px;
    background: linear-gradient(135deg, #101820, color-mix(in srgb, var(--world-ink) 70%, #101820));
    color: #fff;
    font-family: var(--font-mono);
    font-size: .54rem;
    font-weight: 900;
    letter-spacing: .12em;
    text-transform: uppercase;
    box-shadow: 0 8px 18px rgba(16,24,32,.2);
  }
  .article-world-card .cbody {
    padding: 26px 26px 28px;
    background:
      linear-gradient(180deg, rgba(255,255,255,.96), rgba(255,255,255,.99)),
      radial-gradient(260px 160px at 100% 0%, color-mix(in srgb, var(--world-a) 10%, transparent), transparent 72%);
  }
  .article-world-card .ctype {
    color: var(--world-a);
  }
  .article-world-card h3 {
    font-size: clamp(1.25rem, 2vw, 1.65rem);
    line-height: 1.06;
  }
  .article-world-card .cexc {
    color: #334155;
    font-size: .98rem;
    line-height: 1.55;
  }
  .article-world-card .cmeta {
    color: var(--world-a);
  }
  @media (max-width: 680px) {
    .article-world-card .cimg { min-height: 270px; padding: 26px 20px 24px; }
    .article-world-card .cimg img { height: 210px; }
  }
</style>
