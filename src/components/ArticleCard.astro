---
interface Props {
  href: string;
  title: string;
  excerpt?: string;
  type?: string;
  image?: string;
  imageAlt?: string;
  meta?: string;
}
const { href, title, excerpt, type, image, imageAlt, meta } = Astro.props;
const typeLabel = (type || '').replace(/-/g, ' ');
---
<a class="card" href={href}>
  <div class="cimg">
    {image
      ? <img src={image} alt={imageAlt || title} loading="lazy" decoding="async" />
      : <div class="cimg-fallback" aria-hidden="true"></div>}
  </div>
  <div class="cbody">
    {type && <span class="ctype">{typeLabel}</span>}
    <h3>{title}</h3>
    {excerpt && <p class="cexc">{excerpt}</p>}
    {meta && <span class="cmeta">{meta}</span>}
  </div>
</a>

<style>
  .card { color: inherit; }
  .cimg-fallback {
    width: 100%; height: 100%;
    background:
      radial-gradient(200px 140px at 80% 120%, var(--bayglow), transparent 70%),
      linear-gradient(160deg, var(--baypanel, var(--panel2)), var(--baybg, var(--panel)));
  }
  .cimg-fallback::after {
    content: ""; display: block; width: 100%; height: 100%; opacity: .3;
    background-image: linear-gradient(var(--line) 1px, transparent 1px), linear-gradient(90deg, var(--line) 1px, transparent 1px);
    background-size: 30px 30px;
  }
</style>
