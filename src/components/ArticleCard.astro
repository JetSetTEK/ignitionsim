---
interface Props {
  href: string;
  title: string;
  excerpt?: string;
  type?: string;
  image?: string;
  imageAlt?: string;
  meta?: string;
}
import { getArticleCardArt, getBayFromHref } from '../lib/articleArt';
const { href, title, excerpt, type, image, imageAlt, meta } = Astro.props;
const typeLabel = (type || '').replace(/-/g, ' ');
const bay = getBayFromHref(href);
const art = getArticleCardArt(href);
const cardImage = art?.image || image;
const cardAlt = art?.alt || imageAlt || title;
const cardLabel = art?.label || 'Product proof';
const isWideArt = Boolean(art?.wide);
---
<a class="card article-world-card" data-bay={bay} href={href}>
  {cardImage && (
    <div class:list={['cimg', isWideArt && 'is-wide-art']}>
      <span class="world-chip">{cardLabel}</span>
      <img src={cardImage} alt={cardAlt} loading="lazy" decoding="async" />
    </div>
  )}
  <div class="cbody">
    {type && <span class="ctype">{typeLabel}</span>}
    <h3>{title}</h3>
    {excerpt && <p class="cexc">{excerpt}</p>}
    {meta && <span class="cmeta">{meta}</span>}
  </div>
</a>

<style>
  .card { color: inherit; }
  .article-world-card {
    --world-a: #ff5e1a;
    --world-b: #101820;
    --world-ink: #101820;
    border: 0;
    border-radius: 18px;
    background: #fff;
    box-shadow: 0 9px 0 rgba(16,24,32,.1), 0 28px 58px rgba(16,24,32,.12);
    overflow: hidden;
    display: grid;
    grid-template-columns: minmax(250px, .95fr) minmax(0, 1fr);
    min-height: 286px;
  }
  .article-world-card[data-bay="racing"] { --world-a: #ff4b16; --world-b: #111827; --world-ink: #3b1107; }
  .article-world-card[data-bay="golf"] { --world-a: #10b981; --world-b: #eab308; --world-ink: #073b28; }
  .article-world-card[data-bay="flight"] { --world-a: #0ea5e9; --world-b: #38bdf8; --world-ink: #082f49; }
  .article-world-card[data-bay="space"] { --world-a: #d946ef; --world-b: #22d3ee; --world-ink: #3b0764; }
  .article-world-card[data-bay="marine"] { --world-a: #14b8a6; --world-b: #0f766e; --world-ink: #042f2e; }
  .article-world-card:hover {
    transform: translateY(-6px);
    box-shadow: 0 14px 0 rgba(16,24,32,.16), 0 34px 72px color-mix(in srgb, var(--world-a) 20%, transparent);
  }
  .article-world-card .cimg {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 286px;
    padding: 28px 24px;
    overflow: hidden;
    background:
      radial-gradient(420px 230px at 72% 14%, color-mix(in srgb, var(--world-a) 13%, transparent), transparent 72%),
      linear-gradient(135deg, #fff, #eef4f8);
    border-bottom: 2px solid color-mix(in srgb, var(--world-a) 22%, rgba(16,24,32,.12));
  }
  .article-world-card .cimg::before {
    content: "";
    position: absolute;
    inset: auto 14% 24px 14%;
    height: 24%;
    border-radius: 999px;
    background:
      linear-gradient(90deg, color-mix(in srgb, var(--world-a) 18%, transparent), rgba(16,24,32,.12));
    filter: blur(18px);
    transform: perspective(500px) rotateX(58deg);
  }
  .article-world-card .cimg::after {
    content: "";
    position: absolute;
    inset: 13px;
    border: 1px solid rgba(16,24,32,.08);
    border-radius: 14px;
    pointer-events: none;
  }
  .article-world-card .cimg img {
    position: relative;
    z-index: 1;
    width: min(100%, 360px);
    height: 235px;
    object-fit: contain;
    filter: drop-shadow(0 22px 28px rgba(16,24,32,.2));
    transition: transform .45s ease;
  }
  .article-world-card .cimg.is-wide-art {
    min-height: 286px;
    padding: 0;
    background: #101820;
  }
  .article-world-card .cimg.is-wide-art::before,
  .article-world-card .cimg.is-wide-art::after {
    display: none;
  }
  .article-world-card .cimg.is-wide-art img {
    width: 100%;
    max-width: none;
    height: 100%;
    min-height: 286px;
    object-fit: cover;
    filter: none;
  }
  .article-world-card:hover .cimg.is-wide-art img {
    transform: scale(1.025);
  }
  .article-world-card:hover .cimg img { transform: scale(1.08) rotate(-1deg); }
  .world-chip {
    position: absolute;
    left: 18px;
    top: 18px;
    z-index: 2;
    padding: 8px 11px;
    border: 1px solid #101820;
    border-radius: 8px;
    background: #ff5e1a;
    color: #101820;
    font-family: var(--font-mono);
    font-size: .54rem;
    font-weight: 900;
    letter-spacing: .12em;
    text-transform: uppercase;
    box-shadow: 0 8px 18px rgba(16,24,32,.2);
  }
  .article-world-card .cbody {
    padding: 22px 24px 26px;
    background: #fff;
    align-self: center;
  }
  .article-world-card .ctype {
    color: var(--world-a);
  }
  .article-world-card h3 {
    font-size: clamp(1.25rem, 2vw, 1.65rem);
    line-height: 1.06;
  }
  .article-world-card .cexc {
    color: #334155;
    font-size: .98rem;
    line-height: 1.55;
  }
  .article-world-card .cmeta {
    color: var(--world-a);
  }
  @media (max-width: 680px) {
    .article-world-card { grid-template-columns: 1fr; }
    .article-world-card .cimg { min-height: 270px; padding: 26px 20px 24px; }
    .article-world-card .cimg img { height: 210px; }
    .article-world-card .cimg.is-wide-art { min-height: 194px; padding: 0; }
    .article-world-card .cimg.is-wide-art img { height: 194px; min-height: 194px; }
    .article-world-card .cbody { padding: 18px; }
    .article-world-card h3 { font-size: 1.16rem; }
    .article-world-card .cexc {
      display: -webkit-box;
      -webkit-line-clamp: 2;
      -webkit-box-orient: vertical;
      overflow: hidden;
    }
  }
</style>
