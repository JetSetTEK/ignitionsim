---
/**
 * Horizontal, image-rich product rail — scroll-snap, arrow nav, reduced-motion safe.
 * items: [{ href, image, brand, model, price, priceNote?, type?, buyUrl, tag? }]
 */
interface Item { href: string; image?: string; brand: string; model: string; price?: number; priceNote?: string; type?: string; buyUrl: string; tag?: string; }
interface Props { items: Item[]; id?: string; }
const { items, id = 'gearrail' } = Astro.props;
const fmt = (n?: number) => (typeof n === 'number' ? '$' + n.toLocaleString('en-US') : '');
---
<div class="grail" id={id}>
  <div class="grail-track">
    {items.map((p) => (
      <div class="grail-card">
        <a class="grail-shot" href={p.href} aria-label={`${p.brand} ${p.model} review`}>
          {p.tag && <span class="grail-tag">{p.tag}</span>}
          {p.image
            ? <img src={p.image} alt={`${p.brand} ${p.model}`} loading="lazy" decoding="async" />
            : <span class="grail-fallback" aria-hidden="true"></span>}
        </a>
        <div class="grail-body">
          {p.type && <span class="grail-type">{p.type.replace(/-/g, ' ')}</span>}
          <a class="grail-name" href={p.href}>{p.brand} {p.model}</a>
          {(p.price || p.priceNote) && <span class="grail-price">{fmt(p.price)}{p.priceNote ? ` · ${p.priceNote}` : ''}</span>}
          <div class="grail-actions">
            <a class="grail-review" href={p.href}>Review ▸</a>
            <a class="grail-buy" href={p.buyUrl} target="_blank" rel="sponsored nofollow noopener" data-event="gearrail_amazon">Amazon ↗</a>
          </div>
        </div>
      </div>
    ))}
  </div>
  {items.length > 2 && (
    <>
      <button class="grail-nav prev" aria-label="Scroll left">‹</button>
      <button class="grail-nav next" aria-label="Scroll right">›</button>
    </>
  )}
</div>

<style>
  .grail { position: relative; margin: 4px 0; }
  .grail-track { display: flex; gap: 16px; overflow-x: auto; scroll-snap-type: x mandatory; scroll-behavior: smooth; padding: 4px 2px 14px; -ms-overflow-style: none; scrollbar-width: none; }
  .grail-track::-webkit-scrollbar { display: none; }
  .grail-card { flex: 0 0 248px; scroll-snap-align: start; border: 1px solid var(--line2); border-radius: 14px; overflow: hidden; background: var(--panel); display: flex; flex-direction: column; transition: border-color .25s, box-shadow .25s, transform .25s; }
  @media (prefers-reduced-motion: no-preference) { .grail-card:hover { transform: translateY(-4px); border-color: var(--accent); box-shadow: 0 14px 34px color-mix(in srgb, var(--accent) 15%, transparent); } }
  .grail-shot { position: relative; display: block; aspect-ratio: 16 / 11; overflow: hidden; background: var(--panel2); }
  .grail-shot img, .grail-fallback { width: 100%; height: 100%; object-fit: cover; display: block; transition: transform .4s; }
  .grail-fallback { background: radial-gradient(200px 140px at 80% 120%, var(--bayglow), transparent 70%), linear-gradient(160deg, var(--baypanel, var(--panel2)), var(--baybg, var(--panel))); }
  @media (prefers-reduced-motion: no-preference) { .grail-card:hover .grail-shot img { transform: scale(1.06); } }
  .grail-tag { position: absolute; top: 9px; left: 9px; z-index: 2; font-family: var(--font-mono); font-size: .52rem; letter-spacing: .12em; text-transform: uppercase; color: var(--night); background: var(--accent); padding: 4px 8px; border-radius: 6px; font-weight: 700; }
  .grail-body { padding: 13px 14px 15px; display: flex; flex-direction: column; gap: 6px; flex: 1; }
  .grail-type { font-family: var(--font-mono); font-size: .54rem; letter-spacing: .12em; text-transform: uppercase; color: var(--accent); }
  .grail-name { font-weight: 700; font-size: .98rem; line-height: 1.22; color: var(--txt); }
  .grail-name:hover { color: var(--accent); }
  .grail-price { font-family: var(--font-mono); font-size: .72rem; color: var(--dim); flex: 1; }
  .grail-actions { display: flex; gap: 8px; margin-top: 4px; }
  .grail-actions a { font-family: var(--font-mono); font-size: .66rem; letter-spacing: .03em; padding: 7px 11px; border-radius: 7px; text-decoration: none; }
  .grail-review { border: 1px solid var(--line2); color: var(--txt); }
  .grail-review:hover { border-color: var(--accent); color: var(--accent); }
  .grail-buy { background: var(--accent); color: var(--night); font-weight: 700; }
  .grail-buy:hover { filter: brightness(1.08); }
  .grail-nav { position: absolute; top: calc(50% - 20px); transform: translateY(-50%); z-index: 3; width: 40px; height: 40px; border-radius: 50%; border: 1px solid var(--line2); background: color-mix(in srgb, var(--night) 78%, transparent); color: var(--txt); font-size: 1.35rem; cursor: pointer; -webkit-backdrop-filter: blur(6px); backdrop-filter: blur(6px); display: flex; align-items: center; justify-content: center; }
  .grail-nav:hover { border-color: var(--accent); color: var(--accent); }
  .grail-nav.prev { left: -8px; } .grail-nav.next { right: -8px; }
  @media (max-width: 720px) { .grail-nav { display: none; } .grail-card { flex-basis: 76%; } }
</style>

<script>
  document.querySelectorAll<HTMLElement>('.grail').forEach((rail) => {
    const track = rail.querySelector<HTMLElement>('.grail-track')!;
    const step = () => Math.max(track.clientWidth * 0.8, 264);
    rail.querySelector('.next')?.addEventListener('click', () => track.scrollBy({ left: step(), behavior: 'smooth' }));
    rail.querySelector('.prev')?.addEventListener('click', () => track.scrollBy({ left: -step(), behavior: 'smooth' }));
  });
</script>
