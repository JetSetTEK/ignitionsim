---
import Logo from './Logo.astro';
import bays from '../data/bays.json';
interface Props { activeNav?: string; }
const { activeNav } = Astro.props;
---
<header class="site">
  <div class="wrap bar">
    <a href="/" class="brand" aria-label="IgnitionSim home">
      <Logo variant="horizontal" size={30} />
    </a>
    <nav class="primary" aria-label="Sim disciplines">
      {bays.map((b) => (
        <a href={`/${b.slug}`} aria-current={activeNav === b.slug ? 'page' : undefined}>{b.name}</a>
      ))}
      <a href="/games" aria-current={activeNav === 'games' ? 'page' : undefined}>Games</a>
      <a href="/build-stream" aria-current={activeNav === 'stream' ? 'page' : undefined}>Stream</a>
      <a href="/guides" aria-current={activeNav === 'guides' ? 'page' : undefined}>Guides</a>
    </nav>
    <a class="btn btn-ghost" href="/#build-bays">Start Here</a>
  </div>
</header>
