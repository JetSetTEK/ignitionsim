---
import catalog from '../data/catalog-racing.json';
// Merge deep product data (image, summary, pros, gear link) into each catalog
// item by id. Resilient glob so the build works before the data file exists.
const prodMods = import.meta.glob('/src/data/products/racing.json', { eager: true });
const products = ((Object.values(prodMods)[0] as any)?.default || []) as any[];
const pmap = Object.fromEntries(products.map((p) => [p.id, p]));
const enrich = (arr: any[]) => arr.map((o) => {
  const p = pmap[o.id];
  return p ? { ...o, image: p.image, summary: p.summary, pros: (p.pros || []).slice(0, 3), gearId: p.id, prating: p.rating?.overall } : o;
});
const enriched = {
  ...catalog,
  bases: enrich(catalog.bases), wheels: enrich(catalog.wheels),
  pedals: enrich(catalog.pedals), mounts: enrich(catalog.mounts),
};
---
<section id="cfg" class="cfg-section">
  <div class="cfg-top">
    <div class="tt">
      <h2>Racing Rig Configurator</h2>
      <span class="pill">● Compatibility-checked</span>
    </div>
    <span class="bayswitch">bay: <b>RACING</b> · carbon &amp; amber</span>
  </div>
  <div class="cfg-body">
    <div class="cfg-steps" id="cfg-steps"></div>
    <aside class="cfg-ledger">
      <h4>// Your Build</h4>
      <div id="cfg-ledger"></div>
      <div id="cfg-verdict" class="verdict none">Select a wheelbase to begin. We'll check every part against it.</div>
      <div class="total"><span class="tl">Est. total</span><span class="tv" id="cfg-total">$0</span></div>
      <div class="lbtns">
        <button class="lbtn" id="cfg-copy">⧉ Copy as forum post</button>
        <button class="lbtn" id="cfg-share">↗ Share build</button>
      </div>
      <button class="lbtn primary" id="cfg-buy" style="margin-top:8px">Get parts ▸</button>
    </aside>
  </div>
  <script type="application/json" id="cfg-catalog" set:html={JSON.stringify(enriched)}></script>
</section>

<style is:global>
  .cfg-section { margin: 40px 0 26px; border: 1px solid var(--line2); border-radius: 18px; overflow: hidden; background: var(--panel); box-shadow: 0 18px 48px rgba(15,23,42,.08); }
  .cfg-top { display: flex; align-items: center; justify-content: space-between; padding: 18px 24px; border-bottom: 1px solid var(--line); background: linear-gradient(180deg, var(--baypanel), var(--baybg)); flex-wrap: wrap; gap: 10px; }
  .cfg-top .tt { display: flex; align-items: center; gap: 13px; flex-wrap: wrap; }
  .cfg-top h2 { font-size: 1.35rem; color: var(--txt); }
  .cfg-top .pill { font-family: var(--font-mono); font-size: .6rem; letter-spacing: .14em; text-transform: uppercase; color: var(--accent); border: 1px solid color-mix(in srgb, var(--accent) 40%, transparent); padding: 4px 10px; border-radius: 20px; }
  .cfg-top .bayswitch { font-family: var(--font-mono); font-size: .64rem; color: var(--dim); letter-spacing: .08em; }
  .cfg-top .bayswitch b { color: var(--accent); }
  .cfg-body { display: grid; grid-template-columns: 1fr 350px; gap: 0; }
  .cfg-steps { padding: 20px 24px 26px; border-right: 1px solid var(--line); }
  .step { margin-bottom: 22px; }
  .step-h { display: flex; align-items: center; gap: 10px; margin-bottom: 12px; }
  .step-n { width: 24px; height: 24px; border-radius: 6px; background: color-mix(in srgb, var(--accent) 14%, transparent); color: var(--accent); font-family: var(--font-mono); font-weight: 700; font-size: .78rem; display: flex; align-items: center; justify-content: center; }
  .step-h h4 { font-family: var(--font-disp); font-weight: 700; font-size: 1.04rem; text-transform: uppercase; letter-spacing: .04em; }
  .opts { display: grid; grid-template-columns: repeat(auto-fill, minmax(160px, 1fr)); gap: 8px; }
  .opt { position: relative; border: 1px solid var(--line2); border-radius: 10px; padding: 11px 12px; cursor: pointer; background: var(--panel); transition: border-color .15s, background .15s; }
  .opt:hover { border-color: var(--accent); }
  .opt.sel { border-color: var(--accent); background: color-mix(in srgb, var(--accent) 8%, transparent); box-shadow: inset 0 0 0 1px color-mix(in srgb, var(--accent) 40%, transparent); }
  .opt.disabled { opacity: .32; cursor: not-allowed; }
  .opt .ob { font-family: var(--font-mono); font-size: .6rem; color: var(--dim); letter-spacing: .06em; text-transform: uppercase; }
  .opt .om { font-weight: 600; font-size: .92rem; margin: 2px 0 4px; color: var(--txt); }
  .opt .op { font-family: var(--font-mono); font-size: .82rem; color: var(--accent); }
  .opt .ospec { font-family: var(--font-mono); font-size: .58rem; color: var(--dimmer); margin-top: 3px; }
  .opt .flag { position: absolute; top: 9px; right: 9px; font-size: .62rem; }
  .dot { width: 8px; height: 8px; border-radius: 50%; display: inline-block; }
  .compat-line { font-family: var(--font-mono); font-size: .66rem; margin-top: 7px; display: flex; align-items: center; gap: 6px; color: var(--dim); }
  .opt-img { width: 100%; aspect-ratio: 16/10; border-radius: 7px; overflow: hidden; margin-bottom: 9px; background: var(--panel2); border: 1px solid var(--line); }
  .opt-img img { width: 100%; height: 100%; object-fit: contain; background:#fff; }
  .opt-more { margin-top: 9px; font-family: var(--font-mono); font-size: .56rem; letter-spacing: .12em; text-transform: uppercase; color: var(--dim); background: none; border: none; cursor: pointer; padding: 2px 0; }
  .opt-more:hover { color: var(--accent); }
  .opt-detail { display: none; margin-top: 8px; border-top: 1px dashed var(--line); padding-top: 9px; }
  .opt.show-detail .opt-detail { display: block; }
  .opt-detail p { font-size: .74rem; color: var(--dim); line-height: 1.55; }
  .opt-detail ul { margin: 7px 0; padding-left: 1em; }
  .opt-detail li { font-size: .72rem; color: #475569; margin: 3px 0; }
  .opt-detail li::marker { color: var(--green); }
  .opt-detail a { font-family: var(--font-mono); font-size: .66rem; color: var(--accent); display: inline-block; margin-top: 4px; }
  .cfg-ledger { padding: 22px 22px 26px; background: linear-gradient(180deg, #fff, var(--panel2)); display: flex; flex-direction: column; }
  .cfg-ledger h4 { font-family: var(--font-mono); text-transform: uppercase; letter-spacing: .18em; font-size: .66rem; color: var(--dim); margin-bottom: 16px; }
  .lrow { display: flex; justify-content: space-between; gap: 10px; padding: 9px 0; border-bottom: 1px dashed var(--line); font-size: .84rem; }
  .lrow .ln { color: var(--dim); font-family: var(--font-mono); font-size: .62rem; text-transform: uppercase; letter-spacing: .08em; }
  .lrow .lv { text-align: right; }
  .lrow .lv .nm { font-weight: 600; }
  .lrow .lv .pr { font-family: var(--font-mono); color: var(--accent); font-size: .8rem; }
  .lrow.empty .lv { color: var(--dimmer); font-style: italic; }
  .verdict { margin: 16px 0; padding: 13px 15px; border-radius: 10px; font-family: var(--font-mono); font-size: .72rem; line-height: 1.5; border: 1px solid; }
  .verdict.green { background: rgba(52,211,153,.11); border-color: rgba(16,185,129,.45); color: #047857; }
  .verdict.amber { background: rgba(245,158,11,.12); border-color: rgba(245,158,11,.45); color: #92400e; }
  .verdict.none { background: var(--panel); border-color: var(--line2); color: var(--dim); }
  .total { display: flex; justify-content: space-between; align-items: baseline; margin-top: auto; padding-top: 14px; }
  .total .tl { font-family: var(--font-mono); text-transform: uppercase; letter-spacing: .14em; font-size: .66rem; color: var(--dim); }
  .total .tv { font-family: var(--font-disp); font-weight: 800; font-size: 1.9rem; color: var(--txt); }
  .lbtns { display: flex; gap: 8px; margin-top: 14px; }
  .lbtn { flex: 1; font-family: var(--font-mono); font-size: .66rem; text-transform: uppercase; letter-spacing: .08em; padding: 11px; border-radius: 8px; cursor: pointer; text-align: center; border: 1px solid var(--line2); background: var(--panel); color: var(--txt); }
  .lbtn.primary { background: linear-gradient(135deg, var(--ember), #E0490F); border: none; color: #fff; font-weight: 700; width: 100%; }
  .lbtn:hover { border-color: var(--accent); }
  .lbtn.primary:hover { filter: brightness(1.08); }
  @media (max-width: 880px) { .cfg-body { grid-template-columns: 1fr; } .cfg-steps { border-right: none; border-bottom: 1px solid var(--line); } }
</style>

<script>
  type Item = Record<string, any>;
  const CAT = JSON.parse(document.getElementById('cfg-catalog')!.textContent || '{}');
  const sel: Record<string, Item | null> = { base: null, wheel: null, pedals: null, mount: null };
  const KEYS: Record<string, Item[]> = { base: CAT.bases, wheel: CAT.wheels, pedals: CAT.pedals, mount: CAT.mounts };

  function qrCompat(baseQR: string, wheelQR: string) {
    if (!baseQR || !wheelQR) return { s: 'none', t: '' };
    if (wheelQR.startsWith('universal')) return { s: 'green', t: 'Universal 70mm — bolts to an adapter hub' };
    if (baseQR === wheelQR) return { s: 'green', t: 'Same ecosystem — plug & play' };
    return { s: 'amber', t: 'Cross-brand — quick-release adapter required' };
  }
  function dotHtml(s: string) {
    const c = s === 'green' ? 'var(--green)' : s === 'amber' ? 'var(--amber)' : s === 'red' ? 'var(--red)' : 'var(--dimmer)';
    return `<span class="dot" style="background:${c}"></span>`;
  }
  const esc = (s: any) => String(s).replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;');

  function stepBlock(n: number, title: string, key: string, items: Item[], mapper: (o: Item) => any) {
    let h = `<div class="step"><div class="step-h"><span class="step-n">${n}</span><h4>${title}</h4></div><div class="opts">`;
    items.forEach((o) => {
      const m = mapper(o);
      const seld = sel[key] && sel[key]!.id === o.id ? ' sel' : '';
      const disd = m.disabled ? ' disabled' : '';
      const pros = Array.isArray(o.pros) ? o.pros : [];
      h += `<div class="opt${seld}${disd}" data-key="${key}" data-id="${o.id}">`
        + (m.flag ? `<span class="flag">${m.flag}</span>` : '')
        + (o.image ? `<div class="opt-img"><img src="${o.image}" alt="" loading="lazy"></div>` : '')
        + `<div class="ob">${esc(m.band)}</div><div class="om">${esc(m.model)}</div>`
        + `<div class="op">${typeof m.price === 'number' ? '$' + m.price : esc(m.price)}${o.prating ? ` · ${o.prating}/10` : ''}</div>`
        + `<div class="ospec">${esc(m.spec)}</div>`
        + (m.line ? `<div class="compat-line">${m.flag || ''} ${esc(m.line)}</div>` : '')
        + (o.summary
            ? `<button class="opt-more" type="button">details ▾</button><div class="opt-detail">`
              + `<p>${esc(o.summary)}</p>`
              + (pros.length ? `<ul>${pros.map((x: string) => `<li>${esc(x)}</li>`).join('')}</ul>` : '')
              + (o.gearId ? `<a href="/${CAT.bay}/gear/${o.gearId}">Full review →</a>` : '')
              + `</div>`
            : '')
        + `</div>`;
    });
    return h + '</div></div>';
  }

  function render() {
    const steps = document.getElementById('cfg-steps')!;
    let html = '';
    html += stepBlock(1, 'Wheelbase', 'base', CAT.bases, (o: Item) => ({
      band: o.brand, model: o.model, price: o.price, spec: `${o.torque} Nm · ${o.eco} · ${o.platforms || 'PC'}`,
    }));
    html += stepBlock(2, 'Wheel', 'wheel', CAT.wheels, (o: Item) => {
      let flag = '', line = '';
      if (sel.base) { const c = qrCompat(sel.base.qr, o.qr); flag = dotHtml(c.s); line = c.t; }
      return { band: o.brand, model: o.model, price: o.price === 0 ? 'incl.' : o.price, spec: o.eco, flag, line };
    });
    html += stepBlock(3, 'Pedals', 'pedals', CAT.pedals, (o: Item) => {
      const spec = `${o.hydraulic ? 'Hydraulic' : o.loadcell ? 'Load cell' : 'Potentiometer'} · ${o.conn === 'via-base' ? 'via base' : 'USB'}`;
      let flag = dotHtml('green'), line = 'Universal — works with any base';
      if (o.conn === 'via-base' && sel.base && o.eco !== sel.base.eco && o.eco !== 'Universal') {
        flag = dotHtml('amber'); line = `${o.brand} pedals plug into ${o.brand} bases; on others use a USB pedal set`;
      }
      return { band: o.brand, model: o.model, price: o.price, spec, flag, line };
    });
    html += stepBlock(4, 'Mount / Cockpit', 'mount', CAT.mounts, (o: Item) => {
      let flag = '', line = '', dis = false;
      if (sel.base) {
        const needs4bolt = sel.base.torque > 9;
        if (o.fit === 'clamp-ok' && needs4bolt) { flag = dotHtml('red'); line = `Too much torque (${sel.base.torque} Nm) for a desk clamp — needs a cockpit`; dis = true; }
        else if (o.maxtorque < sel.base.torque) { flag = dotHtml('red'); line = `Rated to ${o.maxtorque} Nm — under your base`; dis = true; }
        else { flag = dotHtml('green'); line = `Handles ${sel.base.torque} Nm comfortably`; }
      }
      return { band: o.brand, model: o.model, price: o.price === 0 ? 'incl.' : o.price, spec: o.note || `${o.maxtorque} Nm max`, flag, line, disabled: dis };
    });
    steps.innerHTML = html;
    renderLedger();
  }

  function pick(key: string, id: string) {
    const o = (KEYS[key] || []).find((x) => x.id === id);
    if (!o) return;
    sel[key] = o;
    if (key === 'base' && sel.mount) {
      const mt = sel.mount;
      if ((mt.fit === 'clamp-ok' && sel.base!.torque > 9) || (mt.maxtorque < sel.base!.torque)) sel.mount = null;
    }
    render();
    writeHash();
  }

  function renderLedger() {
    const L = document.getElementById('cfg-ledger')!;
    const rows: [string, string][] = [['Base', 'base'], ['Wheel', 'wheel'], ['Pedals', 'pedals'], ['Mount', 'mount']];
    let total = 0, html = '';
    rows.forEach(([label, key]) => {
      const o = sel[key];
      if (o) {
        const p = o.price || 0; total += p;
        html += `<div class="lrow"><span class="ln">${label}</span><span class="lv"><div class="nm">${esc(o.brand)} ${esc(o.model)}</div><div class="pr">${p === 0 ? 'included' : '$' + p}</div></span></div>`;
      } else {
        html += `<div class="lrow empty"><span class="ln">${label}</span><span class="lv">not selected</span></div>`;
      }
    });
    L.innerHTML = html;
    document.getElementById('cfg-total')!.textContent = '$' + total.toLocaleString();
    const v = document.getElementById('cfg-verdict')!;
    if (!sel.base) { v.className = 'verdict none'; v.textContent = "Select a wheelbase to begin. We'll check every part against it."; return; }
    const issues: string[] = [];
    if (sel.wheel) { const c = qrCompat(sel.base.qr, sel.wheel.qr); if (c.s === 'amber') issues.push('Wheel needs a QR adapter (cross-brand).'); }
    if (sel.pedals && sel.pedals.conn === 'via-base' && sel.pedals.eco !== 'Universal' && sel.pedals.eco !== sel.base.eco)
      issues.push(`${sel.pedals.brand} pedals connect via ${sel.pedals.brand} bases — confirm the port or use a USB set.`);
    if (issues.length === 0 && sel.wheel && sel.pedals && sel.mount) {
      v.className = 'verdict green';
      v.innerHTML = '✓ All compatible. This rig is plug-and-play' + (sel.base.eco !== 'Universal' ? ` within the ${sel.base.eco} ecosystem.` : '.');
    } else if (issues.length) {
      v.className = 'verdict amber';
      v.innerHTML = '⚠ Works, with notes:<br>· ' + issues.map(esc).join('<br>· ');
    } else {
      v.className = 'verdict none';
      v.textContent = 'Keep going — add a wheel, pedals and a mount for a full compatibility check.';
    }
  }

  // ---- shareable build via URL hash ----
  function writeHash() {
    const p = new URLSearchParams();
    (['base', 'wheel', 'pedals', 'mount'] as const).forEach((k) => { if (sel[k]) p.set(k[0], sel[k]!.id); });
    const h = p.toString();
    history.replaceState(null, '', h ? '#' + h : location.pathname + location.search);
  }
  function readHash() {
    const p = new URLSearchParams(location.hash.slice(1));
    const map: Record<string, string> = { b: 'base', w: 'wheel', p: 'pedals', m: 'mount' };
    Object.entries(map).forEach(([abbr, key]) => {
      const id = p.get(abbr); if (!id) return;
      const o = (KEYS[key] || []).find((x) => x.id === id); if (o) sel[key] = o;
    });
  }

  function buildMarkup() {
    if (!sel.base) return '';
    const lines = ['[b]My IgnitionSim rig[/b]'];
    let total = 0;
    (['base', 'wheel', 'pedals', 'mount'] as const).forEach((k) => {
      const o = sel[k]; if (!o) return; const p = o.price || 0; total += p;
      lines.push(`• ${k.charAt(0).toUpperCase() + k.slice(1)}: ${o.brand} ${o.model}${p ? ` ($${p})` : ''}`);
    });
    lines.push(`• Est. total: $${total.toLocaleString()}`);
    lines.push(`Built + compatibility-checked at ${location.origin}${location.pathname}${location.hash}`);
    return lines.join('\n');
  }

  function init() {
    readHash();
    render();
    document.getElementById('cfg-steps')!.addEventListener('click', (e) => {
      const t = e.target as HTMLElement;
      const more = t.closest('.opt-more') as HTMLElement | null;
      if (more) { more.closest('.opt')!.classList.toggle('show-detail'); return; }
      if (t.closest('.opt-detail')) return;   // drawer clicks never select; the review link works via default
      const opt = t.closest('.opt') as HTMLElement | null;
      if (!opt || opt.classList.contains('disabled')) return;
      pick(opt.dataset.key!, opt.dataset.id!);
    });
    document.getElementById('cfg-copy')!.addEventListener('click', async () => {
      const md = buildMarkup();
      if (!md) { (window as any).toast?.('Pick some parts first'); return; }
      try { await navigator.clipboard.writeText(md); (window as any).toast?.('Build copied — paste into Reddit/forums'); }
      catch { (window as any).toast?.('Copy failed — select and copy manually'); }
    });
    document.getElementById('cfg-share')!.addEventListener('click', async () => {
      if (!sel.base) { (window as any).toast?.('Pick a wheelbase first'); return; }
      writeHash();
      try { await navigator.clipboard.writeText(location.href); (window as any).toast?.('Share link copied to clipboard'); }
      catch { (window as any).toast?.('Link is in your address bar'); }
    });
    document.getElementById('cfg-buy')!.addEventListener('click', () => {
      (window as any).toast?.('Affiliate link routing ships with launch — coming soon');
    });
  }
  init();
</script>
