---
import Base from '../../layouts/Base.astro';
import ArticleCard from '../../components/ArticleCard.astro';
import { getCollection } from 'astro:content';
import { isCertifiedArticle, sortNewestArticles } from '../../lib/content';
import bays from '../../data/bays.json';
import site from '../../data/site.json';
import { getWorldForBay } from '../../lib/worlds';

const all = sortNewestArticles(await getCollection('articles', ({ data }) => isCertifiedArticle(data)));
const slug = (a: any) => a.id.split('/').pop();
const byBay = bays.map((b) => ({ bay: b, items: all.filter((a) => a.data.bay === b.slug) })).filter((g) => g.items.length);

const schema = [{
  '@context': 'https://schema.org', '@type': 'ItemList',
  name: 'IgnitionSim guides & reviews',
  numberOfItems: all.length,
  itemListElement: all.map((a, i) => ({
    '@type': 'ListItem', position: i + 1, name: a.data.title,
    url: new URL(`/${a.data.bay}/${slug(a)}`, site.url).href,
  })),
}];
---
<Base title="All Guides & Reviews" description={`Every IgnitionSim buying guide, comparison, how-to and ecosystem deep-dive — ${all.length} in-depth articles across racing, flight, space, marine and golf.`} schema={schema} activeNav="guides">
  <div class="guide-archive">
  <div class="wrap">
    <div class="crumbs"><a href="/">Home</a><span>/</span>Guides</div>
    <section class="guide-hero">
      <div class="lbl lbl-accent">// {all.length} in-depth guides &amp; reviews</div>
      <h1>Guides &amp; reviews</h1>
      <p>Buying guides, head-to-head comparisons, ecosystem upgrade paths, how-tos and DIY. Every public piece has to help you build the room, avoid the trap, and buy with adult supervision.</p>
    </section>
    {byBay.map((g) => (
      <section class="guide-bay" data-bay={g.bay.slug} style={`--world-bg: url('${getWorldForBay(g.bay.slug).image}')`}>
        <div class="sec-head"><h2>{g.bay.name}</h2><a class="lbl" href={`/${g.bay.slug}`}>{g.items.length} guides · the {g.bay.name} bay →</a></div>
        <div class="card-grid">
          {g.items.map((a) => (
            <ArticleCard href={`/${g.bay.slug}/${slug(a)}`} title={a.data.title}
              excerpt={a.data.excerpt || a.data.description} type={a.data.type}
              image={a.data.heroImage} imageAlt={a.data.heroAlt}
              meta={`${a.data.readingTime || 7} min read`} />
          ))}
        </div>
      </section>
    ))}
  </div>
  </div>
</Base>

<style>
  .guide-archive {
    position: relative;
    overflow: hidden;
    padding: 30px 0 60px;
  }
  .guide-archive::before {
    content: "";
    position: absolute;
    inset: 0;
    pointer-events: none;
    background:
      radial-gradient(680px 360px at 6% 0%, rgba(56,189,248,.16), transparent 70%),
      radial-gradient(760px 420px at 94% 8%, rgba(255,75,22,.13), transparent 70%),
      radial-gradient(620px 340px at 78% 100%, rgba(16,185,129,.12), transparent 72%);
  }
  .guide-hero {
    position: relative;
    margin: 8px 0 34px;
    padding: clamp(30px, 5vw, 54px);
    overflow: hidden;
    border: 2px solid #101820;
    border-radius: 28px;
    background:
      linear-gradient(120deg, rgba(16,24,32,.94), rgba(16,24,32,.78) 48%, rgba(255,94,26,.82)),
      repeating-linear-gradient(90deg, rgba(255,255,255,.08) 0 1px, transparent 1px 36px);
    color: #fff;
    box-shadow: 0 12px 0 rgba(16,24,32,.16), 0 34px 72px rgba(16,24,32,.18);
  }
  .guide-hero::after {
    content: "";
    position: absolute;
    right: -90px;
    bottom: -150px;
    width: 420px;
    height: 420px;
    border: 34px solid rgba(255,255,255,.08);
    border-radius: 50%;
  }
  .guide-hero h1 {
    position: relative;
    z-index: 1;
    margin-top: 14px;
    max-width: 12ch;
    color: #fff;
    font-size: clamp(2.45rem, 6vw, 4.8rem);
    line-height: .94;
    text-transform: uppercase;
  }
  .guide-hero p {
    position: relative;
    z-index: 1;
    max-width: 66ch;
    margin-top: 18px;
    color: rgba(255,255,255,.86);
    font-size: 1.06rem;
  }
  .guide-bay {
    --bay-a: #ff5e1a;
    --bay-b: #101820;
    position: relative;
    margin: 26px -18px 36px;
    padding: 34px 18px 40px;
    overflow: hidden;
    border: 2px solid color-mix(in srgb, var(--bay-a) 42%, rgba(255,255,255,.18));
    border-radius: 34px;
    background:
      radial-gradient(820px 380px at 88% 8%, color-mix(in srgb, var(--bay-a) 22%, transparent), transparent 70%),
      linear-gradient(90deg, rgba(16,24,32,.92), rgba(16,24,32,.58) 48%, rgba(16,24,32,.34)),
      var(--world-bg) center / cover no-repeat;
    box-shadow: 0 14px 0 rgba(16,24,32,.16), 0 40px 90px color-mix(in srgb, var(--bay-a) 15%, transparent);
  }
  .guide-bay::after {
    content: "";
    position: absolute;
    inset: 0;
    pointer-events: none;
    background:
      linear-gradient(rgba(255,255,255,.055) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255,255,255,.04) 1px, transparent 1px);
    background-size: 46px 46px;
    opacity: .36;
    mix-blend-mode: screen;
  }
  .guide-bay > * { position: relative; z-index: 1; }
  .guide-bay[data-bay="racing"] { --bay-a: #ff4b16; --bay-b: #101820; }
  .guide-bay[data-bay="golf"] { --bay-a: #10b981; --bay-b: #eab308; }
  .guide-bay[data-bay="flight"] { --bay-a: #0ea5e9; --bay-b: #38bdf8; }
  .guide-bay[data-bay="space"] { --bay-a: #d946ef; --bay-b: #22d3ee; }
  .guide-bay[data-bay="marine"] { --bay-a: #14b8a6; --bay-b: #0f766e; }
  .guide-bay .sec-head h2 {
    color: #fff;
    font-size: clamp(1.9rem, 4vw, 3.2rem);
    text-transform: uppercase;
    text-shadow: 0 2px 18px rgba(0,0,0,.32);
  }
  .guide-bay .sec-head a {
    color: color-mix(in srgb, var(--bay-a) 72%, #fff);
  }
  .guide-bay .card-grid {
    gap: 24px;
    grid-template-columns: repeat(auto-fit, minmax(min(100%, 560px), 1fr));
  }
  @media (max-width: 760px) {
    .guide-archive { padding-top: 18px; }
    .guide-bay { margin-inline: 0; padding-inline: 12px; border-radius: 20px; }
    .guide-bay .card-grid { grid-template-columns: 1fr; }
  }
</style>
