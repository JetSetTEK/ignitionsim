---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';
import site from '../../data/site.json';
import bays from '../../data/bays.json';
import games from '../../data/games.json';
import { isCertifiedArticle } from '../../lib/content';
import { getWorldForBay } from '../../lib/worlds';

const certified = await getCollection('articles', ({ data }) => isCertifiedArticle(data));
const articleMap = new Map(certified.map((a) => [a.id, a]));
const slug = (a: any) => a.id.split('/').pop();
const bayMap = new Map(bays.map((b) => [b.slug, b]));
const grouped = bays
  .map((bay) => ({
    bay,
    world: getWorldForBay(bay.slug),
    games: (games as any[])
      .filter((g) => g.bay === bay.slug)
      .map((g) => ({
        ...g,
        guides: (g.guideIds || []).map((id: string) => articleMap.get(id)).filter(Boolean),
      })),
  }))
  .filter((group) => group.games.length);

const featured = (games as any[])
  .filter((g) => ['iracing', 'gspro', 'assetto-corsa-evo', 'microsoft-flight-simulator-2024', 'star-citizen', 'bridge-command'].includes(g.slug))
  .map((g) => ({ ...g, bayData: bayMap.get(g.bay), world: getWorldForBay(g.bay) }));

const description = 'IgnitionSim simulator games hub: the racing, golf, flight, space, and marine sims worth building hardware around, with buyer-map links and setup traps.';
const schema = [{
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: 'Simulator Games Hub',
  description,
  url: new URL('/games', site.url).href,
  hasPart: (games as any[]).map((g) => ({
    '@type': 'VideoGame',
    name: g.name,
    genre: g.type,
    url: g.officialUrl,
  })),
}, {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: 'Popular simulator games and sports for hardware builders',
  numberOfItems: (games as any[]).length,
  itemListElement: (games as any[]).map((g, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    name: g.name,
    url: g.officialUrl,
  })),
}];
---
<Base title="Simulator Games Hub" description={description} image="/images/worlds/racing-world.webp" schema={schema} activeNav="games">
  <div class="games-page">
    <section class="games-hero" style={`--world-bg: url('${getWorldForBay('racing').image}')`}>
      <div class="games-hero-scrim"></div>
      <div class="wrap games-hero-inner">
        <div class="crumbs"><a href="/">Home</a><span>/</span>Games</div>
        <span class="lbl lbl-accent">Simulator games hub</span>
        <h1>The games worth building hardware around.</h1>
        <p>Some games are weekend distractions. These are the sims that make people buy wheelbases, launch monitors, yokes, sticks, mounts, screens, pedals, projectors, and occasionally a second apology to the family budget.</p>
        <div class="hero-actions">
          <a class="btn btn-primary btn-lg" href="#sim-worlds">Browse sim worlds</a>
          <a class="btn btn-lg" href="/guides">Open certified guides</a>
        </div>
      </div>
    </section>

    <div class="wrap">
      <section class="games-signal-strip" aria-label="Games hub promise">
        <div><b>{(games as any[]).length}</b><span>games and sim platforms</span></div>
        <div><b>5</b><span>hardware worlds</span></div>
        <div><b>{certified.length}</b><span>certified buyer guides</span></div>
        <div><b>{(games as any[]).length}</b><span>official source links</span></div>
      </section>

      <section class="sec games-featured" style={`--world-bg: url('${getWorldForBay('space').image}')`}>
        <div class="sec-head">
          <div>
            <span class="lbl lbl-accent">Where the rigs come from</span>
            <h2>Game first. Hardware second. Regret last.</h2>
          </div>
          <span class="lbl">official links + certified routes</span>
        </div>
        <div class="featured-game-grid">
          {featured.map((g) => (
            <article class="featured-game" data-bay={g.bay} style={`--world-bg: url('${g.world.image}')`}>
              <div>
                <span>{g.bayData?.name || g.bay}</span>
                <h3>{g.name}</h3>
                <p>{g.signal}</p>
              </div>
              <a href={`#${g.bay}`}>Build around it</a>
            </article>
          ))}
        </div>
      </section>

      <section class="sec games-bays" id="sim-worlds">
        <div class="sec-head">
          <div>
            <span class="lbl lbl-accent">Sim worlds</span>
            <h2>Pick the game. Then pick the gear that makes it feel alive.</h2>
          </div>
          <span class="lbl">SEO path: simulator games by hardware need</span>
        </div>

        {grouped.map(({ bay, world, games }) => (
          <section class="game-bay" id={bay.slug} data-bay={bay.slug} style={`--world-bg: url('${world.image}')`}>
            <div class="game-bay-head">
              <div>
                <span class="lbl lbl-accent">{bay.name} games</span>
                <h2>{bay.tagline}</h2>
                <p>{world.mood}</p>
              </div>
              <a class="btn btn-ghost" href={`/${bay.slug}`}>Open {bay.name} bay</a>
            </div>

            <div class="game-grid">
              {games.map((game: any) => (
                <article class="game-card" data-bay={game.bay}>
                  <div class="game-topline">
                    <span>{game.type}</span>
                    <a href={game.officialUrl} target="_blank" rel="noopener">Official site</a>
                  </div>
                  <h3>{game.name}</h3>
                  <p class="signal">{game.signal}</p>
                  <div class="game-decisions">
                    <div>
                      <b>Best for</b>
                      <p>{game.bestFor}</p>
                    </div>
                    <div>
                      <b>Hardware that matters</b>
                      <p>{game.hardwareThatMatters}</p>
                    </div>
                    <div class="watch">
                      <b>Watch the trap</b>
                      <p>{game.watchTheTrap}</p>
                    </div>
                  </div>
                  {game.guides.length > 0 ? (
                    <div class="guide-links">
                      <span>Certified routes</span>
                      {game.guides.map((guide: any) => (
                        <a href={`/${guide.data.bay}/${slug(guide)}`}>{guide.data.title}</a>
                      ))}
                    </div>
                  ) : (
                    <div class="guide-links empty">
                      <span>Certified routes</span>
                      <a href={`/${game.bay}`}>Start with the {bay.name} hardware bay</a>
                    </div>
                  )}
                </article>
              ))}
            </div>
          </section>
        ))}
      </section>
    </div>
  </div>
</Base>

<style>
  .games-page {
    position: relative;
    overflow: hidden;
    padding-bottom: 70px;
  }
  .games-page::before {
    content: "";
    position: absolute;
    inset: 0;
    pointer-events: none;
    background:
      radial-gradient(780px 380px at 8% 5%, rgba(255,94,26,.14), transparent 72%),
      radial-gradient(840px 420px at 92% 10%, rgba(56,189,248,.13), transparent 70%),
      radial-gradient(760px 420px at 72% 100%, rgba(16,185,129,.13), transparent 72%);
  }
  .games-page > * { position: relative; z-index: 1; }
  .games-hero {
    position: relative;
    min-height: min(760px, 84vh);
    display: grid;
    align-items: end;
    overflow: hidden;
    margin-top: -72px;
    padding: 120px 0 56px;
    color: #fff;
    background:
      linear-gradient(90deg, rgba(10,14,23,.96), rgba(10,14,23,.62) 48%, rgba(10,14,23,.22)),
      var(--world-bg) center / cover no-repeat;
    box-shadow: inset 0 -120px 110px rgba(245,248,251,1);
  }
  .games-hero::after {
    content: "";
    position: absolute;
    inset: 0;
    pointer-events: none;
    background:
      radial-gradient(660px 380px at 76% 18%, rgba(255,94,26,.28), transparent 72%),
      linear-gradient(rgba(255,255,255,.055) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255,255,255,.04) 1px, transparent 1px);
    background-size: auto, 48px 48px, 48px 48px;
    mix-blend-mode: screen;
    opacity: .75;
  }
  .games-hero-scrim {
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, rgba(10,14,23,.15), rgba(10,14,23,.42));
  }
  .games-hero-inner {
    position: relative;
    z-index: 1;
    max-width: 1020px;
  }
  .games-hero .crumbs,
  .games-hero .crumbs a {
    color: rgba(255,255,255,.72);
  }
  .games-hero h1 {
    max-width: 11ch;
    margin-top: 14px;
    color: #fff;
    font-size: clamp(3rem, 7vw, 7.4rem);
    line-height: .86;
    text-transform: uppercase;
    text-shadow: 0 18px 60px rgba(0,0,0,.45);
  }
  .games-hero p {
    max-width: 73ch;
    margin-top: 22px;
    color: rgba(255,255,255,.86);
    font-size: clamp(1rem, 1.8vw, 1.22rem);
  }
  .games-signal-strip {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 12px;
    margin: -28px 0 34px;
  }
  .games-signal-strip div {
    min-height: 112px;
    padding: 20px;
    border: 1px solid rgba(16,24,32,.16);
    border-radius: 18px;
    background: rgba(255,255,255,.9);
    box-shadow: 0 12px 32px rgba(16,24,32,.12);
  }
  .games-signal-strip b {
    display: block;
    color: var(--txt);
    font-family: var(--font-disp);
    font-size: 2.4rem;
    line-height: 1;
  }
  .games-signal-strip span {
    display: block;
    margin-top: 8px;
    color: var(--muted);
    font-family: var(--font-mono);
    font-size: .75rem;
    font-weight: 800;
    letter-spacing: .12em;
    text-transform: uppercase;
  }
  .games-featured,
  .game-bay {
    position: relative;
    overflow: hidden;
    border: 2px solid rgba(16,24,32,.2);
    border-radius: 34px;
    background:
      linear-gradient(120deg, rgba(10,14,23,.94), rgba(10,14,23,.62) 48%, rgba(10,14,23,.34)),
      var(--world-bg) center / cover no-repeat;
    color: #fff;
    box-shadow: 0 14px 0 rgba(16,24,32,.14), 0 40px 90px rgba(16,24,32,.18);
  }
  .games-featured {
    padding: 34px;
    margin-bottom: 34px;
  }
  .games-featured::after,
  .game-bay::after {
    content: "";
    position: absolute;
    inset: 0;
    pointer-events: none;
    background:
      linear-gradient(rgba(255,255,255,.055) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255,255,255,.04) 1px, transparent 1px);
    background-size: 46px 46px;
    opacity: .44;
    mix-blend-mode: screen;
  }
  .games-featured > *,
  .game-bay > * {
    position: relative;
    z-index: 1;
  }
  .games-featured .sec-head h2,
  .game-bay h2,
  .games-bays > .sec-head h2 {
    color: inherit;
  }
  .games-featured .sec-head,
  .game-bay-head {
    color: #fff;
  }
  .featured-game-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 16px;
  }
  .featured-game {
    min-height: 260px;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    overflow: hidden;
    padding: 20px;
    border: 1px solid rgba(255,255,255,.28);
    border-radius: 22px;
    background:
      linear-gradient(180deg, rgba(10,14,23,.2), rgba(10,14,23,.82)),
      var(--world-bg) center / cover no-repeat;
    box-shadow: inset 0 -90px 80px rgba(0,0,0,.48);
  }
  .featured-game span,
  .game-topline span,
  .guide-links span {
    color: var(--accent);
    font-family: var(--font-mono);
    font-size: .7rem;
    font-weight: 900;
    letter-spacing: .15em;
    text-transform: uppercase;
  }
  .featured-game h3 {
    margin-top: 8px;
    color: #fff;
    font-size: clamp(1.6rem, 3vw, 2.5rem);
    line-height: .9;
    text-transform: uppercase;
  }
  .featured-game p {
    max-width: 32ch;
    margin-top: 8px;
    color: rgba(255,255,255,.82);
  }
  .featured-game a {
    width: max-content;
    padding: 10px 12px;
    border: 1px solid rgba(255,255,255,.3);
    border-radius: 999px;
    background: rgba(255,255,255,.12);
    color: #fff;
    font-family: var(--font-mono);
    font-size: .74rem;
    font-weight: 900;
    letter-spacing: .08em;
    text-transform: uppercase;
  }
  .games-bays {
    margin-top: 40px;
  }
  .games-bays > .sec-head {
    margin-bottom: 24px;
  }
  .game-bay {
    --bay-a: #ff5e1a;
    margin: 0 0 34px;
    padding: clamp(22px, 4vw, 38px);
    background:
      radial-gradient(820px 380px at 88% 8%, color-mix(in srgb, var(--bay-a) 24%, transparent), transparent 70%),
      linear-gradient(90deg, rgba(10,14,23,.92), rgba(10,14,23,.58) 52%, rgba(10,14,23,.34)),
      var(--world-bg) center / cover no-repeat;
  }
  .game-bay[data-bay="racing"] { --bay-a: #ff4b16; }
  .game-bay[data-bay="golf"] { --bay-a: #eab308; }
  .game-bay[data-bay="flight"] { --bay-a: #38bdf8; }
  .game-bay[data-bay="space"] { --bay-a: #d946ef; }
  .game-bay[data-bay="marine"] { --bay-a: #14b8a6; }
  .game-bay-head {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    gap: 22px;
    align-items: end;
    margin-bottom: 24px;
  }
  .game-bay-head h2 {
    max-width: 16ch;
    margin-top: 8px;
    font-size: clamp(2rem, 4vw, 4.4rem);
    line-height: .9;
    text-transform: uppercase;
  }
  .game-bay-head p {
    max-width: 58ch;
    margin-top: 12px;
    color: rgba(255,255,255,.78);
  }
  .game-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 18px;
  }
  .game-card {
    min-height: 100%;
    padding: 20px;
    border: 1px solid rgba(255,255,255,.26);
    border-radius: 20px;
    background: rgba(255,255,255,.92);
    color: var(--txt);
    box-shadow: 0 18px 44px rgba(0,0,0,.16);
  }
  .game-topline {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
  }
  .game-topline a {
    color: var(--muted);
    font-family: var(--font-mono);
    font-size: .72rem;
    font-weight: 900;
    letter-spacing: .08em;
    text-transform: uppercase;
  }
  .game-card h3 {
    margin-top: 12px;
    font-size: clamp(1.7rem, 3vw, 2.65rem);
    line-height: .92;
    text-transform: uppercase;
  }
  .signal {
    margin-top: 10px;
    color: color-mix(in srgb, var(--txt) 76%, var(--accent));
    font-weight: 800;
  }
  .game-decisions {
    display: grid;
    gap: 10px;
    margin-top: 18px;
  }
  .game-decisions div {
    padding: 14px;
    border: 1px solid rgba(16,24,32,.12);
    border-radius: 14px;
    background: rgba(245,248,251,.9);
  }
  .game-decisions .watch {
    border-color: rgba(255,94,26,.24);
    background: rgba(255,240,232,.95);
  }
  .game-decisions b {
    display: block;
    margin-bottom: 6px;
    color: var(--txt);
    font-family: var(--font-mono);
    font-size: .72rem;
    font-weight: 900;
    letter-spacing: .12em;
    text-transform: uppercase;
  }
  .game-decisions p {
    color: var(--muted);
    font-size: .94rem;
  }
  .guide-links {
    display: grid;
    gap: 8px;
    margin-top: 18px;
  }
  .guide-links a {
    display: block;
    padding: 11px 12px;
    border: 1px solid rgba(16,24,32,.12);
    border-radius: 12px;
    background: #fff;
    color: var(--txt);
    font-family: var(--font-disp);
    font-weight: 800;
    line-height: 1.08;
  }
  .guide-links a:hover {
    border-color: var(--accent);
    color: var(--accent);
  }
  @media (max-width: 980px) {
    .games-signal-strip,
    .featured-game-grid,
    .game-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }
  @media (max-width: 720px) {
    .games-hero {
      min-height: 720px;
      margin-top: -66px;
      padding-top: 106px;
    }
    .games-signal-strip,
    .featured-game-grid,
    .game-grid,
    .game-bay-head {
      grid-template-columns: 1fr;
    }
    .game-bay,
    .games-featured {
      border-radius: 22px;
      padding: 20px;
    }
  }
</style>
