---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';
import site from '../../data/site.json';
import bays from '../../data/bays.json';
import games from '../../data/games.json';
import { isCertifiedArticle } from '../../lib/content';
import { getWorldForBay } from '../../lib/worlds';

const certified = await getCollection('articles', ({ data }) => isCertifiedArticle(data));
const articleMap = new Map(certified.map((a) => [a.id, a]));
const slug = (a: any) => a.id.split('/').pop();
const bayMap = new Map(bays.map((b) => [b.slug, b]));
const gameMediaBySlug: Record<string, { image: string; alt: string; label: string }> = {
  iracing: {
    image: '/images/games/iracing/iracing-2026-s3-hero.jpg',
    alt: 'iRacing 2026 Season 3 official racing screenshot',
    label: 'Game proof',
  },
  'assetto-corsa-evo': {
    image: '/images/gear/racing/sim-lab-p1x.jpg',
    alt: 'Sim-Lab P1X aluminum profile cockpit for serious PC racing simulators',
    label: 'Rig proof',
  },
  'assetto-corsa-competizione': {
    image: '/images/gear/racing/heusinkveld-sprint.jpg',
    alt: 'Heusinkveld Sprint load-cell sim racing pedals',
    label: 'Pedal proof',
  },
  'le-mans-ultimate': {
    image: '/images/gear/racing/samsung-odyssey-oled-g9-49.jpg',
    alt: 'Samsung Odyssey OLED G9 ultrawide monitor for racing simulation',
    label: 'Display proof',
  },
  'gran-turismo-7': {
    image: '/images/gear/racing/logitech-rs50-system.jpg',
    alt: 'Logitech RS50 direct drive racing wheel system',
    label: 'Console proof',
  },
  'forza-motorsport': {
    image: '/images/gear/racing/moza-r3-xbox-bundle.png',
    alt: 'MOZA R3 Xbox direct drive racing wheel bundle',
    label: 'Xbox proof',
  },
  gspro: {
    image: '/images/gear/golf/garmin-approach-r50.jpg',
    alt: 'Garmin Approach R50 launch monitor for golf simulator software',
    label: 'Launch proof',
  },
  'e6-connect': {
    image: '/images/gear/golf/skytrak-st-max.jpg',
    alt: 'SkyTrak ST MAX launch monitor used for home golf simulator software',
    label: 'Software path',
  },
  'awesome-golf': {
    image: '/images/gear/golf/sig10-enclosure.jpg',
    alt: 'SIG10 golf simulator enclosure and impact screen',
    label: 'Room proof',
  },
  'microsoft-flight-simulator-2024': {
    image: '/images/gear/flight/honeycomb-alpha-yoke.jpg',
    alt: 'Honeycomb Alpha flight simulator yoke',
    label: 'Yoke proof',
  },
  'x-plane-12': {
    image: '/images/gear/flight/honeycomb-bravo-throttle.jpg',
    alt: 'Honeycomb Bravo throttle quadrant for flight simulators',
    label: 'Throttle proof',
  },
  'dcs-world': {
    image: '/images/gear/flight/thrustmaster-hotas-warthog.jpg',
    alt: 'Thrustmaster HOTAS Warthog flight stick and throttle',
    label: 'HOTAS proof',
  },
  'star-citizen': {
    image: '/images/gear/space/vkb-gladiator-nxt-evo-space-combat-edition.jpg',
    alt: 'VKB Gladiator NXT EVO Space Combat Edition joystick',
    label: 'HOSAS proof',
  },
  'elite-dangerous': {
    image: '/images/gear/space/vkb-gladiator-nxt-evo-omni-throttle.jpg',
    alt: 'VKB Gladiator NXT EVO Omni Throttle for space simulators',
    label: 'Cruise proof',
  },
  sailaway: {
    image: '/images/gear/marine/thrustmaster-twcs-throttle-engine-lever.jpg',
    alt: 'Thrustmaster TWCS throttle repurposed as a marine simulator control',
    label: 'Control proof',
  },
  'bridge-command': {
    image: '/images/gear/marine/leobodnar-bbi-32-button-box-interface.jpg',
    alt: 'Leo Bodnar BBI-32 button box interface board for DIY simulator controls',
    label: 'DIY proof',
  },
  evercade: {
    image: '/images/gear/racing/evercade-vs-r-exp-r.png',
    alt: 'Evercade VS-R console and EXP-R handheld physical cartridge gaming hardware',
    label: 'Physical shelf',
  },
};
const fallbackMediaByBay: Record<string, { image: string; alt: string; label: string }> = {
  racing: gameMediaBySlug['assetto-corsa-evo'],
  golf: gameMediaBySlug.gspro,
  flight: gameMediaBySlug['microsoft-flight-simulator-2024'],
  space: gameMediaBySlug['star-citizen'],
  marine: gameMediaBySlug['bridge-command'],
};
const gameMediaFor = (game: any) => gameMediaBySlug[game.slug] || fallbackMediaByBay[game.bay];
const grouped = bays
  .map((bay) => ({
    bay,
    world: getWorldForBay(bay.slug),
    games: (games as any[])
      .filter((g) => g.bay === bay.slug)
      .map((g) => ({
        ...g,
        media: gameMediaFor(g),
        guides: (g.guideIds || []).map((id: string) => articleMap.get(id)).filter(Boolean),
      })),
  }))
  .filter((group) => group.games.length);

const featured = (games as any[])
  .filter((g) => ['iracing', 'gspro', 'assetto-corsa-evo', 'microsoft-flight-simulator-2024', 'star-citizen', 'bridge-command', 'evercade'].includes(g.slug))
  .map((g) => ({ ...g, bayData: bayMap.get(g.bay), world: getWorldForBay(g.bay), media: gameMediaFor(g) }));

const description = 'IgnitionSim simulator games hub: the racing, golf, flight, space, and marine sims worth building hardware around, with buyer-map links and setup traps.';
const schema = [{
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: 'Simulator Games Hub',
  description,
  url: new URL('/games', site.url).href,
  hasPart: (games as any[]).map((g) => ({
    '@type': 'VideoGame',
    name: g.name,
    genre: g.type,
    url: g.officialUrl,
  })),
}, {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: 'Popular simulator games and sports for hardware builders',
  numberOfItems: (games as any[]).length,
  itemListElement: (games as any[]).map((g, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    name: g.name,
    url: g.officialUrl,
  })),
}];
---
<Base title="Simulator Games Hub" description={description} image="/images/worlds/space-world.webp" schema={schema} activeNav="games">
  <div class="games-page">
    <section class="games-hero" style={`--world-bg: url('${getWorldForBay('space').image}')`}>
      <div class="games-hero-scrim"></div>
      <div class="wrap games-hero-inner">
        <div class="crumbs"><a href="/">Home</a><span>/</span>Games</div>
        <span class="lbl lbl-accent">Simulator games hub</span>
        <h1>Start with the sim. Build the room around it.</h1>
        <p>iRacing, GSPro, MSFS, Star Citizen, Bridge Command, and the rest do not want the same hardware. Pick the world you actually play, then build the controls, screens, mounts, and room around that reality.</p>
        <div class="hero-actions">
          <a class="btn btn-primary btn-lg" href="#sim-worlds">Browse sim worlds</a>
          <a class="btn btn-lg" href="/guides">Open certified guides</a>
        </div>
      </div>
    </section>

    <div class="wrap">
      <section class="games-signal-strip" aria-label="Games hub promise">
        <div><b>{(games as any[]).length}</b><span>games and sim platforms</span></div>
        <div><b>5</b><span>hardware worlds</span></div>
        <div><b>{certified.length}</b><span>certified buyer guides</span></div>
        <div><b>{(games as any[]).length}</b><span>official source links</span></div>
      </section>

      <section class="sec games-featured" style={`--world-bg: url('${getWorldForBay('space').image}')`}>
        <div class="sec-head">
          <div>
            <span class="lbl lbl-accent">Where the rigs come from</span>
            <h2>Game first. Hardware second. Regret last.</h2>
          </div>
          <span class="lbl">official links + certified routes</span>
        </div>
        <div class="featured-game-grid">
          {featured.map((g) => (
            <article class="featured-game" data-bay={g.bay} style={`--world-bg: url('${g.world.image}')`}>
              <div class="featured-game-media">
                <img src={g.media.image} alt={g.media.alt} loading="lazy" decoding="async" />
                <span>{g.media.label}</span>
              </div>
              <div>
                <span>{g.bayData?.name || g.bay}</span>
                <h3>{g.name}</h3>
                <p>{g.signal}</p>
              </div>
              <a href={`#${g.bay}`}>Build around it</a>
            </article>
          ))}
        </div>
      </section>

      <section class="sec games-bays" id="sim-worlds">
        <div class="sec-head">
          <div>
            <span class="lbl lbl-accent">Sim worlds</span>
            <h2>Pick the game. Then pick the gear that makes it feel alive.</h2>
          </div>
          <span class="lbl">SEO path: simulator games by hardware need</span>
        </div>

        {grouped.map(({ bay, world, games }) => (
          <section class="game-bay" id={bay.slug} data-bay={bay.slug} style={`--world-bg: url('${world.image}')`}>
            <div class="game-bay-head">
              <div>
                <span class="lbl lbl-accent">{bay.name} games</span>
                <h2>{bay.tagline}</h2>
                <p>{world.mood}</p>
              </div>
              <a class="btn btn-ghost" href={`/${bay.slug}`}>Open {bay.name} bay</a>
            </div>

            <div class="game-grid">
              {games.map((game: any) => (
                <article class="game-card" data-bay={game.bay}>
                  <div class="game-card-media">
                    <img src={game.media.image} alt={game.media.alt} loading="lazy" decoding="async" />
                    <span>{game.media.label}</span>
                  </div>
                  <div class="game-topline">
                    <span>{game.type}</span>
                    <a href={game.officialUrl} target="_blank" rel="noopener">Official site</a>
                  </div>
                  <h3>{game.name}</h3>
                  <p class="signal">{game.signal}</p>
                  <div class="game-decisions">
                    <div>
                      <b>Best for</b>
                      <p>{game.bestFor}</p>
                    </div>
                    <div>
                      <b>Hardware that matters</b>
                      <p>{game.hardwareThatMatters}</p>
                    </div>
                    <div class="watch">
                      <b>Watch the trap</b>
                      <p>{game.watchTheTrap}</p>
                    </div>
                  </div>
                  {game.guides.length > 0 ? (
                    <div class="guide-links">
                      <span>Certified routes</span>
                      {game.guides.map((guide: any) => (
                        <a href={`/${guide.data.bay}/${slug(guide)}`}>{guide.data.title}</a>
                      ))}
                    </div>
                  ) : (
                    <div class="guide-links empty">
                      <span>Certified routes</span>
                      <a href={`/${game.bay}`}>Start with the {bay.name} hardware bay</a>
                    </div>
                  )}
                </article>
              ))}
            </div>
          </section>
        ))}
      </section>
    </div>
  </div>
</Base>

<style>
  .games-page {
    position: relative;
    overflow: hidden;
    padding-bottom: 70px;
  }
  .games-page::before {
    content: "";
    position: absolute;
    inset: 0;
    pointer-events: none;
    background:
      radial-gradient(780px 380px at 8% 5%, rgba(255,94,26,.14), transparent 72%),
      radial-gradient(840px 420px at 92% 10%, rgba(56,189,248,.13), transparent 70%),
      radial-gradient(760px 420px at 72% 100%, rgba(16,185,129,.13), transparent 72%);
  }
  .games-page > * { position: relative; z-index: 1; }
  .games-hero {
    position: relative;
    min-height: min(660px, 74vh);
    display: grid;
    align-items: end;
    overflow: hidden;
    margin-top: -72px;
    padding: 120px 0 56px;
    color: #fff;
    background:
      radial-gradient(820px 420px at 86% 18%, rgba(217,70,239,.22), transparent 70%),
      linear-gradient(90deg, rgba(10,14,23,.78), rgba(10,14,23,.38) 50%, rgba(10,14,23,.08)),
      var(--world-bg) center / cover no-repeat;
    box-shadow: inset 0 -120px 110px rgba(245,248,251,1);
  }
  .games-hero::after {
    content: "";
    position: absolute;
    inset: 0;
    pointer-events: none;
    background:
      radial-gradient(660px 380px at 76% 18%, rgba(255,94,26,.18), transparent 72%),
      linear-gradient(rgba(255,255,255,.055) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255,255,255,.04) 1px, transparent 1px);
    background-size: auto, 48px 48px, 48px 48px;
    mix-blend-mode: screen;
    opacity: .5;
  }
  .games-hero-scrim {
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, rgba(10,14,23,.15), rgba(10,14,23,.42));
  }
  .games-hero-inner {
    position: relative;
    z-index: 1;
    max-width: 1020px;
  }
  .games-hero .crumbs,
  .games-hero .crumbs a {
    color: rgba(255,255,255,.72);
  }
  .games-hero h1 {
    max-width: 12.5ch;
    margin-top: 14px;
    color: #fff;
    font-size: clamp(2.6rem, 5.4vw, 5.2rem);
    line-height: .9;
    text-transform: uppercase;
    text-shadow: 0 18px 60px rgba(0,0,0,.45);
  }
  .games-hero p {
    max-width: 73ch;
    margin-top: 22px;
    color: rgba(255,255,255,.86);
    font-size: clamp(1rem, 1.8vw, 1.22rem);
  }
  .games-signal-strip {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 12px;
    margin: -28px 0 34px;
  }
  .games-signal-strip div {
    min-height: 112px;
    padding: 20px;
    border: 1px solid rgba(16,24,32,.16);
    border-radius: 18px;
    background: rgba(255,255,255,.9);
    box-shadow: 0 12px 32px rgba(16,24,32,.12);
  }
  .games-signal-strip b {
    display: block;
    color: var(--txt);
    font-family: var(--font-disp);
    font-size: 2.4rem;
    line-height: 1;
  }
  .games-signal-strip span {
    display: block;
    margin-top: 8px;
    color: var(--muted);
    font-family: var(--font-mono);
    font-size: .75rem;
    font-weight: 800;
    letter-spacing: .12em;
    text-transform: uppercase;
  }
  .games-featured,
  .game-bay {
    position: relative;
    overflow: hidden;
    border: 2px solid rgba(16,24,32,.2);
    border-radius: 34px;
    background:
      radial-gradient(760px 360px at 86% 0%, color-mix(in srgb, var(--accent) 16%, transparent), transparent 70%),
      linear-gradient(120deg, rgba(10,14,23,.82), rgba(10,14,23,.44) 48%, rgba(10,14,23,.16)),
      var(--world-bg) center / cover no-repeat;
    color: #fff;
    box-shadow: 0 14px 0 rgba(16,24,32,.14), 0 40px 90px rgba(16,24,32,.18);
  }
  .games-featured {
    padding: 34px;
    margin-bottom: 34px;
  }
  .games-featured::after,
  .game-bay::after {
    content: "";
    position: absolute;
    inset: 0;
    pointer-events: none;
    background:
      linear-gradient(rgba(255,255,255,.055) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255,255,255,.04) 1px, transparent 1px);
    background-size: 46px 46px;
    opacity: .44;
    mix-blend-mode: screen;
  }
  .games-featured > *,
  .game-bay > * {
    position: relative;
    z-index: 1;
  }
  .games-featured .sec-head h2,
  .game-bay h2,
  .games-bays > .sec-head h2 {
    color: inherit;
  }
  .games-featured .sec-head,
  .game-bay-head {
    color: #fff;
  }
  .featured-game-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 16px;
  }
  .featured-game {
    min-height: 100%;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    overflow: hidden;
    padding: 0;
    border: 1px solid rgba(255,255,255,.28);
    border-radius: 22px;
    background: rgba(255,255,255,.94);
    color: #101820;
    box-shadow: 0 18px 44px rgba(0,0,0,.18);
  }
  .featured-game > div:not(.featured-game-media) {
    padding: 18px 20px 0;
  }
  .featured-game-media,
  .game-card-media {
    position: relative;
    display: grid;
    place-items: center;
    background: linear-gradient(135deg, #fff, #eef4f8);
    border-bottom: 1px solid rgba(16,24,32,.12);
  }
  .featured-game-media {
    min-height: 190px;
    padding: 22px;
  }
  .featured-game-media img,
  .game-card-media img {
    width: 100%;
    height: 100%;
    max-height: 180px;
    object-fit: contain;
    filter: drop-shadow(0 18px 24px rgba(16,24,32,.2));
  }
  .featured-game-media span,
  .game-card-media span {
    position: absolute;
    left: 12px;
    top: 12px;
    z-index: 2;
    padding: 7px 9px;
    border: 1px solid #101820;
    border-radius: 8px;
    background: #ff5e1a;
    color: #101820;
    font-family: var(--font-mono);
    font-size: .54rem;
    font-weight: 900;
    letter-spacing: .11em;
    text-transform: uppercase;
  }
  .featured-game span,
  .game-topline span,
  .guide-links span {
    color: var(--accent);
    font-family: var(--font-mono);
    font-size: .7rem;
    font-weight: 900;
    letter-spacing: .15em;
    text-transform: uppercase;
  }
  .featured-game h3 {
    margin-top: 8px;
    color: #101820;
    font-size: clamp(1.6rem, 3vw, 2.5rem);
    line-height: .9;
    text-transform: uppercase;
  }
  .featured-game p {
    max-width: 32ch;
    margin-top: 8px;
    color: #435363;
  }
  .featured-game a {
    width: max-content;
    margin: 16px 20px 20px;
    padding: 10px 12px;
    border: 1px solid #101820;
    border-radius: 999px;
    background: #101820;
    color: #fff;
    font-family: var(--font-mono);
    font-size: .74rem;
    font-weight: 900;
    letter-spacing: .08em;
    text-transform: uppercase;
  }
  .games-bays {
    margin-top: 40px;
  }
  .games-bays > .sec-head {
    margin-bottom: 24px;
  }
  .game-bay {
    --bay-a: #ff5e1a;
    margin: 0 0 34px;
    padding: clamp(22px, 4vw, 38px);
    background:
      radial-gradient(820px 380px at 88% 8%, color-mix(in srgb, var(--bay-a) 24%, transparent), transparent 70%),
      linear-gradient(90deg, rgba(10,14,23,.78), rgba(10,14,23,.36) 52%, rgba(10,14,23,.16)),
      var(--world-bg) center / cover no-repeat;
  }
  .game-bay[data-bay="racing"] { --bay-a: #ff4b16; }
  .game-bay[data-bay="golf"] { --bay-a: #eab308; }
  .game-bay[data-bay="flight"] { --bay-a: #38bdf8; }
  .game-bay[data-bay="space"] { --bay-a: #d946ef; }
  .game-bay[data-bay="marine"] { --bay-a: #14b8a6; }
  .game-bay-head {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    gap: 22px;
    align-items: end;
    margin-bottom: 24px;
  }
  .game-bay-head h2 {
    max-width: 16ch;
    margin-top: 8px;
    font-size: clamp(2rem, 4vw, 4.4rem);
    line-height: .9;
    text-transform: uppercase;
  }
  .game-bay-head p {
    max-width: 58ch;
    margin-top: 12px;
    color: rgba(255,255,255,.78);
  }
  .game-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 18px;
  }
  .game-card {
    min-height: 100%;
    overflow: hidden;
    padding: 0 0 20px;
    border: 1px solid rgba(255,255,255,.26);
    border-radius: 20px;
    background: rgba(255,255,255,.92);
    color: var(--txt);
    box-shadow: 0 18px 44px rgba(0,0,0,.16);
  }
  .game-card > :not(.game-card-media) {
    margin-left: 20px;
    margin-right: 20px;
  }
  .game-card-media {
    min-height: 210px;
    padding: 22px;
  }
  .game-topline {
    margin-top: 18px;
  }
  .game-topline {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
  }
  .game-topline a {
    color: var(--muted);
    font-family: var(--font-mono);
    font-size: .72rem;
    font-weight: 900;
    letter-spacing: .08em;
    text-transform: uppercase;
  }
  .game-card h3 {
    margin-top: 12px;
    font-size: clamp(1.7rem, 3vw, 2.65rem);
    line-height: .92;
    text-transform: uppercase;
  }
  .signal {
    margin-top: 10px;
    color: color-mix(in srgb, var(--txt) 76%, var(--accent));
    font-weight: 800;
  }
  .game-decisions {
    display: grid;
    gap: 10px;
    margin-top: 18px;
  }
  .game-decisions div {
    padding: 14px;
    border: 1px solid rgba(16,24,32,.12);
    border-radius: 14px;
    background: rgba(245,248,251,.9);
  }
  .game-decisions .watch {
    border-color: rgba(255,94,26,.24);
    background: rgba(255,240,232,.95);
  }
  .game-decisions b {
    display: block;
    margin-bottom: 6px;
    color: var(--txt);
    font-family: var(--font-mono);
    font-size: .72rem;
    font-weight: 900;
    letter-spacing: .12em;
    text-transform: uppercase;
  }
  .game-decisions p {
    color: var(--muted);
    font-size: .94rem;
  }
  .guide-links {
    display: grid;
    gap: 8px;
    margin-top: 18px;
  }
  .guide-links a {
    display: block;
    padding: 11px 12px;
    border: 1px solid rgba(16,24,32,.12);
    border-radius: 12px;
    background: #fff;
    color: var(--txt);
    font-family: var(--font-disp);
    font-weight: 800;
    line-height: 1.08;
  }
  .guide-links a:hover {
    border-color: var(--accent);
    color: var(--accent);
  }
  @media (max-width: 980px) {
    .games-signal-strip,
    .featured-game-grid,
    .game-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }
  @media (max-width: 720px) {
    .games-hero {
      min-height: 720px;
      margin-top: -66px;
      padding-top: 106px;
