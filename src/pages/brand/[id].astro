---
import Base from '../../layouts/Base.astro';
import FAQ from '../../components/FAQ.astro';
import bays from '../../data/bays.json';
import site from '../../data/site.json';
import { hasVerifiedProductImage } from '../../lib/productMedia';
import { canonicalAmazonProductUrl } from '../../lib/amazon';

const slugify = (s) => String(s).toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/(^-|-$)/g, '');

export async function getStaticPaths() {
  const brandMods = import.meta.glob('/src/data/brands.json', { eager: true });
  const brands = ((Object.values(brandMods)[0] as any)?.default || []) as any[];
  const prodMods = import.meta.glob('/src/data/products/*.json', { eager: true });
  const amazonTag = (site as any).affiliate?.amazonTag;
  const products = (Object.values(prodMods).flatMap((m: any) => (m.default || [])) as any[])
    .filter(hasVerifiedProductImage)
    .map((product) => ({ ...product, amazonUrl: canonicalAmazonProductUrl(product, amazonTag) }))
    .filter((product) => product.amazonUrl);
  const sl = (s) => String(s).toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/(^-|-$)/g, '');
  return brands.map((brand) => ({
    params: { id: brand.id },
    props: { brand, products: products.filter((p) => sl(p.brand) === brand.id) },
  }));
}
const { brand, products } = Astro.props;
const url = new URL(`/brand/${brand.id}`, site.url).href;
const byType: Record<string, any[]> = {};
products.forEach((p) => { (byType[p.type] = byType[p.type] || []).push(p); });

const schema: Record<string, any>[] = [
  { '@context': 'https://schema.org', '@type': 'Brand', name: brand.name, description: brand.profile, url, slogan: brand.tagline,
    ...(brand.founded ? { foundingDate: String(brand.founded) } : {}) },
  { '@context': 'https://schema.org', '@type': 'BreadcrumbList', itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: site.url },
    { '@type': 'ListItem', position: 2, name: 'Brands', item: new URL('/brand', site.url).href },
    { '@type': 'ListItem', position: 3, name: brand.name, item: url } ] },
];
if (brand.faqs?.length) schema.push({ '@context': 'https://schema.org', '@type': 'FAQPage', mainEntity: brand.faqs.map((f) => ({ '@type': 'Question', name: f.q, acceptedAnswer: { '@type': 'Answer', text: f.a } })) });
const primaryBay = (brand.bays && brand.bays[0]) || (products[0] && products[0].bay) || null;
---
<Base title={`${brand.name} — sim hardware reviews, gear & verdict`} description={brand.tagline || brand.profile?.slice(0, 150)} bay={primaryBay} schema={schema} image={primaryBay ? `/images/${primaryBay}/hero.jpg` : '/og-default.png'} noindex={true}>
  <div class="wrap">
    <div class="crumbs"><a href="/">Home</a><span>/</span><a href="/brand">Brands</a><span>/</span>{brand.name}</div>
    <section class="hero" style="text-align:left;padding:34px 0 8px">
      <div class="lbl lbl-accent">// Brand · {(brand.bays || []).join(' · ') || 'sim hardware'}</div>
      <h1 style="font-size:clamp(2rem,5vw,3rem)">{brand.name}</h1>
      {brand.tagline && <p style="color:var(--accent);font-size:1.1rem;margin-top:6px">{brand.tagline}</p>}
    </section>
    <div class="prose" style="max-width:820px">
      <p>{brand.profile}</p>
      {brand.ecosystem && <div class="callout"><div class="ct">// Ecosystem</div>{brand.ecosystem}</div>}
      {brand.whoFor && <p><strong>Who it's for:</strong> {brand.whoFor}</p>}
    </div>

    {products.length > 0 && Object.entries(byType).map(([t, list]) => (
      <section class="sec" style="padding:18px 0">
        <div class="sec-head"><h2>{brand.name} {t.replace(/-/g, ' ')}s</h2><span class="lbl">{list.length}</span></div>
        <div class="card-grid">
          {list.sort((a, b) => (b.rating?.overall || 0) - (a.rating?.overall || 0)).map((p) => (
            <article class="card commerce-card">
              <a class="cimg" href={p.amazonUrl} target="_blank" rel="sponsored nofollow noopener" data-buy-link="true" data-event="buy_click" data-buy-product={p.id}><img src={p.image} alt={`${p.brand} ${p.model}`} loading="lazy" /></a>
              <div class="cbody"><span class="ctype">{p.bay}{p.rating?.overall ? ` · ${p.rating.overall}/10` : ''}</span><h3 style="font-size:1.05rem"><a href={p.amazonUrl} target="_blank" rel="sponsored nofollow noopener" data-buy-link="true" data-event="buy_click" data-buy-product={p.id}>{p.model}</a></h3><p class="cexc">{p.summary}</p><span class="cmeta" style="color:var(--accent)">{p.price ? `~$${p.price.toLocaleString()}` : ''}</span><div class="commerce-actions"><a class="btn btn-primary" href={p.amazonUrl} target="_blank" rel="sponsored nofollow noopener" data-buy-link="true" data-event="buy_click" data-buy-product={p.id}>Exact product on Amazon</a><a class="btn" href={`/${p.bay}/gear/${p.id}`}>Specs</a></div></div>
            </article>
          ))}
        </div>
      </section>
    ))}

    {brand.faqs?.length > 0 && <div class="prose" style="max-width:820px"><FAQ faqs={brand.faqs} heading={`${brand.name} — common questions`} /></div>}

    {primaryBay && (
      <section class="cfg-cta">
        <div><span class="lbl lbl-accent">// Explore</span><h4 style="margin-top:6px">See where {brand.name} fits in the gear bench</h4><p>Compare {brand.name} against the other products in its bay, with specs, caveats, and buyer notes close at hand.</p></div>
        <a class="btn btn-primary btn-lg" href={`/${primaryBay}/gear`}>Browse the gear ▸</a>
      </section>
    )}
  </div>
</Base>

<style>
  .commerce-card { display: flex; flex-direction: column; }
  .commerce-card h3 a { color: inherit; }
  .commerce-actions { display: flex; flex-wrap: wrap; gap: 8px; margin-top: 14px; }
  .commerce-actions .btn { padding: 9px 11px; font-size: .64rem; }
</style>
