---
import Base from '../layouts/Base.astro';
import GearCarousel from '../components/GearCarousel.astro';
import { getCollection } from 'astro:content';
import site from '../data/site.json';
import bays from '../data/bays.json';
import games from '../data/games.json';
import signals from '../data/research-signals.json';
import crew from '../data/crew.json';
import growthPriorities from '../data/growth-priorities.json';
import { articleMeta, isCertifiedArticle, sortNewestArticles } from '../lib/content';
import { getArticleCardArt } from '../lib/articleArt';
import { hasVerifiedProductImage } from '../lib/productMedia';
import { getWorldForBay } from '../lib/worlds';
import { crewSlug } from '../lib/crew';
import { canonicalAmazonProductUrl } from '../lib/amazon';

const all = sortNewestArticles(await getCollection('articles', ({ data }) => isCertifiedArticle(data)));
const articleById = new Map(all.map((a) => [a.id, a]));
const slug = (a: any) => a.id.split('/').pop();
const articleHref = (a: any) => `/${a.data.bay}/${slug(a)}`;
const crewByName = new Map((crew as any[]).map((person) => [person.name, person]));
const bayFallbackCurator = (bay: string) => {
  const curatorName = bay === 'golf' ? 'Nina Brooks'
    : bay === 'racing' ? 'Duke Alvarez'
    : bay === 'marine' ? 'Gus Calder'
    : bay === 'flight' ? 'Val Chen'
    : bay === 'space' ? 'Val Chen'
    : 'Mac Donovan';
  return crewByName.get(curatorName) || (crew as any[])[0];
};
const curatorForArticle = (a: any) => crewByName.get(a.data.author) || bayFallbackCurator(a.data.bay);
const uniqueArticles = (items: any[]) => {
  const seen = new Set();
  return items.filter((item) => {
    if (!item || seen.has(item.id)) return false;
    seen.add(item.id);
    return true;
  });
};
const diverseArticles = (items: any[], limit: number) => {
  const remaining = [...uniqueArticles(items)];
  const picked: any[] = [];
  while (picked.length < limit && remaining.length) {
    const last = picked[picked.length - 1];
    const index = remaining.findIndex((item) => item.data.bay !== last?.data?.bay);
    const [next] = remaining.splice(index >= 0 ? index : 0, 1);
    picked.push(next);
  }
  return picked;
};

const cornerstoneIds = (growthPriorities as any).cornerstoneArticleIds || [];
const cornerstones = cornerstoneIds.map((id) => articleById.get(id)).filter(Boolean);
const featureGuides = cornerstones.map((a: any, i) => {
  const href = articleHref(a);
  return { a, href, art: getArticleCardArt(href), i };
});
const streamLeadIds = (growthPriorities as any).streamLeadArticleIds || [];
const streamArticles = diverseArticles(uniqueArticles([
  ...streamLeadIds.map((id) => articleById.get(id)),
  ...all,
]), 18);
const latestRotator = streamArticles.slice(0, 10).map((a: any) => {
  const href = articleHref(a);
  return { a, href, art: getArticleCardArt(href) };
});
const latestBriefing = streamArticles.slice(0, 12).map((a: any, i) => {
  const href = articleHref(a);
  const art = getArticleCardArt(href);
  const curator = curatorForArticle(a);
  return { a, href, art, curator, i };
});

const amazonTag = (site as any).affiliate?.amazonTag;
const prodMods = import.meta.glob('/src/data/products/*.json', { eager: true });
const allProducts = Object.values(prodMods).flatMap((m: any) => (m.default || m)) as any[];
const verifiedProducts = allProducts.filter(hasVerifiedProductImage);
const buyUrl = (p: any) => canonicalAmazonProductUrl(p, amazonTag);
const rankProduct = (p: any) => (p.rating?.overall || 0) * 100 + Math.min(p.price || 0, 4000) / 1000;
const gearItem = (p: any, tag?: string) => ({
  href: `/${p.bay}/gear/${p.id}`,
  image: p.image || `/images/gear/${p.bay}/${p.id}.jpg`,
  brand: p.brand,
  model: p.model,
  price: p.price,
  priceNote: p.priceNote,
  type: p.type,
  whoFor: p.whoFor,
  summary: p.summary,
  buyUrl: buyUrl(p),
  tag,
});

const heroPhoto = '/images/dream/ignitionsim-dream-garage.webp';
const homeGameCards = (games as any[])
  .filter((g) => ['iracing', 'gspro', 'assetto-corsa-evo', 'microsoft-flight-simulator-2024', 'star-citizen'].includes(g.slug))
  .map((g) => ({
    ...g,
    bayData: bays.find((b) => b.slug === g.bay),
    world: getWorldForBay(g.bay),
  }));

const bayPriority: Record<string, number> = { golf: 1, racing: 2, flight: 3, space: 4, marine: 5 };
const productsByBay = new Map(bays.map((b) => [
  b.slug,
  verifiedProducts.filter((p) => p.bay === b.slug).sort((a, c) => rankProduct(c) - rankProduct(a)),
]));
const moneyProducts = [
  ...((productsByBay.get('golf') || []).filter((p) => ['launch-monitor', 'enclosure', 'mat', 'projector'].includes(p.type)).slice(0, 5)),
  ...((productsByBay.get('racing') || []).filter((p) => ['base', 'pedals', 'cockpit', 'haptics'].includes(p.type)).slice(0, 5)),
  ...((productsByBay.get('flight') || []).filter((p) => ['yoke', 'throttle', 'rudder', 'head-tracking'].includes(p.type)).slice(0, 2)),
].slice(0, 12).map((p, i) => gearItem(p, i < 4 ? 'Money part' : undefined));
const lustKeys = [
  'golf/garmin-approach-r50',
  'racing/simucube-activepedal-pro',
  'racing/samsung-odyssey-oled-g9-49',
  'racing/sim-lab-p1x',
  'flight/honeycomb-alpha-yoke',
  'space/vkb-gladiator-nxt-evo-space-combat-edition',
];
const lustProducts = lustKeys
  .map((key) => verifiedProducts.find((p) => `${p.bay}/${p.id}` === key))
  .filter(Boolean)
  .map((p: any) => ({
    ...p,
    href: `/${p.bay}/gear/${p.id}`,
    buyUrl: buyUrl(p),
  }));
const heroBenchNotes = [
  {
    label: 'Room veto',
    title: 'Nina measures before anyone falls in love.',
    text: 'Ceiling, throw, hitting depth, and mat pain decide the golf bay before the launch monitor gets a vote.',
    href: '/golf/home-golf-simulator-build-sheet-2026',
    curator: crewByName.get('Nina Brooks'),
  },
  {
    label: 'Rig truth',
    title: 'Duke starts at the brake deck.',
    text: 'Torque is fun. A flexing cockpit just makes expensive force feedback tell lies louder.',
    href: '/racing/cockpit-rigidity-wheel-stand-vs-8020-2026',
    curator: crewByName.get('Duke Alvarez'),
  },
  {
    label: 'Cable tax',
    title: 'Val buys the powered hub first.',
    text: 'A cockpit that drops USB mid-flight is not immersive. It is an avoidable wiring problem.',
    href: '/flight/flight-sim-usb-hub-wiring-multi-panel',
    curator: crewByName.get('Val Chen'),
  },
].filter((note) => note.curator);

const bayLanes = [...bays]
  .sort((a, b) => (bayPriority[a.slug] || 9) - (bayPriority[b.slug] || 9))
  .map((bay) => {
    const bayProducts = (productsByBay.get(bay.slug) || []).slice(0, 3);
    const signal = (signals as any)[bay.slug];
    const world = getWorldForBay(bay.slug);
    return { bay, bayProducts, signal, world };
  });

const schema = [{
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: 'IgnitionSim certified simulator hardware buyer paths',
  itemListElement: cornerstones.map((a: any, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    name: a.data.title,
    url: new URL(`/${a.data.bay}/${slug(a)}`, site.url).href,
  })),
}];
---
<Base title={site.name} description={site.descriptor} schema={schema}>
  <section class="hero-v2" aria-label="IgnitionSim workshop">
    <img src={heroPhoto} alt="AI editorial concept of a premium simulator garage with racing, golf, flight, and hardware benches" loading="eager" decoding="async" />
    <div class="hero-v2-scrim"></div>
    <span class="ai-scene-badge">AI editorial concept</span>
    <div class="wrap hero-v2-inner">
      <div class="hero-v2-copy">
        <span class="lbl lbl-accent">Dream rigs. Real buying proof.</span>
        <h1>Build the rig in your head. Then buy like an adult.</h1>
        <p>IgnitionSim sells the dream first: the golf bay, racing cockpit, flight deck, space desk, or marine bridge you actually want to walk into. Then we get mean about fit, parts, subscriptions, install pain, and the products worth your money.</p>
        <div class="hero-actions">
          <a class="btn btn-primary btn-lg" href="#build-bays">Choose your sim world</a>
          <a class="btn btn-lg" href="#money-bench">See the parts bench</a>
        </div>
      </div>
      <div class="hero-bench-stack">
        <span>The crew's first warnings</span>
        {heroBenchNotes.map((note: any) => (
          <a class="hero-bench-card" href={note.href}>
            <img src={note.curator.image} alt={note.curator.alt} loading="eager" decoding="async" />
            <div>
              <small>{note.label} · {note.curator.handle}</small>
              <b>{note.title}</b>
              <p>{note.text}</p>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <div class="wrap">
    <section class="signal-strip" aria-label="IgnitionSim promise">
      <div><b>{all.length}</b><span>certified guides</span></div>
      <div><b>{verifiedProducts.length}</b><span>real product proof</span></div>
      <div><b>0</b><span>paid verdicts</span></div>
      <div><b>5</b><span>sim build bays</span></div>
    </section>

    <section class="sec home-world-section build-world" id="build-bays" style={`--world-bg: url('${getWorldForBay('racing').image}')`}>
      <div class="sec-head">
        <div>
          <span class="lbl lbl-accent">Build bays</span>
          <h2>Pick the world first. The hardware only matters after that.</h2>
        </div>
        <span class="lbl">highest-intent build lanes</span>
      </div>
      <div class="bay-command-grid">
        {bayLanes.map(({ bay, bayProducts, signal, world }) => (
          <a class="bay-command" data-bay={bay.slug} href={`/${bay.slug}`} style={`--world-bg: url('${world.image}')`}>
            <div class="bay-command-media">
              <img src={world.image} alt={world.alt || `${bay.name} simulator world`} loading="lazy" decoding="async" />
              <span>{bay.name}</span>
            </div>
            <div class="bay-command-copy">
              <h3>{bay.tagline}</h3>
              <p>{signal?.buyFast || bay.intro}</p>
              <div class="bay-chip-row">
                {bayProducts.map((p: any) => <span>{p.brand} {p.model}</span>)}
              </div>
            </div>
          </a>
        ))}
      </div>
    </section>

    <section class="sec home-world-section home-games-world" style={`--world-bg: url('${getWorldForBay('racing').image}')`}>
      <div class="sec-head">
        <div>
          <span class="lbl lbl-accent">Games hub</span>
          <h2>Start with what you play. Build the room around that.</h2>
        </div>
        <a class="lbl" href="/games">all sim games</a>
      </div>
      <div class="home-game-grid">
        {homeGameCards.map((game) => (
          <a class="home-game-card" data-bay={game.bay} href={`/games#${game.bay}`} style={`--world-bg: url('${game.world.image}')`}>
            <span>{game.bayData?.name || game.bay}</span>
            <h3>{game.name}</h3>
            <p>{game.signal}</p>
            <small>{game.hardwareThatMatters}</small>
          </a>
        ))}
      </div>
    </section>

    <section class="sec latest-rotator" aria-label="Latest IgnitionSim buyer guides">
      <div class="sec-head">
        <div>
          <span class="lbl lbl-accent">Sim Stream</span>
          <h2>Workbench dispatches worth reading before the cart opens.</h2>
        </div>
        <a class="lbl" href="/build-stream">open the Sim Stream</a>
      </div>
      <div class="latest-rail">
        {latestRotator.map(({ a, href, art }, i) => (
          <a class="latest-slide" data-bay={a.data.bay} href={href}>
            <div class:list={['latest-slide-art', art?.wide && 'is-wide-art']}>
              {art && <img src={art.image} alt={art.alt} loading={i < 2 ? 'eager' : 'lazy'} decoding="async" />}
              {art && <span>{art.label}</span>}
            </div>
            <div class="latest-slide-copy">
              <small>{a.data.type.replace(/-/g, ' ')} · {articleMeta(a.data)}</small>
              <h3>{a.data.title}</h3>
              <p>{a.data.excerpt || a.data.description}</p>
            </div>
          </a>
        ))}
      </div>
    </section>

    {latestBriefing.length > 0 && (
      <section class="sec curator-latest">
        <div class="sec-head">
          <div>
            <span class="lbl lbl-accent">Curator briefing</span>
            <h2>12 fresh routes through the build bench.</h2>
          </div>
          <span class="lbl">product-first · certified only</span>
        </div>
        <div class="curator-latest-grid">
          {latestBriefing.map(({ a, href, art, curator, i }) => (
            <a class="brief-card" data-bay={a.data.bay} href={href}>
              <div class:list={['brief-art', art?.wide && 'is-wide-art']}>
                {art && <img src={art.image} alt={art.alt} loading={i < 4 ? 'eager' : 'lazy'} decoding="async" />}
              </div>
              <div class="brief-body">
                <div class="brief-curator">
                  <img src={curator.image} alt={curator.alt} loading="lazy" decoding="async" />
                  <span>{curator.name} <b class="brief-handle">· {curator.handle}</b></span>
                </div>
                <h3>{a.data.title}</h3>
                <p>{a.data.excerpt || a.data.description}</p>
                <small>{articleMeta(a.data)}</small>
              </div>
            </a>
          ))}
        </div>
      </section>
    )}

    {lustProducts.length > 0 && (
      <section class="sec lust-section home-world-section" style={`--world-bg: url('${getWorldForBay('golf').image}')`}>
        <div class="sec-head">
          <div>
            <span class="lbl lbl-accent">Lust objects</span>
            <h2>The big pieces people daydream about before they ask what fits.</h2>
          </div>
          <span class="lbl">dream, then inspect</span>
        </div>
        <div class="lust-grid">
          {lustProducts.map((p: any) => (
            <article class="lust-card" data-bay={p.bay}>
              <a class="lust-image" href={p.href}>
                <img src={p.image} alt={`${p.brand} ${p.model}`} loading="lazy" decoding="async" />
              </a>
              <div class="lust-copy">
                <span>{p.type.replace(/-/g, ' ')}</span>
                <h3>{p.brand} {p.model}</h3>
                <p>{p.whoFor || p.summary}</p>
                <div class="lust-actions">
                  <a href={p.href}>Dig in</a>
                  {p.buyUrl && <a href={p.buyUrl} target="_blank" rel="sponsored nofollow noopener" data-event="lust_buy_click">Amazon ↗</a>}
                </div>
              </div>
            </article>
          ))}
        </div>
      </section>
    )}

    {moneyProducts.length > 0 && (
      <section class="sec home-world-section money-world" id="money-bench" style={`--world-bg: url('${getWorldForBay('racing').image}')`}>
        <div class="sec-head">
          <div>
            <span class="lbl lbl-accent">Parts bench</span>
            <h2>Buy once, cry once, worth-it parts.</h2>
          </div>
          <a class="lbl" href="/guides">certified buyer maps</a>
        </div>
        <GearCarousel items={moneyProducts} id="home-money-bench" />
      </section>
    )}

    {cornerstones.length > 0 && (
      <section class="sec home-world-section maps-world" style={`--world-bg: url('${getWorldForBay('flight').image}')`}>
        <div class="sec-head">
          <div>
            <span class="lbl lbl-accent">Certified maps</span>
            <h2>Only the buying maps strong enough to hand to a builder with a credit card.</h2>
          </div>
          <a class="lbl" href="/guides">all certified guides</a>
        </div>
        <div class="feature-guide-grid">
          {featureGuides.map(({ a, href, art, i }) => (
            <a class="feature-guide" href={href} data-bay={a.data.bay}>
              <div class:list={['feature-guide-media', art?.wide && 'is-wide-art']}>
                {art && <img src={art.image} alt={art.alt} loading="lazy" decoding="async" />}
                {art && <span class="feature-guide-badge">{art.label}</span>}
              </div>
              <div class="feature-guide-copy">
                <span class="feature-guide-index">{String(i + 1).padStart(2, '0')} / {a.data.type.replace(/-/g, ' ')}</span>
                <h3>{a.data.title}</h3>
                <p>{a.data.excerpt || a.data.description}</p>
              </div>
            </a>
          ))}
        </div>
      </section>
    )}

    <section class="sec crew-bench home-world-section" id="curator-bench" style={`--world-bg: url('${getWorldForBay('marine').image}')`}>
      <div class="sec-head">
        <div>
          <span class="lbl lbl-accent">Curator bench</span>
          <h2>Adult supervision for expensive toys.</h2>
        </div>
        <a class="lbl" href="/curators">meet the bench crew</a>
      </div>
      <div class="crew-grid">
        {(crew as any[]).map((person) => (
          <a class="crew-card" href={`/curator/${crewSlug(person)}`}>
            <img src={person.image} alt={person.alt} loading="lazy" decoding="async" />
            <div>
              <span>{person.handle}</span>
              <h3>{person.name}</h3>
              <p>{person.motto || person.voice}</p>
              <small>{person.currentObsession || person.beat}</small>
            </div>
          </a>
        ))}
      </div>
    </section>

    <section class="workbench-drop" id="newsletter" style={`--world-bg: url('${getWorldForBay('marine').image}')`}>
      <div>
        <span class="lbl lbl-accent">Workbench Drop</span>
        <h2>One useful upgrade note. No algorithm soup.</h2>
        <p>{site.newsletter.blurb} Product moves, forum wisdom, weekend-killer warnings, and the occasional “do not buy that yet” from the bench.</p>
      </div>
      <form name="workbench-drop" method="POST" data-netlify="true" netlify-honeypot="bot-field">
        <input type="hidden" name="form-name" value="workbench-drop" />
        <p class="sr-only"><label>Do not fill this out: <input name="bot-field" /></label></p>
        <input type="email" placeholder="builder@garage.net" aria-label="Email address" required />
        <button class="btn btn-primary" type="submit">Join the bench list</button>
      </form>
    </section>
  </div>
</Base>

<style>
  .hero-v2 {
    position: relative;
    min-height: min(760px, calc(100vh - 72px));
    display: flex;
    align-items: flex-end;
    overflow: hidden;
    border-bottom: 3px solid #101820;
  }
  .hero-v2 > img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: saturate(1.05) contrast(1.05);
  }
  .hero-v2-scrim {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(90deg, rgba(16, 24, 32, .92) 0%, rgba(16, 24, 32, .58) 45%, rgba(16, 24, 32, .08) 100%),
      linear-gradient(180deg, rgba(16, 24, 32, .08), rgba(16, 24, 32, .42));
  }
  .hero-v2-inner {
    position: relative;
    z-index: 2;
    width: 100%;
    display: grid;
    grid-template-columns: minmax(0, 1fr) 360px;
    gap: 28px;
    align-items: end;
    padding-top: 70px;
    padding-bottom: 42px;
  }
  .hero-v2-copy {
    max-width: 760px;
    color: #fff;
  }
  .hero-v2-copy h1 {
    max-width: 12ch;
    margin: 14px 0 18px;
    color: #fff;
    font-size: clamp(2.8rem, 6.8vw, 5.55rem);
    line-height: .92;
    text-transform: uppercase;
  }
  .hero-v2-copy p {
    max-width: 62ch;
    color: rgba(255,255,255,.86);
    font-size: 1.08rem;
  }
  .hero-actions { display: flex; flex-wrap: wrap; gap: 12px; margin-top: 24px; }
  .hero-bench-stack {
    align-self: end;
    display: grid;
    gap: 12px;
    max-width: 470px;
    padding: 14px;
    color: #fff;
    background:
      linear-gradient(145deg, rgba(16,24,32,.9), rgba(16,24,32,.68)),
      radial-gradient(360px 220px at 100% 0%, rgba(255,94,26,.22), transparent 72%);
    border: 2px solid rgba(255,255,255,.34);
    border-radius: 18px;
    box-shadow: 0 10px 0 rgba(16,24,32,.28), 0 28px 72px rgba(0,0,0,.28);
    -webkit-backdrop-filter: blur(10px);
    backdrop-filter: blur(10px);
  }
  .hero-bench-stack > span {
    font-family: var(--font-mono);
    font-size: .62rem;
    text-transform: uppercase;
    letter-spacing: .08em;
    font-weight: 800;
    color: color-mix(in srgb, var(--accent) 70%, #fff);
  }
  .hero-bench-card {
    min-width: 0;
    display: grid;
    grid-template-columns: 76px 1fr;
    gap: 12px;
    align-items: center;
    padding: 12px;
    border: 1px solid rgba(255,255,255,.28);
    border-radius: 14px;
    background: rgba(255,255,255,.93);
    color: #101820;
  }
  .hero-bench-card:hover {
    border-color: #fff;
    transform: translateY(-3px);
  }
  .hero-bench-card img {
    width: 76px;
    height: 76px;
    border-radius: 12px;
    object-fit: cover;
    object-position: center top;
    display: block;
    border: 2px solid rgba(16,24,32,.14);
    box-shadow: 0 10px 18px rgba(16,24,32,.16);
  }
  .hero-bench-card b {
    display: block;
    font-family: var(--font-disp);
    font-size: 1.05rem;
    line-height: 1.05;
  }
  .hero-bench-card small {
    display: block;
    margin-bottom: 5px;
    color: var(--accent);
    font-family: var(--font-mono);
    font-size: .54rem;
    font-weight: 900;
    letter-spacing: .1em;
    line-height: 1.25;
    text-transform: uppercase;
  }
  .hero-bench-card p {
    margin-top: 6px;
    color: #435363;
    font-size: .78rem;
    line-height: 1.42;
  }
  .signal-strip {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    margin: 28px 0 8px;
    border: 2px solid #101820;
    background: #fff;
    box-shadow: 0 8px 0 rgba(16, 24, 32, .12);
  }
  .signal-strip div {
    padding: 18px;
    border-right: 1px solid rgba(16, 24, 32, .12);
  }
  .signal-strip div:last-child { border-right: 0; }
  .signal-strip b {
    display: block;
    font-family: var(--font-disp);
    font-size: 2rem;
    line-height: 1;
    color: var(--accent);
  }
  .signal-strip span {
    display: block;
    margin-top: 7px;
    font-family: var(--font-mono);
    font-size: .62rem;
    text-transform: uppercase;
    letter-spacing: .1em;
    color: #435363;
  }
  .home-world-section {
    position: relative;
    margin: 34px 0;
