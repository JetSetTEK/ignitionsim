  /* Feature-guide cards — bulletproof vertical card: never skinny (min 320px),
     never towering (capped title/excerpt). Media on top, copy below. */
  .feature-guide-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: 20px;
  }
  .feature-guide {
    --world-a: var(--accent);
    --world-b: var(--accent2);
    color: #101820;
    display: flex;
    flex-direction: column;
    overflow: hidden;
    border: 2px solid color-mix(in srgb, var(--world-a) 34%, rgba(16,24,32,.16));
    border-radius: 20px;
    background: linear-gradient(160deg, #fff, color-mix(in srgb, var(--world-a) 5%, #f6f9fb));
    box-shadow: 0 10px 0 rgba(16,24,32,.10), 0 26px 56px rgba(16,24,32,.13);
    transition: transform .25s ease, box-shadow .25s ease, border-color .25s ease;
  }
  @media (prefers-reduced-motion: no-preference) {
    .feature-guide:hover {
      transform: translateY(-5px);
      border-color: #101820;
      box-shadow: 0 14px 0 rgba(16,24,32,.15), 0 34px 70px color-mix(in srgb, var(--world-a) 18%, transparent);
    }
  }
  .feature-guide-media {
    position: relative;
    display: grid;
    place-items: center;
    aspect-ratio: 16 / 10;
    width: 100%;
    padding: 22px 22px 26px;
    overflow: hidden;
    border-bottom: 2px solid rgba(16,24,32,.1);
    background:
      radial-gradient(360px 200px at 70% 18%, color-mix(in srgb, var(--world-b) 20%, transparent), transparent 72%),
      radial-gradient(340px 180px at 12% 108%, color-mix(in srgb, var(--world-a) 16%, transparent), transparent 72%),
      linear-gradient(150deg, color-mix(in srgb, var(--world-a) 12%, #fff), #fff 52%, color-mix(in srgb, var(--world-b) 10%, #fff));
  }
  /* soft pedestal so the product reads as staged, not lost */
  .feature-guide-media::before {
    content: "";
    position: absolute;
    left: 18%; right: 18%; bottom: 16px;
    height: 16%;
    border-radius: 999px;
    background: radial-gradient(ellipse at center, rgba(16,24,32,.20), transparent 70%);
    filter: blur(10px);
  }
  .feature-guide-media img {
    position: relative;
    z-index: 1;
    width: auto;
    max-width: 88%;
    max-height: 100%;
    object-fit: contain;
    filter: drop-shadow(0 20px 26px rgba(16,24,32,.26));
    transition: transform .4s ease;
  }
  @media (prefers-reduced-motion: no-preference) {
    .feature-guide:hover .feature-guide-media img { transform: scale(1.06); }
  }
  .feature-guide-media.is-wide-art {
    padding: 0;
    background: #101820;
  }
  .feature-guide-media.is-wide-art::before { display: none; }
  .feature-guide-media.is-wide-art img {
    width: 100%;
    max-width: none;
    height: 100%;
    max-height: none;
    object-fit: cover;
    filter: none;
  }
  @media (prefers-reduced-motion: no-preference) {
    .feature-guide:hover .feature-guide-media.is-wide-art img { transform: scale(1.03); }
  }
  .feature-guide-badge {
