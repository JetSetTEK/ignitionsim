---
import Base from '../layouts/Base.astro';
import ArticleCard from '../components/ArticleCard.astro';
import GearCarousel from '../components/GearCarousel.astro';
import { getCollection } from 'astro:content';
import site from '../data/site.json';
import bays from '../data/bays.json';
import games from '../data/games.json';
import signals from '../data/research-signals.json';
import crew from '../data/crew.json';
import { isCertifiedArticle, sortNewestArticles } from '../lib/content';
import { getArticleCardArt } from '../lib/articleArt';
import { hasVerifiedProductImage } from '../lib/productMedia';
import { getWorldForBay } from '../lib/worlds';

const all = sortNewestArticles(await getCollection('articles', ({ data }) => isCertifiedArticle(data)));
const articleById = new Map(all.map((a) => [a.id, a]));
const slug = (a: any) => a.id.split('/').pop();

const cornerstoneIds = [
  'racing/iracing-review-2026',
  'golf/premium-launch-monitor-room-fit-2026',
  'golf/budget-launch-monitor-war-2026',
  'golf/golf-simulator-projector-guide',
  'golf/golf-launch-monitors-under-5000-2026',
  'golf/home-golf-simulator-under-10000-2026',
  'golf/home-golf-simulator-build-sheet-2026',
  'racing/console-direct-drive-2026',
  'racing/direct-drive-upgrade-ladder-2026',
  'racing/active-pedals-vs-load-cell-hydraulic-2026',
  'racing/cockpit-rigidity-wheel-stand-vs-8020-2026',
  'flight/msfs-home-cockpit-buyer-map-2026',
  'space/star-citizen-hosas-buyer-map-2026',
];
const cornerstones = cornerstoneIds.map((id) => articleById.get(id)).filter(Boolean);
const featureGuides = cornerstones.map((a: any, i) => {
  const href = `/${a.data.bay}/${slug(a)}`;
  return { a, href, art: getArticleCardArt(href), i };
});
const latest = all.slice(0, 6);

const amazonTag = (site as any).affiliate?.amazonTag;
const prodMods = import.meta.glob('/src/data/products/*.json', { eager: true });
const allProducts = Object.values(prodMods).flatMap((m: any) => (m.default || m)) as any[];
const verifiedProducts = allProducts.filter(hasVerifiedProductImage);
const buyUrl = (p: any) => p.amazonAsin
  ? `https://www.amazon.com/dp/${p.amazonAsin}/?tag=${amazonTag}`
  : `https://www.amazon.com/s?k=${encodeURIComponent(p.brand + ' ' + p.model)}${amazonTag ? `&tag=${amazonTag}` : ''}`;
const rankProduct = (p: any) => (p.rating?.overall || 0) * 100 + Math.min(p.price || 0, 4000) / 1000;
const gearItem = (p: any, tag?: string) => ({
  href: `/${p.bay}/gear/${p.id}`,
  image: p.image || `/images/gear/${p.bay}/${p.id}.jpg`,
  brand: p.brand,
  model: p.model,
  price: p.price,
  priceNote: p.priceNote,
  type: p.type,
  buyUrl: buyUrl(p),
  tag,
});

const heroPhoto = '/images/dream/ignitionsim-dream-garage.webp';
const dreamScenes = [
  {
    bay: 'golf',
    image: getWorldForBay('golf').image,
    title: 'Golf should feel like sneaking into a private course after sunset.',
    copy: 'The dream is the view. The buy decision is ceiling height, enclosure width, projector throw, mat pain, and launch monitor fit.',
    href: '/golf/home-golf-simulator-build-sheet-2026',
  },
  {
    bay: 'racing',
    image: getWorldForBay('racing').image,
    title: 'Racing should smell like hot brakes and bad decisions you can afford.',
    copy: 'The dream is pit lane. The buy decision is cockpit rigidity, brake repeatability, display geometry, and ecosystem lock-in.',
    href: '/racing/cockpit-rigidity-wheel-stand-vs-8020-2026',
  },
  {
    bay: 'flight',
    image: getWorldForBay('flight').image,
    title: 'Flight should make the spare room feel cleared for departure.',
    copy: 'The dream is runway light. The buy decision is yoke/throttle order, rudders, head tracking, USB power, and sane bindings.',
    href: '/flight/msfs-home-cockpit-buyer-map-2026',
  },
  {
    bay: 'space',
    image: getWorldForBay('space').image,
    title: 'Space should feel like command authority, not desk spaghetti.',
    copy: 'The dream is six-axis control. The buy decision is HOSAS versus HOTAS, mounts, curves, and buttons you can find under stress.',
    href: '/space/star-citizen-hosas-buyer-map-2026',
  },
  {
    bay: 'marine',
    image: getWorldForBay('marine').image,
    title: 'Marine should feel like a bridge console during ugly weather.',
    copy: 'The dream is ocean glass and throttles. The buy decision is software support, DIY mapping, labels, and hardware that exists.',
    href: '/marine',
  },
];

const homeGameCards = (games as any[])
  .filter((g) => ['iracing', 'gspro', 'assetto-corsa-evo', 'microsoft-flight-simulator-2024', 'star-citizen'].includes(g.slug))
  .map((g) => ({
    ...g,
    bayData: bays.find((b) => b.slug === g.bay),
    world: getWorldForBay(g.bay),
  }));

const bayPriority: Record<string, number> = { golf: 1, racing: 2, flight: 3, space: 4, marine: 5 };
const productsByBay = new Map(bays.map((b) => [
  b.slug,
  verifiedProducts.filter((p) => p.bay === b.slug).sort((a, c) => rankProduct(c) - rankProduct(a)),
]));
const moneyProducts = [
  ...((productsByBay.get('golf') || []).filter((p) => ['launch-monitor', 'enclosure', 'mat', 'projector'].includes(p.type)).slice(0, 5)),
  ...((productsByBay.get('racing') || []).filter((p) => ['base', 'pedals', 'cockpit', 'haptics'].includes(p.type)).slice(0, 5)),
  ...((productsByBay.get('flight') || []).filter((p) => ['yoke', 'throttle', 'rudder', 'head-tracking'].includes(p.type)).slice(0, 2)),
].slice(0, 12).map((p, i) => gearItem(p, i < 4 ? 'Money part' : undefined));
const lustKeys = [
  'golf/garmin-approach-r50',
  'racing/simucube-activepedal-pro',
  'racing/samsung-odyssey-oled-g9-49',
  'racing/sim-lab-p1x',
  'flight/honeycomb-alpha-yoke',
  'space/vkb-gladiator-nxt-evo-space-combat-edition',
];
const lustProducts = lustKeys
  .map((key) => verifiedProducts.find((p) => `${p.bay}/${p.id}` === key))
  .filter(Boolean)
  .map((p: any) => ({
    ...p,
    href: `/${p.bay}/gear/${p.id}`,
    buyUrl: buyUrl(p),
  }));

const bayLanes = [...bays]
  .sort((a, b) => (bayPriority[a.slug] || 9) - (bayPriority[b.slug] || 9))
  .map((bay) => {
    const bayProducts = (productsByBay.get(bay.slug) || []).slice(0, 3);
    const signal = (signals as any)[bay.slug];
    const world = getWorldForBay(bay.slug);
    return { bay, bayProducts, signal, world };
  });

const schema = [{
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: 'IgnitionSim certified simulator hardware buyer paths',
  itemListElement: cornerstones.map((a: any, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    name: a.data.title,
    url: new URL(`/${a.data.bay}/${slug(a)}`, site.url).href,
  })),
}];
---
<Base title={site.name} description={site.descriptor} schema={schema}>
  <section class="hero-v2" aria-label="IgnitionSim workshop">
    <img src={heroPhoto} alt="AI editorial concept of a premium simulator garage with racing, golf, flight, and hardware benches" loading="eager" decoding="async" />
    <div class="hero-v2-scrim"></div>
    <span class="ai-scene-badge">AI editorial concept</span>
    <div class="wrap hero-v2-inner">
      <div class="hero-v2-copy">
        <span class="lbl lbl-accent">Dream rigs. Real buying proof.</span>
        <h1>Build the rig in your head. Then buy like an adult.</h1>
        <p>IgnitionSim sells the dream first: the golf bay, racing cockpit, flight deck, space desk, or marine bridge you actually want to walk into. Then we get mean about fit, parts, subscriptions, install pain, and the products worth your money.</p>
        <div class="hero-actions">
          <a class="btn btn-primary btn-lg" href="#build-bays">Choose your sim world</a>
          <a class="btn btn-lg" href="#money-bench">See the parts bench</a>
        </div>
      </div>
      <div class="dream-manifesto">
        <span>Dream first</span>
        <b>Then make the cart honest.</b>
        <p>Dream scenes are for ambition. Real product photos, owner complaints, and fit checks decide the cart.</p>
      </div>
    </div>
  </section>

  <div class="wrap">
    <section class="signal-strip" aria-label="IgnitionSim promise">
      <div><b>{all.length}</b><span>certified guides</span></div>
      <div><b>{verifiedProducts.length}</b><span>verified product photos</span></div>
      <div><b>0</b><span>sponsored verdicts</span></div>
      <div><b>5</b><span>sim build bays</span></div>
    </section>

    <section class="sec dream-strip home-world-section" aria-label="IgnitionSim dream scenes" style={`--world-bg: url('${getWorldForBay('space').image}')`}>
      <div class="sec-head">
        <div>
          <span class="lbl lbl-accent">Dream mecca</span>
          <h2>The rig has to make them want the weekend back.</h2>
        </div>
        <span class="lbl">curators, rooms, consequences</span>
      </div>
      <div class="dream-rail">
        {dreamScenes.map((scene) => (
          <a class="dream-slide" data-bay={scene.bay} href={scene.href}>
            <img src={scene.image} alt={`AI curator scene: ${scene.title}`} loading="lazy" decoding="async" />
            <span class="ai-scene-badge">AI world scene</span>
            <div>
              <span>{scene.bay}</span>
              <h3>{scene.title}</h3>
              <p>{scene.copy}</p>
            </div>
          </a>
        ))}
      </div>
    </section>

    <section class="sec home-world-section home-games-world" style={`--world-bg: url('${getWorldForBay('racing').image}')`}>
      <div class="sec-head">
        <div>
          <span class="lbl lbl-accent">Games hub</span>
          <h2>Start with what you play. Build the room around that.</h2>
        </div>
        <a class="lbl" href="/games">all sim games</a>
      </div>
      <div class="home-game-grid">
        {homeGameCards.map((game) => (
          <a class="home-game-card" data-bay={game.bay} href={`/games#${game.bay}`} style={`--world-bg: url('${game.world.image}')`}>
            <span>{game.bayData?.name || game.bay}</span>
            <h3>{game.name}</h3>
            <p>{game.signal}</p>
            <small>{game.hardwareThatMatters}</small>
          </a>
        ))}
      </div>
    </section>

    <section class="sec home-world-section build-world" id="build-bays" style={`--world-bg: url('${getWorldForBay('racing').image}')`}>
      <div class="sec-head">
        <div>
          <span class="lbl lbl-accent">Build bays</span>
          <h2>Five worlds to build. Each one punishes lazy measurements differently.</h2>
        </div>
        <span class="lbl">highest-intent build lanes</span>
      </div>
      <div class="bay-command-grid">
        {bayLanes.map(({ bay, bayProducts, signal, world }) => (
          <a class="bay-command" data-bay={bay.slug} href={`/${bay.slug}`} style={`--world-bg: url('${world.image}')`}>
            <div class="bay-command-media">
              <img src={world.image} alt={world.alt || `${bay.name} simulator world`} loading="lazy" decoding="async" />
              <span>{bay.name}</span>
            </div>
            <div class="bay-command-copy">
              <h3>{bay.tagline}</h3>
              <p>{signal?.buyFast || bay.intro}</p>
              <div class="bay-chip-row">
                {bayProducts.map((p: any) => <span>{p.brand} {p.model}</span>)}
              </div>
            </div>
          </a>
        ))}
      </div>
    </section>

    {lustProducts.length > 0 && (
      <section class="sec lust-section home-world-section" style={`--world-bg: url('${getWorldForBay('golf').image}')`}>
        <div class="sec-head">
          <div>
            <span class="lbl lbl-accent">Lust objects</span>
            <h2>The big pieces people daydream about before they ask what fits.</h2>
          </div>
          <span class="lbl">dream, then inspect</span>
        </div>
        <div class="lust-grid">
          {lustProducts.map((p: any) => (
            <article class="lust-card" data-bay={p.bay}>
              <a class="lust-image" href={p.href}>
                <img src={p.image} alt={`${p.brand} ${p.model}`} loading="lazy" decoding="async" />
              </a>
              <div class="lust-copy">
                <span>{p.type.replace(/-/g, ' ')}</span>
                <h3>{p.brand} {p.model}</h3>
                <p>{p.whoFor || p.summary}</p>
                <div class="lust-actions">
                  <a href={p.href}>Dig in</a>
                  <a href={p.buyUrl} target="_blank" rel="sponsored nofollow noopener" data-event="lust_buy_click">Amazon ↗</a>
                </div>
              </div>
            </article>
          ))}
        </div>
      </section>
    )}

    {moneyProducts.length > 0 && (
      <section class="sec home-world-section money-world" id="money-bench" style={`--world-bg: url('${getWorldForBay('racing').image}')`}>
        <div class="sec-head">
          <div>
            <span class="lbl lbl-accent">Parts bench</span>
            <h2>The expensive parts that make the dream feel real.</h2>
          </div>
          <a class="lbl" href="/guides">certified buyer maps</a>
        </div>
        <GearCarousel items={moneyProducts} id="home-money-bench" />
      </section>
    )}

    {cornerstones.length > 0 && (
      <section class="sec home-world-section maps-world" style={`--world-bg: url('${getWorldForBay('flight').image}')`}>
        <div class="sec-head">
          <div>
            <span class="lbl lbl-accent">Certified maps</span>
            <h2>Only the buying maps strong enough to hand to a builder with a credit card.</h2>
          </div>
          <a class="lbl" href="/guides">all certified guides</a>
        </div>
        <div class="feature-guide-grid">
          {featureGuides.map(({ a, href, art, i }) => (
            <a class="feature-guide" href={href} data-bay={a.data.bay}>
              <div class="feature-guide-media">
                {art && <img src={art.image} alt={art.alt} loading="lazy" decoding="async" />}
                {art && <span class="feature-guide-badge">{art.label}</span>}
              </div>
              <div class="feature-guide-copy">
                <span class="feature-guide-index">{String(i + 1).padStart(2, '0')} / {a.data.type.replace(/-/g, ' ')}</span>
                <h3>{a.data.title}</h3>
                <p>{a.data.excerpt || a.data.description}</p>
              </div>
            </a>
          ))}
        </div>
      </section>
    )}

    <section class="sec crew-bench home-world-section" style={`--world-bg: url('${getWorldForBay('marine').image}')`}>
      <div class="sec-head">
        <div>
          <span class="lbl lbl-accent">Curator bench</span>
          <h2>Adult supervision for expensive toys.</h2>
        </div>
        <span class="lbl">voices with jobs to do</span>
      </div>
      <div class="crew-grid">
        {(crew as any[]).map((person) => (
          <article class="crew-card">
            <img src={person.image} alt={person.alt} loading="lazy" decoding="async" />
            <div>
              <span>{person.handle}</span>
              <h3>{person.name}</h3>
              <p>{person.voice}</p>
              <small>{person.beat}</small>
            </div>
          </article>
        ))}
      </div>
    </section>

    {latest.length > 0 && (
      <section class="sec home-world-section latest-world" style={`--world-bg: url('${getWorldForBay('space').image}')`}>
        <div class="sec-head">
          <div>
            <span class="lbl lbl-accent">Latest certified</span>
            <h2>Fresh from the public bench.</h2>
          </div>
          <span class="lbl">certified only</span>
        </div>
        <div class="card-grid">
          {latest.map((a) => (
            <div data-bay={a.data.bay}>
              <ArticleCard href={`/${a.data.bay}/${slug(a)}`} title={a.data.title}
                excerpt={a.data.excerpt || a.data.description} type={a.data.type}
                image={a.data.heroImage} imageAlt={a.data.heroAlt}
                meta={`${a.data.bay.toUpperCase()} · ${a.data.readingTime || 6} min read`} />
            </div>
          ))}
        </div>
      </section>
    )}

    <section class="workbench-drop" style={`--world-bg: url('${getWorldForBay('marine').image}')`}>
      <div>
        <span class="lbl lbl-accent">Workbench Drop</span>
        <h2>One useful upgrade note. No algorithm soup.</h2>
        <p>{site.newsletter.blurb} Product moves, forum wisdom, weekend-killer warnings, and the occasional “do not buy that yet” from the bench.</p>
      </div>
      <form onsubmit="event.preventDefault(); window.toast && window.toast('newsletter signup is being wired into the new stack'); this.reset();">
        <input type="email" placeholder="builder@garage.net" aria-label="Email address" required />
        <button class="btn btn-primary" type="submit">Join the bench list</button>
      </form>
    </section>
  </div>
</Base>

<style>
  .hero-v2 {
    position: relative;
    min-height: min(760px, calc(100vh - 72px));
    display: flex;
    align-items: flex-end;
    overflow: hidden;
    border-bottom: 3px solid #101820;
  }
  .hero-v2 > img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: saturate(1.05) contrast(1.05);
  }
  .hero-v2-scrim {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(90deg, rgba(16, 24, 32, .92) 0%, rgba(16, 24, 32, .58) 45%, rgba(16, 24, 32, .08) 100%),
      linear-gradient(180deg, rgba(16, 24, 32, .08), rgba(16, 24, 32, .42));
  }
  .hero-v2-inner {
    position: relative;
    z-index: 2;
    width: 100%;
    display: grid;
    grid-template-columns: minmax(0, 1fr) 360px;
    gap: 28px;
    align-items: end;
    padding-top: 70px;
    padding-bottom: 42px;
  }
  .hero-v2-copy {
    max-width: 760px;
    color: #fff;
  }
  .hero-v2-copy h1 {
    max-width: 12ch;
    margin: 14px 0 18px;
    color: #fff;
    font-size: clamp(2.8rem, 6.8vw, 5.55rem);
    line-height: .92;
    text-transform: uppercase;
  }
  .hero-v2-copy p {
    max-width: 62ch;
    color: rgba(255,255,255,.86);
    font-size: 1.08rem;
  }
  .hero-actions { display: flex; flex-wrap: wrap; gap: 12px; margin-top: 24px; }
  .dream-manifesto {
    align-self: end;
    padding: 22px;
    color: #101820;
    background: rgba(255,255,255,.88);
    border: 2px solid rgba(255,255,255,.8);
    border-radius: 14px;
    box-shadow: 0 10px 0 rgba(16,24,32,.22);
    -webkit-backdrop-filter: blur(10px);
    backdrop-filter: blur(10px);
  }
  .dream-manifesto span {
    font-family: var(--font-mono);
    font-size: .62rem;
    text-transform: uppercase;
    letter-spacing: .08em;
    font-weight: 800;
    color: var(--accent);
  }
  .dream-manifesto b {
    display: block;
    margin-top: 8px;
    font-family: var(--font-disp);
    font-size: 1.55rem;
    line-height: 1;
  }
  .dream-manifesto p {
    margin-top: 10px;
    color: #435363;
    font-size: .92rem;
    line-height: 1.55;
  }
  .signal-strip {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    margin: 28px 0 8px;
    border: 2px solid #101820;
    background: #fff;
    box-shadow: 0 8px 0 rgba(16, 24, 32, .12);
  }
  .signal-strip div {
    padding: 18px;
    border-right: 1px solid rgba(16, 24, 32, .12);
  }
  .signal-strip div:last-child { border-right: 0; }
  .signal-strip b {
    display: block;
    font-family: var(--font-disp);
    font-size: 2rem;
    line-height: 1;
    color: var(--accent);
  }
  .signal-strip span {
    display: block;
    margin-top: 7px;
    font-family: var(--font-mono);
    font-size: .62rem;
    text-transform: uppercase;
    letter-spacing: .1em;
    color: #435363;
  }
  .home-world-section {
    position: relative;
    margin: 34px -18px;
    padding: 36px 18px 42px;
    overflow: hidden;
    border: 2px solid rgba(16,24,32,.18);
    border-radius: 32px;
    background:
      radial-gradient(820px 380px at 84% 6%, color-mix(in srgb, var(--accent) 22%, transparent), transparent 70%),
      linear-gradient(90deg, rgba(16,24,32,.92), rgba(16,24,32,.58) 45%, rgba(16,24,32,.3)),
      var(--world-bg) center / cover no-repeat;
    box-shadow: 0 14px 0 rgba(16,24,32,.14), 0 40px 90px rgba(16,24,32,.16);
  }
  .home-world-section::after {
    content: "";
    position: absolute;
    inset: 0;
    pointer-events: none;
    background:
      linear-gradient(rgba(255,255,255,.055) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255,255,255,.04) 1px, transparent 1px);
    background-size: 46px 46px;
    opacity: .36;
    mix-blend-mode: screen;
  }
  .home-world-section > * {
    position: relative;
    z-index: 1;
  }
  .home-world-section .sec-head h2,
  .home-world-section .sec-head .lbl {
    color: #fff;
    text-shadow: 0 2px 18px rgba(0,0,0,.3);
  }
  .home-world-section .sec-head .lbl-accent,
  .home-world-section .sec-head a {
    color: color-mix(in srgb, var(--accent) 68%, #fff);
  }
  .dream-strip {
    background:
      radial-gradient(760px 360px at 88% 8%, rgba(217,70,239,.24), transparent 70%),
      linear-gradient(90deg, rgba(16,24,32,.94), rgba(16,24,32,.48)),
      var(--world-bg) center / cover no-repeat;
  }
  .dream-rail {
    display: grid;
    grid-auto-flow: column;
    grid-auto-columns: minmax(640px, 78%);
    gap: 18px;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    padding: 4px 2px 18px;
    -ms-overflow-style: none;
    scrollbar-width: none;
  }
  .dream-rail::-webkit-scrollbar { display: none; }
  .dream-slide {
    position: relative;
    min-height: 480px;
    overflow: hidden;
    border: 2px solid rgba(255,255,255,.24);
    border-radius: 22px;
    color: #fff;
    scroll-snap-align: start;
    box-shadow: 0 11px 0 rgba(16,24,32,.28), 0 32px 72px rgba(0,0,0,.26);
  }
  .dream-slide img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform .7s ease;
  }
  .dream-slide::after {
    content: "";
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, transparent 34%, rgba(16,24,32,.86));
  }
  .dream-slide:hover img { transform: scale(1.04); }
  .dream-slide div {
    position: absolute;
    left: 0;
