---
import Base from '../layouts/Base.astro';
import { getCollection } from 'astro:content';
import site from '../data/site.json';
import bays from '../data/bays.json';
import signals from '../data/research-signals.json';
import crew from '../data/crew.json';
import editorialSurfaces from '../data/editorial-surfaces.json';
import { articleMeta, articleSlug, isCertifiedArticle, sortNewestArticles } from '../lib/content';
import { getArticleCardArt } from '../lib/articleArt';
import { crewSlug } from '../lib/crew';
import { getWorldForBay } from '../lib/worlds';
import { clearsDiscoveryGate, clearsHomepageGate, evidenceLabels, qualityFor, sortByEditorialStrength } from '../lib/editorial';

const all = sortNewestArticles(await getCollection('articles', ({ data }) => isCertifiedArticle(data)));
const articleHref = (entry: any) => `/${entry.data.bay}/${articleSlug(entry)}`;
const crewByName = new Map((crew as any[]).map((person) => [person.name, person]));
const curatorFor = (entry: any) => crewByName.get(entry.data.author) || (crew as any[])[0];

const takeDiverse = (items: any[], limit: number, used = new Set<string>()) => {
  const remaining = items.filter((item) => !used.has(item.id));
  const picked: any[] = [];
  while (picked.length < limit && remaining.length) {
    const previousBay = picked[picked.length - 1]?.data?.bay;
    const index = remaining.findIndex((item) => item.data.bay !== previousBay);
    const [next] = remaining.splice(index >= 0 ? index : 0, 1);
    picked.push(next);
    used.add(next.id);
  }
  return picked;
};

const editorialLeaders = sortByEditorialStrength(all.filter((entry) => clearsHomepageGate(entry.id)));
const discoveryPool = sortByEditorialStrength(all.filter((entry) => clearsDiscoveryGate(entry.id)));
const promotedIds = new Set<string>();
const investigations = takeDiverse(editorialLeaders, 3, promotedIds).map((entry) => ({
  entry,
  href: articleHref(entry),
  art: getArticleCardArt(articleHref(entry)),
  curator: curatorFor(entry),
  quality: qualityFor(entry.id),
  evidence: evidenceLabels(entry.id),
}));
const streamPreview = takeDiverse(discoveryPool, 5, promotedIds).map((entry) => ({
  entry,
  href: articleHref(entry),
  art: getArticleCardArt(articleHref(entry)),
  curator: curatorFor(entry),
  quality: qualityFor(entry.id),
}));

const curatorActions = (editorialSurfaces as any).curatorActions as Record<string, any[]>;
const benchVoices = (crew as any[]).map((person, index) => ({
  person,
  scene: curatorActions[crewSlug(person)]?.[index % 2] || { image: person.scene, alt: person.sceneAlt, task: person.currentObsession },
  verdict: person.favoriteWarning || person.hillsToDieOn?.[0],
}));

const bayPriority: Record<string, number> = { racing: 1, golf: 2, flight: 3, space: 4, marine: 5 };
const worldLanes = [...bays]
  .sort((a, b) => (bayPriority[a.slug] || 9) - (bayPriority[b.slug] || 9))
  .map((bay) => ({ bay, world: getWorldForBay(bay.slug), signal: (signals as any)[bay.slug] || {} }));

const realBuilds = (editorialSurfaces as any).realBuilds as any[];
const objectsOfDesire = (editorialSurfaces as any).objectsOfDesire as any[];
const heroPhoto = '/images/dream/ignitionsim-dream-garage.webp';

const schema = [{
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: 'IgnitionSim editor-selected simulator buyer guides',
  itemListElement: investigations.map((item, index) => ({
    '@type': 'ListItem',
    position: index + 1,
    name: item.entry.data.title,
    url: new URL(item.href, site.url).href,
  })),
}];
---
<Base title={site.name} description={site.descriptor} schema={schema}>
  <section class="home-hero" aria-label="IgnitionSim simulator workshop">
    <img src={heroPhoto} alt="AI editorial concept of an aspirational simulator workshop with racing, golf, flight, and hardware bays" loading="eager" decoding="async" />
    <div class="home-hero-shade"></div>
    <span class="ai-scene-badge">AI editorial concept</span>
    <div class="wrap home-hero-inner">
      <div class="home-hero-copy">
        <span class="lbl lbl-accent">The rig should make you want the weekend back</span>
        <h1>Build the room you keep seeing in your head.</h1>
        <p>Start with the dream. Then let five obsessive builders interrogate the room, the mounting, the subscriptions, the firmware, and the parts that can turn it into an expensive mistake.</p>
        <div class="hero-actions">
          <a class="btn btn-primary btn-lg" href="#worlds">Choose your sim world</a>
          <a class="btn btn-lg" href="#investigations">See the strongest guides</a>
        </div>
      </div>
      <aside class="weekend-brief">
        <img src={benchVoices[0].scene.image} alt={benchVoices[0].scene.alt} loading="eager" decoding="async" />
        <div>
          <span>Weekend objective · {benchVoices[0].person.handle}</span>
          <h2>{benchVoices[0].scene.task}</h2>
          <p>{benchVoices[0].person.benchMove}</p>
          <div class="weekend-links">
            <button type="button" data-open-crew-chat>Ask Duke about the build</button>
            <a href={`/curator/${crewSlug(benchVoices[0].person)}`}>Open Duke's bench notes</a>
          </div>
        </div>
      </aside>
    </div>
  </section>

  <section class="world-band" id="worlds">
    <div class="wrap">
      <div class="section-intro light-copy">
        <div><span class="lbl lbl-accent">Five build worlds</span><h2>Walk into the room first.</h2></div>
        <p>The category is not a filter. It is the environment every purchase has to survive.</p>
      </div>
      <div class="world-grid">
        {worldLanes.map(({ bay, world, signal }) => (
          <a class="world-door" data-bay={bay.slug} href={`/${bay.slug}`}>
            <img src={world.image} alt={world.alt} loading="lazy" decoding="async" />
            <div>
              <span>{bay.name}</span>
              <h3>{world.label}</h3>
              <p>{signal.buyFast || bay.tagline}</p>
              <small>Enter the {bay.name.toLowerCase()} bay</small>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="bench-says-band">
    <div class="wrap">
      <div class="section-intro">
        <div><span class="lbl lbl-accent">The bench says</span><h2>Five people who will interrupt the spec sheet.</h2></div>
        <a class="text-link" href="/curators">Meet the entire bench crew</a>
      </div>
      <div class="bench-rail">
        {benchVoices.map(({ person, scene, verdict }) => (
          <a class="bench-verdict" href={`/curator/${crewSlug(person)}`} data-bay={String(person.bay).toLowerCase().split(' ')[0]}>
            <div class="bench-scene">
              <img src={scene.image} alt={scene.alt} loading="lazy" decoding="async" />
              <span>AI editorial scene</span>
            </div>
            <div class="bench-copy">
              <small>{person.handle} · {scene.task}</small>
              <h3>{person.name}</h3>
              <blockquote>“{verdict}”</blockquote>
              <p>{person.voice}</p>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="real-build-band">
    <div class="wrap">
      <div class="section-intro light-copy">
        <div><span class="lbl lbl-accent">Real builds · real people</span><h2>This is what the dream has to survive.</h2></div>
        <p>Real rooms and real controls first. Editorial scenes are labeled. Product proof stays product proof.</p>
      </div>
      <div class="real-build-grid">
        {realBuilds.map((build, index) => (
          <article class:list={['real-build', index === 0 && 'lead']} data-bay={build.bay}>
            <a class="real-build-image" href={build.href}><img src={build.image} alt={build.alt} loading="lazy" decoding="async" /></a>
            <div>
              <span>{build.bay} build study</span>
              <h3>{build.title}</h3>
              <p>{build.dek}</p>
              <a class="photo-credit" href={build.creditUrl} target="_blank" rel="noopener">Photo: {build.credit}</a>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="investigation-band" id="investigations">
    <div class="wrap">
      <div class="section-intro">
        <div><span class="lbl lbl-accent">Current investigations</span><h2>Three guides strong enough for the front bench.</h2></div>
        <p>Every guide here cleared the A-grade authority gate. Nothing is promoted because it merely exists.</p>
      </div>
      <div class="investigation-grid">
        {investigations.map(({ entry, href, art, curator, quality, evidence }, index) => (
          <a class:list={['investigation-card', index === 0 && 'lead']} data-bay={entry.data.bay} href={href}>
            <div class="investigation-image">
              {art && <img src={art.image} alt={art.alt} loading={index === 0 ? 'eager' : 'lazy'} decoding="async" />}
              <span class="grade">{quality?.grade} · {quality?.score}/100</span>
            </div>
            <div class="investigation-copy">
              <div class="investigator"><span>{curator.name} · {entry.data.type.replace(/-/g, ' ')}</span></div>
              <h3>{entry.data.title}</h3>
              <p>{entry.data.excerpt || entry.data.description}</p>
              <blockquote class="investigator-note">&ldquo;{curator.favoriteWarning}&rdquo;</blockquote>
              <div class="evidence-row">{evidence.map((label) => <span>{label}</span>)}</div>
              <small>{articleMeta(entry.data)}</small>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="desire-band">
    <div class="wrap">
      <div class="section-intro light-copy">
        <div><span class="lbl lbl-accent">Objects of desire</span><h2>The parts that make builders lean toward the screen.</h2></div>
        <p>Shown installed or in use wherever the proof exists. No white marketplace squares pretending to be atmosphere.</p>
      </div>
      <div class="desire-grid">
        {objectsOfDesire.map((item, index) => (
          <a class:list={['desire-card', index % 3 === 0 && 'wide']} data-bay={item.bay} href={item.href}>
            <div class="desire-image"><img src={item.image} alt={item.alt} loading="lazy" decoding="async" /><span>{item.proof}</span></div>
            <div><small>{item.eyebrow}</small><h3>{item.title}</h3><p>{item.verdict}</p><b>Inspect the product →</b></div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="stream-preview-band">
    <div class="wrap">
      <div class="section-intro">
        <div><span class="lbl lbl-accent">Sim Stream</span><h2>Five more routes from the information river.</h2></div>
        <a class="text-link" href="/build-stream">Open the full Sim Stream</a>
      </div>
      <div class="stream-preview-list">
        {streamPreview.map(({ entry, href, art, curator, quality }, index) => (
          <a class="stream-preview-row" data-bay={entry.data.bay} href={href}>
            <span class="stream-index">{String(index + 1).padStart(2, '0')}</span>
            <div class="stream-preview-image">{art && <img src={art.image} alt={art.alt} loading="lazy" decoding="async" />}</div>
            <div class="stream-preview-copy">
              <small>{entry.data.bay} · {entry.data.type.replace(/-/g, ' ')} · {quality?.grade}</small>
              <h3>{entry.data.title}</h3>
              <p>{entry.data.excerpt || entry.data.description}</p>
            </div>
            <div class="stream-curator"><span>{curator.name}</span><blockquote>&ldquo;{curator.benchMove}&rdquo;</blockquote></div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="crew-debate-band">
    <div class="wrap debate-layout">
      <div class="debate-copy">
        <span class="lbl lbl-accent">The bench, mid-argument</span>
        <h2>Good builders do not agree. They expose the trade.</h2>
        <p>Every curator has a history, a current rig, expensive mistakes, and a different tolerance for setup pain. Their job is not to decorate a card. It is to tell you what they would buy, what they would skip, and what ruins the weekend.</p>
        <a class="btn btn-primary" href="/curators">Listen at the bench</a>
      </div>
      <div class="debate-thread">
        {benchVoices.slice(1, 5).map(({ person }, index) => (
          <a href={`/curator/${crewSlug(person)}`}>
            <img src={person.image} alt={person.alt} loading="lazy" decoding="async" />
            <div><span>{person.handle}</span><blockquote>“{person.hillsToDieOn?.[index % person.hillsToDieOn.length] || person.favoriteWarning}”</blockquote></div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="newsletter-band" id="newsletter">
    <div class="wrap newsletter-inner">
      <div><span class="lbl lbl-accent">Workbench Drop</span><h2>One useful upgrade note. No algorithm soup.</h2><p>{site.newsletter.blurb} Product moves, forum wisdom, owner warnings, and the occasional “wait for version two.”</p></div>
      <form name="workbench-drop" method="POST" data-netlify="true" netlify-honeypot="bot-field">
        <input type="hidden" name="form-name" value="workbench-drop" />
        <p class="sr-only"><label>Do not fill this out: <input name="bot-field" /></label></p>
        <input type="email" name="email" placeholder="builder@garage.net" aria-label="Email address" required />
        <button class="btn btn-primary" type="submit">Join the bench list</button>
      </form>
    </div>
  </section>
</Base>

<style>
  .home-hero { position: relative; min-height: min(780px, calc(100vh - 72px)); display: flex; align-items: flex-end; overflow: hidden; background: #101820; }
  .home-hero > img { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; filter: saturate(1.14) contrast(1.02) brightness(1.06); }
  .home-hero-shade { position: absolute; inset: 0; background: linear-gradient(90deg, rgba(8,15,22,.93), rgba(8,15,22,.48) 55%, rgba(8,15,22,.12)), linear-gradient(180deg, rgba(8,15,22,.04), rgba(8,15,22,.58)); }
  .home-hero-inner { position: relative; z-index: 2; width: 100%; display: grid; grid-template-columns: minmax(0, 1fr) 430px; gap: 38px; align-items: end; padding-top: 84px; padding-bottom: 42px; }
  .home-hero-copy { max-width: 830px; color: #fff; }
  .home-hero-copy h1 { max-width: 12ch; margin: 14px 0 18px; color: #fff; font-size: clamp(3.2rem, 7vw, 6.5rem); line-height: .89; text-transform: uppercase; }
  .home-hero-copy p { max-width: 66ch; color: rgba(255,255,255,.88); font-size: 1.08rem; line-height: 1.65; }
  .hero-actions { display: flex; flex-wrap: wrap; gap: 12px; margin-top: 24px; }
  .weekend-brief { overflow: hidden; border: 2px solid rgba(255,255,255,.45); background: rgba(255,255,255,.95); color: #101820; box-shadow: 0 14px 0 rgba(6,12,18,.28), 0 40px 90px rgba(0,0,0,.28); }
  .weekend-brief img { width: 100%; aspect-ratio: 16/10; object-fit: cover; display: block; }
  .weekend-brief div { padding: 20px; }
  .weekend-brief span, .weekend-brief a { color: var(--accent); font-family: var(--font-mono); font-size: .62rem; font-weight: 900; letter-spacing: .09em; text-transform: uppercase; }
  .weekend-brief h2 { margin-top: 9px; font-size: 1.45rem; line-height: 1.08; }
  .weekend-brief p { margin: 9px 0 14px; color: #435363; font-size: .9rem; line-height: 1.5; }
  .weekend-links { display: flex; flex-wrap: wrap; gap: 10px; padding: 0 !important; }
  .weekend-links button, .weekend-links a { padding: 0; border: 0; color: var(--accent); background: none; font-family: var(--font-mono); font-size: .62rem; font-weight: 900; letter-spacing: .09em; text-transform: uppercase; cursor: pointer; }
  .weekend-links button { color: #101820; text-decoration: underline; text-decoration-color: var(--accent); text-underline-offset: 3px; }

  .section-intro { display: grid; grid-template-columns: minmax(0, 1fr) minmax(240px, 470px); gap: 28px; align-items: end; margin-bottom: 28px; }
  .section-intro h2 { max-width: 16ch; margin-top: 8px; font-size: clamp(2rem, 4.5vw, 4.2rem); line-height: .95; text-transform: uppercase; }
  .section-intro > p { color: #536272; font-size: 1rem; line-height: 1.65; }
  .light-copy h2, .light-copy p { color: #fff; }
  .light-copy p { color: rgba(255,255,255,.78); }
  .text-link { align-self: end; color: var(--accent); font-family: var(--font-mono); font-size: .68rem; font-weight: 900; letter-spacing: .08em; text-transform: uppercase; }

  .world-band { padding: 64px 0 72px; background: #101820; color: #fff; }
  .world-grid { display: grid; grid-template-columns: repeat(5, minmax(0,1fr)); gap: 12px; }
  .world-door { position: relative; min-height: 470px; overflow: hidden; color: #fff; border: 1px solid rgba(255,255,255,.26); }
  .world-door img { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; transition: transform .6s ease; }
  .world-door::after { content:""; position:absolute; inset:0; background: linear-gradient(180deg, rgba(8,15,22,.03) 24%, rgba(8,15,22,.92)); }
  .world-door > div { position: absolute; z-index: 1; inset: auto 0 0; padding: 22px; }
  .world-door span, .world-door small { color: color-mix(in srgb, var(--accent) 68%, #fff); font-family: var(--font-mono); font-size: .58rem; font-weight: 900; letter-spacing: .12em; text-transform: uppercase; }
  .world-door h3 { margin-top: 8px; color: #fff; font-size: 1.55rem; line-height: 1.02; }
  .world-door p { margin: 10px 0 16px; color: rgba(255,255,255,.78); font-size: .84rem; line-height: 1.5; }
  .world-door:hover img { transform: scale(1.055); }

  .bench-says-band { padding: 72px 0; background: #f6f1ea; }
  .bench-rail { display: grid; grid-auto-flow: column; grid-auto-columns: minmax(420px, 46%); gap: 18px; overflow-x: auto; padding: 4px 4px 22px; scroll-snap-type: x mandatory; scrollbar-width: thin; }
  .bench-verdict { display: grid; grid-template-columns: 48% 1fr; min-height: 340px; overflow: hidden; color: #101820; background: #fff; border: 2px solid #101820; box-shadow: 0 10px 0 rgba(16,24,32,.12); scroll-snap-align: start; }
  .bench-scene { position: relative; min-height: 340px; }
  .bench-scene img { position:absolute; inset:0; width:100%; height:100%; object-fit:cover; }
  .bench-scene span { position:absolute; z-index:1; left:12px; bottom:12px; padding:6px 8px; background:rgba(16,24,32,.82); color:#fff; font-family:var(--font-mono); font-size:.5rem; text-transform:uppercase; letter-spacing:.08em; }
  .bench-copy { align-self: center; padding: 26px; }
  .bench-copy small, .bench-copy h3 { color: var(--accent); }
  .bench-copy small { font-family: var(--font-mono); font-size:.56rem; font-weight:900; letter-spacing:.09em; text-transform:uppercase; }
  .bench-copy h3 { margin-top:9px; font-size:1.45rem; }
  .bench-copy blockquote { margin:14px 0; font-family:var(--font-disp); font-size:1.28rem; line-height:1.18; }
  .bench-copy p { color:#5a6874; font-size:.88rem; line-height:1.5; }

  .real-build-band { padding: 72px 0 80px; color:#fff; background: linear-gradient(135deg,#152331,#09131d); }
  .real-build-grid { display:grid; grid-template-columns: 1.35fr 1fr; gap:18px; }
  .real-build { display:grid; grid-template-columns: 1.1fr .9fr; min-height:320px; background:#fff; color:#101820; overflow:hidden; }
  .real-build.lead { grid-row: span 2; grid-template-columns:1fr; grid-template-rows: minmax(390px,1fr) auto; }
  .real-build-image { min-height:260px; overflow:hidden; }
  .real-build-image img { width:100%; height:100%; object-fit:cover; display:block; transition:transform .6s ease; }
  .real-build:hover .real-build-image img { transform:scale(1.03); }
  .real-build > div { padding:24px; align-self:center; }
  .real-build span, .real-build .photo-credit { color:var(--accent); font-family:var(--font-mono); font-size:.56rem; font-weight:900; letter-spacing:.1em; text-transform:uppercase; }
  .real-build h3 { margin-top:9px; font-size:1.45rem; line-height:1.08; }
  .real-build p { margin:10px 0 14px; color:#435363; font-size:.9rem; line-height:1.55; }

  .investigation-band { padding:76px 0 86px; background:#edf4f8; }
  .investigation-grid { display:grid; grid-template-columns:1.15fr .85fr; gap:20px; }
  .investigation-card { display:grid; grid-template-rows:auto 1fr; overflow:hidden; color:#101820; border:2px solid rgba(16,24,32,.16); background:#fff; box-shadow:0 10px 0 rgba(16,24,32,.1); }
  .investigation-card.lead { grid-row:span 2; }
  .investigation-card:not(.lead) { grid-template-columns:42% 1fr; grid-template-rows:1fr; min-height:330px; }
  .investigation-image { position:relative; aspect-ratio:16/9; overflow:hidden; background:#101820; }
  .investigation-card:not(.lead) .investigation-image { aspect-ratio:auto; }
  .investigation-image img { width:100%; height:100%; object-fit:cover; display:block; transition:transform .5s ease; }
  .investigation-card:hover .investigation-image img { transform:scale(1.03); }
  .grade { position:absolute; left:14px; top:14px; padding:7px 9px; background:#ff5e1a; border:1px solid #101820; color:#101820; font-family:var(--font-mono); font-size:.56rem; font-weight:900; letter-spacing:.08em; }
  .investigation-copy { padding:24px; align-self:center; }
  .investigator { display:flex; gap:9px; align-items:center; color:var(--accent); font-family:var(--font-mono); font-size:.56rem; font-weight:900; letter-spacing:.08em; text-transform:uppercase; }
  .investigator::before { content:"//"; display:grid; place-items:center; width:34px; height:34px; flex:none; color:#101820; background:var(--accent); border:1px solid #101820; }
  .investigation-copy h3 { margin-top:13px; font-size:clamp(1.3rem,2.2vw,2rem); line-height:1.04; }
  .investigation-copy p { margin-top:11px; color:#435363; line-height:1.55; }
  .investigator-note { margin-top:14px; padding:11px 13px; border-left:3px solid var(--accent); color:#263541; background:#f3f6f8; font-family:var(--font-disp); font-size:.9rem; line-height:1.4; }
  .evidence-row { display:flex; flex-wrap:wrap; gap:7px; margin-top:15px; }
  .evidence-row span { padding:6px 8px; border:1px solid rgba(16,24,32,.14); color:#42515e; font-family:var(--font-mono); font-size:.52rem; text-transform:uppercase; letter-spacing:.06em; }
  .investigation-copy > small { display:block; margin-top:14px; color:var(--accent); font-family:var(--font-mono); font-size:.56rem; font-weight:900; text-transform:uppercase; letter-spacing:.07em; }

  .desire-band { padding:78px 0 86px; color:#fff; background:#12100e; }
  .desire-grid { display:grid; grid-template-columns:repeat(3,minmax(0,1fr)); gap:16px; }
  .desire-card { display:grid; grid-template-rows:280px auto; overflow:hidden; color:#101820; background:#fff; }
  .desire-card.wide { grid-column:span 2; grid-template-columns:1.25fr .75fr; grid-template-rows:1fr; min-height:390px; }
  .desire-image { position:relative; overflow:hidden; background:#1d2935; }
  .desire-image img { width:100%; height:100%; object-fit:cover; display:block; transition:transform .55s ease; }
