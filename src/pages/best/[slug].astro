---
import Base from '../../layouts/Base.astro';
import lists from '../../data/stat-lists.json';
import bays from '../../data/bays.json';
import site from '../../data/site.json';
import { hasVerifiedProductImage } from '../../lib/productMedia';
import { canonicalAmazonProductUrl } from '../../lib/amazon';

export async function getStaticPaths() {
  return (lists as any[]).map((list) => ({ params: { slug: list.slug }, props: { list } }));
}
const { list } = Astro.props;
const bay = bays.find((b) => b.slug === list.bay)!;

const mods = import.meta.glob('/src/data/products/*.json', { eager: true });
const all = Object.values(mods).flatMap((m: any) => (m.default || [])) as any[];
const types = [list.type, ...(list.altTypes || [])];
const amazonTag = (site as any).affiliate?.amazonTag;
let items = all
  .filter((p) => p.bay === list.bay && types.includes(p.type) && hasVerifiedProductImage(p))
  .map((p) => ({ ...p, amazonUrl: canonicalAmazonProductUrl(p, amazonTag) }))
  .filter((p) => p.amazonUrl);
if (list.priceMax) items = items.filter((p) => p.price && p.price <= list.priceMax);
if (list.priceMin) items = items.filter((p) => p.price && p.price >= list.priceMin);
const mv = (p: any) => list.sortBy === 'value' ? (p.rating?.value || 0) : list.sortBy === 'accuracy' ? (p.rating?.accuracy || 0) : list.sortBy.startsWith('price') ? (p.price || 0) : (p.rating?.overall || 0);
items.sort((a, b) => list.sortBy === 'price-asc' ? mv(a) - mv(b) : mv(b) - mv(a));
items = items.slice(0, list.limit || 10);

const url = new URL(`/best/${list.slug}`, site.url).href;
const schema = [
  { '@context': 'https://schema.org', '@type': 'ItemList', name: list.title, description: list.intro, numberOfItems: items.length, itemListOrder: 'https://schema.org/ItemListOrderDescending',
    itemListElement: items.map((p, i) => ({ '@type': 'ListItem', position: i + 1, name: `${p.brand} ${p.model}`, url: new URL(`/${p.bay}/gear/${p.id}`, site.url).href })) },
  { '@context': 'https://schema.org', '@type': 'BreadcrumbList', itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: site.url },
    { '@type': 'ListItem', position: 2, name: 'Best lists', item: new URL('/best', site.url).href },
    { '@type': 'ListItem', position: 3, name: list.title, item: url } ] },
];
const updated = new Date().toLocaleDateString('en-US', { month: 'long', year: 'numeric' });
---
<Base title={`${list.title} (${updated})`} description={list.intro} bay={list.bay} activeNav={list.bay} schema={schema} image={`/images/${list.bay}/hero.jpg`} noindex={true}>
  <div class="wrap">
    <div class="crumbs"><a href="/">Home</a><span>/</span><a href="/best">Best</a><span>/</span>{list.title}</div>
    <section class="hero" style="text-align:left;padding:34px 0 8px">
      <div class="lbl lbl-accent">// {bay.name} · ranked by the IgnitionSim Verdict</div>
      <h1 style="font-size:clamp(2rem,5vw,3rem);max-width:22ch">{list.title}</h1>
      <p style="color:var(--dim);max-width:64ch;margin-top:12px;font-size:1.04rem">{list.intro}</p>
      <p class="byline" style="margin-top:10px">By <b>{site.author.name}</b> · updated {updated} · <a href="/methodology">how we score</a></p>
    </section>

    <section class="sec" style="padding-top:14px">
      <table class="spec-table">
        <thead><tr><th>#</th><th>Product</th><th>Price</th><th>Verdict</th></tr></thead>
        <tbody>
          {items.map((p, i) => (
            <tr>
              <td style="color:var(--accent);font-family:var(--font-mono)">{i + 1}</td>
              <td><a href={p.amazonUrl} target="_blank" rel="sponsored nofollow noopener" data-buy-link="true" data-event="buy_click" data-buy-product={p.id}><b>{p.brand}</b> {p.model}</a> · <a href={`/${p.bay}/gear/${p.id}`}>specs</a></td>
              <td>{p.price ? `~$${p.price.toLocaleString()}` : '—'}</td>
              <td style="color:var(--accent)">{p.rating?.overall ? `${p.rating.overall}/10` : '—'}</td>
            </tr>
          ))}
        </tbody>
      </table>

      <div class="card-grid" style="margin-top:24px">
        {items.slice(0, 6).map((p, i) => (
          <article class="card commerce-card">
            <a class="cimg" href={p.amazonUrl} target="_blank" rel="sponsored nofollow noopener" data-buy-link="true" data-event="buy_click" data-buy-product={p.id}><img src={p.image} alt={`${p.brand} ${p.model}`} loading="lazy" /></a>
            <div class="cbody">
              <span class="ctype">#{i + 1} · {p.brand}{p.rating?.overall ? ` · ${p.rating.overall}/10` : ''}</span>
              <h3 style="font-size:1.05rem"><a href={p.amazonUrl} target="_blank" rel="sponsored nofollow noopener" data-buy-link="true" data-event="buy_click" data-buy-product={p.id}>{p.model}</a></h3>
              <p class="cexc">{p.summary}</p>
              <span class="cmeta" style="color:var(--accent)">{p.price ? `~$${p.price.toLocaleString()}` : ''}</span>
              <div class="commerce-actions"><a class="btn btn-primary" href={p.amazonUrl} target="_blank" rel="sponsored nofollow noopener" data-buy-link="true" data-event="buy_click" data-buy-product={p.id}>Exact product on Amazon</a><a class="btn" href={`/${p.bay}/gear/${p.id}`}>Specs</a></div>
            </div>
          </article>
        ))}
      </div>
    </section>

    <section class="cfg-cta">
      <div><span class="lbl lbl-accent">// Compare deeper</span><h4 style="margin-top:6px">See the full {bay.name.toLowerCase()} gear bench</h4><p>Open the product pages for specs, caveats, live review checks, and the honest buyer notes behind this ranking.</p></div>
      <a class="btn btn-primary btn-lg" href={`/${list.bay}/gear`}>Browse the gear ▸</a>
    </section>
  </div>
</Base>

<style>
  .commerce-card { display: flex; flex-direction: column; }
  .commerce-card h3 a { color: inherit; }
  .commerce-actions { display: flex; flex-wrap: wrap; gap: 8px; margin-top: 14px; }
  .commerce-actions .btn { padding: 9px 11px; font-size: .64rem; }
</style>
