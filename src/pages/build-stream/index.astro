---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';
import site from '../../data/site.json';
import bays from '../../data/bays.json';
import crew from '../../data/crew.json';
import editorialSurfaces from '../../data/editorial-surfaces.json';
import { articleMeta, articleSlug, isCertifiedArticle, sortNewestArticles } from '../../lib/content';
import { getArticleCardArt } from '../../lib/articleArt';
import { crewSlug, getCuratorByName, getCrewForBay } from '../../lib/crew';
import { getWorldForBay } from '../../lib/worlds';
import { clearsDiscoveryGate, evidenceLabels, qualityFor } from '../../lib/editorial';

const articles = sortNewestArticles(await getCollection('articles', ({ data }) => isCertifiedArticle(data)))
  .filter((entry) => clearsDiscoveryGate(entry.id));
const bayMap = new Map(bays.map((bay) => [bay.slug, bay]));
const actionMap = (editorialSurfaces as any).curatorActions as Record<string, any[]>;
const storyLabels = ['Product investigation', 'Build story', 'Failure clinic', 'Curator field test', 'Owner-pattern update'];
const storyFor = (entry: any, index: number) => entry.data.type === 'comparison' ? 'Product investigation'
  : entry.data.type === 'diy' ? 'Build story'
  : storyLabels[index % storyLabels.length];

const articleRows = articles.map((entry, index) => {
  const href = `/${entry.data.bay}/${articleSlug(entry)}`;
  const curator = getCuratorByName(entry.data.author) || getCrewForBay(entry.data.bay);
  const scenes = actionMap[crewSlug(curator)] || [];
  return {
    entry,
    href,
    art: getArticleCardArt(href),
    bay: bayMap.get(entry.data.bay),
    curator,
    scene: scenes[index % Math.max(scenes.length, 1)],
    story: storyFor(entry, index),
    quality: qualityFor(entry.id),
    evidence: evidenceLabels(entry.id),
    take: curator.hillsToDieOn?.[index % Math.max(curator.hillsToDieOn?.length || 0, 1)] || curator.favoriteWarning,
  };
});
const lead = articleRows[0];
const counts = [{ kind: 'all', label: 'Everything', n: articles.length }, ...bays.map((bay) => ({
  kind: bay.slug,
  label: bay.name,
  n: articles.filter((entry) => entry.data.bay === bay.slug).length,
}))].filter((item) => item.n > 0);

const description = 'IgnitionSim Sim Stream: an editor-selected information river of the strongest simulator buyer guides, build stories, failure clinics, real product proof, and curator field notes.';
const schema = [{
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: 'IgnitionSim Sim Stream',
  description,
  url: new URL('/build-stream', site.url).href,
  hasPart: articles.map((entry) => ({ '@type': 'Article', headline: entry.data.title, url: new URL(`/${entry.data.bay}/${articleSlug(entry)}`, site.url).href })),
}];
---
<Base title="Sim Stream: Simulator Build Guides & Gear River" description={description} image={getWorldForBay('racing').image} schema={schema} activeNav="stream">
  <header class="stream-hero">
    <img src={getWorldForBay('racing').image} alt={getWorldForBay('racing').alt} loading="eager" decoding="async" />
    <div class="stream-hero-shade"></div>
    <div class="wrap stream-hero-inner">
      <nav class="crumbs" aria-label="Breadcrumb"><a href="/">Home</a><span>/</span>Sim Stream</nav>
      <div class="stream-title">
        <span class="lbl lbl-accent">The simulator build information river</span>
        <h1>Sim Stream</h1>
        <p>Product investigations, owner-pattern warnings, failure clinics, and build stories. This is the edited river, not the archive dump.</p>
      </div>
      {lead && (
        <a class="stream-lead" href={lead.href}>
          <div class="stream-lead-image">{lead.art && <img src={lead.art.image} alt={lead.art.alt} loading="eager" decoding="async" />}<span>{lead.quality?.grade} · {lead.quality?.score}/100</span></div>
          <div><small>First on the bench · {lead.story}</small><h2>{lead.entry.data.title}</h2><p>{lead.entry.data.excerpt || lead.entry.data.description}</p></div>
        </a>
      )}
    </div>
  </header>

  <div class="stream-shell" data-stream>
    <div class="wrap stream-layout">
      <aside class="stream-sidebar">
        <div class="sidebar-block">
          <span class="lbl lbl-accent">Filter the river</span>
          <div class="stream-filters" role="tablist" aria-label="Filter Sim Stream">
            {counts.map((item) => <button class:list={['stream-filter', item.kind === 'all' && 'on']} type="button" data-bay-filter={item.kind}>{item.label}<b>{item.n}</b></button>)}
          </div>
        </div>
        <div class="sidebar-block crew-sidebar">
          <span class="lbl lbl-accent">Who is on shift</span>
          {(crew as any[]).map((person) => (
            <a href={`/curator/${crewSlug(person)}`}><img src={person.image} alt={person.alt} loading="lazy" decoding="async" /><span><b>{person.name}</b><small>{person.currentObsession}</small></span></a>
          ))}
        </div>
      </aside>

      <main class="stream-river" data-stream-list>
        {articleRows.map((row, index) => (
          <Fragment>
            <article class:list={['river-story', index % 2 === 1 && 'reverse', index >= 8 && 'is-hidden']} data-bay={row.entry.data.bay}>
              <a class="river-story-image" href={row.href}>
                {row.art && <img src={row.art.image} alt={row.art.alt} loading={index < 3 ? 'eager' : 'lazy'} decoding="async" />}
                <span>{row.story}</span>
              </a>
              <div class="river-story-copy">
                <div class="river-byline"><img src={row.curator.image} alt={row.curator.alt} loading="lazy" decoding="async" /><span>{row.curator.name} · {row.bay?.name}</span><b>{row.quality?.grade}</b></div>
                <h2><a href={row.href}>{row.entry.data.title}</a></h2>
                <p>{row.entry.data.excerpt || row.entry.data.description}</p>
                <blockquote class="river-take">&ldquo;{row.take}&rdquo;<span>{row.curator.name}</span></blockquote>
                <div class="river-proof">{row.evidence.map((label) => <span>{label}</span>)}</div>
                <small>{articleMeta(row.entry.data)}</small>
                <a class="river-open" href={row.href}>Open the investigation →</a>
              </div>
            </article>
            {(index + 1) % 3 === 0 && row.scene && (
              <aside class:list={['field-note', index >= 8 && 'is-hidden']} data-bay={row.entry.data.bay}>
                <div class="field-note-image"><img src={row.scene.image} alt={row.scene.alt} loading="lazy" decoding="async" /><span>AI editorial scene</span></div>
                <div><small>{row.curator.handle} · field note</small><h2>{row.scene.task}</h2><blockquote>“{row.curator.favoriteWarning}”</blockquote><p>{row.curator.benchMove}</p><a href={`/curator/${crewSlug(row.curator)}`}>Read {String(row.curator.name).split(' ')[0]}'s rig notes</a></div>
              </aside>
            )}
          </Fragment>
        ))}
        <p class="stream-empty" data-stream-empty hidden>No strong routes in that world yet.</p>
        <button class="stream-more" data-stream-more type="button"><span>Keep following the river</span><b>Load 8 more</b><small><span data-stream-shown>8</span> of <span data-stream-total>{articles.length}</span> guide rows visible</small></button>
      </main>
    </div>
  </div>
</Base>

<script>
  (() => {
    const root = document.querySelector('[data-stream]');
    if (!root) return;
    const filters = Array.from(root.querySelectorAll('[data-bay-filter]')) as HTMLButtonElement[];
    const rows = Array.from(root.querySelectorAll('.river-story')) as HTMLElement[];
    const notes = Array.from(root.querySelectorAll('.field-note')) as HTMLElement[];
    const more = root.querySelector('[data-stream-more]') as HTMLButtonElement | null;
    const empty = root.querySelector('[data-stream-empty]') as HTMLElement | null;
    const shown = root.querySelector('[data-stream-shown]');
    let active = 'all';
    let limit = 8;
    const render = () => {
      let visible = 0;
      let eligible = 0;
      rows.forEach((row) => {
        const matches = active === 'all' || row.dataset.bay === active;
        if (matches) eligible += 1;
        const show = matches && visible < limit;
        row.classList.toggle('is-hidden', !show);
        if (show) visible += 1;
      });
      notes.forEach((note) => {
        const matches = active === 'all' || note.dataset.bay === active;
        const preceding = Number(note.previousElementSibling?.classList.contains('river-story') && !(note.previousElementSibling as HTMLElement).classList.contains('is-hidden'));
        note.classList.toggle('is-hidden', !(matches && preceding));
      });
      if (shown) shown.textContent = String(visible);
      if (more) more.hidden = visible >= eligible;
      if (empty) empty.hidden = eligible !== 0;
    };
    filters.forEach((filter) => filter.addEventListener('click', () => {
      active = filter.dataset.bayFilter || 'all';
      limit = 8;
      filters.forEach((item) => item.classList.toggle('on', item === filter));
      render();
    }));
    more?.addEventListener('click', () => { limit += 8; render(); });
    render();
  })();
</script>

<style>
  .stream-hero { position:relative; min-height:610px; overflow:hidden; color:#fff; background:#101820; }
  .stream-hero > img { position:absolute; inset:0; width:100%; height:100%; object-fit:cover; filter:saturate(1.08) brightness(1.06); }
  .stream-hero-shade { position:absolute; inset:0; background:linear-gradient(90deg,rgba(8,15,22,.95),rgba(8,15,22,.55) 56%,rgba(8,15,22,.18)),linear-gradient(180deg,rgba(8,15,22,.1),rgba(8,15,22,.62)); }
  .stream-hero-inner { position:relative; z-index:1; min-height:610px; display:grid; grid-template-columns:minmax(0,.8fr) minmax(460px,1.2fr); gap:42px; align-items:end; padding-top:88px; padding-bottom:46px; }
  .stream-hero .crumbs { position:absolute; left:22px; top:30px; color:rgba(255,255,255,.7); }
  .stream-hero .crumbs a { color:inherit; }
  .stream-title h1 { margin:8px 0 12px; color:#fff; font-size:clamp(4rem,9vw,8.5rem); line-height:.82; text-transform:uppercase; }
  .stream-title p { max-width:52ch; color:rgba(255,255,255,.82); line-height:1.65; }
  .stream-lead { display:grid; grid-template-columns:46% 1fr; overflow:hidden; color:#101820; background:rgba(255,255,255,.96); border:2px solid rgba(255,255,255,.42); box-shadow:0 14px 0 rgba(8,15,22,.28); }
  .stream-lead-image { position:relative; min-height:330px; background:#101820; overflow:hidden; }
  .stream-lead-image img { width:100%; height:100%; object-fit:cover; display:block; }
  .stream-lead-image span { position:absolute; left:12px; top:12px; padding:7px 9px; background:#ff5e1a; border:1px solid #101820; font-family:var(--font-mono); font-size:.55rem; font-weight:900; }
  .stream-lead > div:last-child { padding:24px; align-self:center; }
  .stream-lead small { color:var(--accent); font-family:var(--font-mono); font-size:.56rem; font-weight:900; text-transform:uppercase; letter-spacing:.08em; }
  .stream-lead h2 { margin-top:10px; font-size:clamp(1.35rem,2.2vw,2rem); line-height:1.03; }
  .stream-lead p { margin-top:10px; color:#435363; font-size:.9rem; line-height:1.5; }

  .stream-shell { padding:60px 0 86px; overflow:hidden; background:linear-gradient(180deg,#eff5f8,#fff 42%); }
  .stream-layout { display:grid; grid-template-columns:270px minmax(0,1fr); gap:36px; align-items:start; }
  .stream-layout > * { min-width:0; }
  .stream-sidebar { position:sticky; top:90px; min-width:0; display:grid; gap:22px; }
  .sidebar-block { padding:20px; border-top:4px solid #101820; background:#fff; box-shadow:0 8px 0 rgba(16,24,32,.08); }
  .stream-filters { display:grid; gap:7px; margin-top:14px; }
  .stream-filter { display:flex; align-items:center; justify-content:space-between; width:100%; padding:10px 12px; border:1px solid rgba(16,24,32,.14); background:#f4f7f9; color:#263541; font-family:var(--font-mono); font-size:.62rem; font-weight:800; text-transform:uppercase; cursor:pointer; }
  .stream-filter b { color:var(--accent); }
  .stream-filter.on { color:#fff; background:#101820; border-color:#101820; }
  .crew-sidebar { display:grid; gap:11px; }
  .crew-sidebar > a { display:grid; grid-template-columns:46px 1fr; gap:10px; align-items:center; color:#101820; }
  .crew-sidebar img { width:46px; height:46px; object-fit:cover; object-position:center top; }
  .crew-sidebar b { display:block; font-size:.8rem; }
  .crew-sidebar small { display:-webkit-box; -webkit-line-clamp:2; -webkit-box-orient:vertical; overflow:hidden; color:#6a7782; font-size:.64rem; line-height:1.3; }

  .stream-river { min-width:0; display:grid; gap:28px; }
  .river-story { display:grid; grid-template-columns:43% 1fr; min-height:390px; overflow:hidden; background:#fff; border:2px solid rgba(16,24,32,.14); box-shadow:0 12px 0 rgba(16,24,32,.08); }
  .river-story.reverse { grid-template-columns:1fr 43%; }
  .river-story.reverse .river-story-image { order:2; }
  .river-story.reverse .river-story-copy { order:1; }
  .river-story-image { position:relative; overflow:hidden; min-height:390px; background:#101820; }
  .river-story-image img { width:100%; height:100%; object-fit:cover; display:block; transition:transform .55s ease; }
  .river-story:hover .river-story-image img { transform:scale(1.035); }
  .river-story-image > span { position:absolute; left:14px; bottom:14px; padding:7px 9px; color:#fff; background:rgba(16,24,32,.86); font-family:var(--font-mono); font-size:.54rem; font-weight:900; letter-spacing:.08em; text-transform:uppercase; }
  .river-story-copy { padding:30px; align-self:center; }
  .river-byline { display:grid; grid-template-columns:44px auto 1fr; gap:10px; align-items:center; color:var(--accent); font-family:var(--font-mono); font-size:.56rem; font-weight:900; letter-spacing:.07em; text-transform:uppercase; }
  .river-byline img { width:44px; height:44px; border-radius:50%; object-fit:cover; object-position:center top; border:2px solid var(--accent); }
  .river-byline b { justify-self:end; padding:5px 7px; color:#101820; background:#ff5e1a; border:1px solid #101820; }
  .river-story h2 { margin-top:14px; font-size:clamp(1.45rem,2.6vw,2.2rem); line-height:1.03; }
  .river-story h2 a { color:#101820; }
  .river-story-copy > p { margin-top:12px; color:#435363; line-height:1.6; }
  .river-take { margin-top:14px; padding:12px 14px; border-left:4px solid var(--accent); color:#263541; background:#f2f6f8; font-family:var(--font-disp); font-size:.94rem; line-height:1.42; }
  .river-take span { display:block; margin-top:7px; color:var(--accent); font-family:var(--font-mono); font-size:.5rem; font-weight:900; letter-spacing:.08em; text-transform:uppercase; }
  .river-proof { display:flex; flex-wrap:wrap; gap:7px; margin-top:15px; }
  .river-proof span { padding:6px 8px; border:1px solid rgba(16,24,32,.14); color:#536272; font-family:var(--font-mono); font-size:.5rem; text-transform:uppercase; letter-spacing:.06em; }
  .river-story-copy > small { display:block; margin-top:14px; color:#73808b; font-family:var(--font-mono); font-size:.55rem; text-transform:uppercase; }
  .river-open { display:inline-block; margin-top:16px; color:var(--accent); font-family:var(--font-mono); font-size:.62rem; font-weight:900; text-transform:uppercase; letter-spacing:.07em; }

  .field-note { display:grid; grid-template-columns:1.1fr .9fr; min-height:340px; overflow:hidden; color:#fff; background:#101820; border:2px solid #101820; box-shadow:0 12px 0 color-mix(in srgb,var(--accent) 28%,rgba(16,24,32,.15)); }
  .field-note-image { position:relative; min-height:340px; }
  .field-note-image img { position:absolute; inset:0; width:100%; height:100%; object-fit:cover; }
  .field-note-image span { position:absolute; left:12px; bottom:12px; padding:6px 8px; background:rgba(16,24,32,.82); font-family:var(--font-mono); font-size:.5rem; text-transform:uppercase; letter-spacing:.08em; }
  .field-note > div:last-child { padding:30px; align-self:center; }
  .field-note small, .field-note a { color:color-mix(in srgb,var(--accent) 68%,#fff); font-family:var(--font-mono); font-size:.56rem; font-weight:900; text-transform:uppercase; letter-spacing:.08em; }
  .field-note h2 { margin-top:10px; color:#fff; font-size:1.65rem; line-height:1.03; }
  .field-note blockquote { margin:16px 0 10px; color:#fff; font-family:var(--font-disp); font-size:1.15rem; line-height:1.3; }
  .field-note p { margin-bottom:16px; color:rgba(255,255,255,.7); line-height:1.5; }
  .is-hidden { display:none !important; }
  .stream-empty { padding:30px; text-align:center; color:#536272; }
  .stream-more { width:100%; display:grid; gap:5px; padding:22px; border:2px solid #101820; background:#ff5e1a; color:#101820; font-family:var(--font-mono); text-transform:uppercase; cursor:pointer; box-shadow:0 9px 0 rgba(16,24,32,.15); }
  .stream-more span { font-size:.56rem; letter-spacing:.12em; }
  .stream-more b { font-family:var(--font-disp); font-size:1.6rem; }
  .stream-more small { font-size:.54rem; }

  @media (max-width:1000px) {
    .stream-hero-inner { grid-template-columns:1fr; padding-top:100px; }
    .stream-lead { max-width:760px; }
    .stream-layout { grid-template-columns:1fr; }
    .stream-sidebar { position:static; grid-template-columns:1fr 1fr; }
  }
  @media (max-width:720px) {
    .stream-hero { min-height:860px; }
    .stream-hero-inner { min-height:860px; }
    .stream-title h1 { font-size:clamp(4.8rem,23vw,7rem); }
    .stream-lead { grid-template-columns:1fr; }
    .stream-lead-image { min-height:220px; }
    .stream-sidebar { grid-template-columns:minmax(0,1fr); }
    .crew-sidebar { display:none; }
    .stream-filters { display:flex; overflow-x:auto; }
    .stream-filter { width:auto; min-width:max-content; gap:14px; }
    .river-story, .river-story.reverse { grid-template-columns:1fr; min-height:0; }
    .river-story.reverse .river-story-image, .river-story.reverse .river-story-copy { order:initial; }
    .river-story-image { min-height:230px; }
    .river-story-copy { padding:22px; }
    .field-note { grid-template-columns:1fr; }
    .field-note-image { min-height:250px; }
  }
</style>
