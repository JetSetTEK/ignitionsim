---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';
import site from '../../data/site.json';
import bays from '../../data/bays.json';
import games from '../../data/games.json';
import crew from '../../data/crew.json';
import { articleMeta, articleSlug, isCertifiedArticle, sortNewestArticles } from '../../lib/content';
import { getArticleCardArt } from '../../lib/articleArt';
import { getWorldForBay } from '../../lib/worlds';

const articles = sortNewestArticles(await getCollection('articles', ({ data }) => isCertifiedArticle(data)));
const bayMap = new Map(bays.map((b) => [b.slug, b]));
const crewByBay: Record<string, any> = {
  racing: (crew as any[]).find((p) => p.name === 'Duke Alvarez'),
  golf: (crew as any[]).find((p) => p.name === 'Nina Brooks'),
  flight: (crew as any[]).find((p) => p.name === 'Val Chen'),
  space: (crew as any[]).find((p) => p.name === 'Val Chen'),
  marine: (crew as any[]).find((p) => p.name === 'Gus Calder'),
};
const crewSlug = (person: any) => person.slug || String(person.name || '').toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/^-|-$/g, '');
const gameRoutes = new Map<string, any[]>();
for (const game of games as any[]) {
  for (const id of game.guideIds || []) {
    const list = gameRoutes.get(id) || [];
    list.push(game);
    gameRoutes.set(id, list);
  }
}

const KIND_LABEL: Record<string, string> = {
  all: 'Everything',
  'buying-guide': 'Buyer maps',
  comparison: 'Comparisons',
  'ecosystem-upgrade-path': 'Upgrade paths',
  'gear-explainer': 'Gear explainers',
  howto: 'How-to',
  diy: 'DIY',
};
const counts = [{ kind: 'all', n: articles.length }, ...Object.entries(articles.reduce((acc: Record<string, number>, a) => {
  acc[a.data.type] = (acc[a.data.type] || 0) + 1;
  return acc;
}, {})).map(([kind, n]) => ({ kind, n }))];

const chimeLines: Record<string, string[]> = {
  racing: [
    'If the brake deck flexes, the lap time lies. Fix the foundation before buying more torque.',
    'The part that feels boring in the cart is usually the part that makes the rig feel expensive.',
  ],
  golf: [
    'Measure ceiling, width, and depth before falling in love with a launch monitor. The room gets veto power.',
    'A good mat saves joints. A cheap mat saves money once and annoys you every session after.',
  ],
  flight: [
    'Panels are dessert. Throttle, rudders, head tracking, and clean USB power are dinner.',
    'If the cable run looks temporary, it will become your most permanent problem.',
  ],
  space: [
    'HOSAS is not a personality test. Buy for what you fly, then bind it like you expect stress.',
    'Mounts are not optional jewelry. They are what turn nice sticks into a cockpit.',
  ],
  marine: [
    'Marine sim hardware is a scavenger hunt. The winners label everything and save their profiles.',
    'If the sim will not expose an axis, no amount of premium hardware can negotiate with it.',
  ],
};

type Row = { row: 'article'; index: number; entry: any; href: string; art: any; bay: any; games: any[]; curator: any } |
  { row: 'chime'; index: number; baySlug: string; curator: any; text: string };
const rows: Row[] = [];
articles.forEach((entry, index) => {
  const href = `/${entry.data.bay}/${articleSlug(entry)}`;
  const curator = crewByBay[entry.data.bay] || (crew as any[])[0];
  rows.push({
    row: 'article',
    index,
    entry,
    href,
    art: getArticleCardArt(href),
    bay: bayMap.get(entry.data.bay),
    games: gameRoutes.get(entry.id) || [],
    curator,
  });
  if ((index + 1) % 4 === 0 && index < articles.length - 1) {
    const baySlug = entry.data.bay;
    const lines = chimeLines[baySlug] || chimeLines.racing;
    rows.push({
      row: 'chime',
      index,
      baySlug,
      curator,
      text: lines[Math.floor(index / 4) % lines.length],
    });
  }
});

const topRoutes = articles.slice(0, 5).map((entry) => {
  const href = `/${entry.data.bay}/${articleSlug(entry)}`;
  return { entry, href, art: getArticleCardArt(href), bay: bayMap.get(entry.data.bay) };
});

const description = 'IgnitionSim Simulator Build Stream: a newest-first information river of certified simulator buyer guides, comparisons, product photos, build warnings, and game-specific hardware routes.';
const schema = [{
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: 'Simulator Build Stream',
  description,
  url: new URL('/build-stream', site.url).href,
  hasPart: articles.map((a) => ({
    '@type': 'Article',
    headline: a.data.title,
    url: new URL(`/${a.data.bay}/${articleSlug(a)}`, site.url).href,
  })),
}];
---
<Base title="Sim Stream: Simulator Build Guides & Gear River" description={description} image="/images/worlds/racing-world.webp" schema={schema} activeNav="stream">
  <div class="sim-stream" data-stream>
    <div class="stream-wrap">
      <nav class="crumbs" aria-label="Breadcrumb"><a href="/">Home</a><span>/</span>Sim Stream</nav>
      <header class="stream-head">
        <p class="lbl lbl-accent"><span class="live-dot" aria-hidden="true"></span> Certified-only information river</p>
        <h1>Sim Stream</h1>
        <p>Newest-first buyer maps, game routes, product-proof cards, and curator warnings. If a guide does not have enough real visual proof to help a builder buy faster, it does not get a public row.</p>
      </header>

      <div class="stream-grid">
        <aside class="stream-rail left">
          <div class="rail-card curator-rail">
            <h2>Bench crew</h2>
            {(crew as any[]).map((person) => (
              <a href={`/curator/${crewSlug(person)}`}>
                <img src={person.image} alt={person.alt} loading="lazy" decoding="async" />
                <span><b>{person.name}</b><small>{person.handle}</small></span>
              </a>
            ))}
          </div>
          <div class="rail-card">
            <h2>Build worlds</h2>
            {bays.map((bay) => (
              <a class="rail-link" href={`/${bay.slug}`}><span>{bay.name}</span><em>{bay.descriptor}</em></a>
            ))}
          </div>
        </aside>

        <main class="stream-center">
          <div class="stream-filters" role="tablist" aria-label="Filter Sim Stream">
            {counts.map((c) => <button class={`stream-chip${c.kind === 'all' ? ' on' : ''}`} data-kind={c.kind}>{KIND_LABEL[c.kind] || c.kind.replace(/-/g, ' ')} <b>{c.n}</b></button>)}
          </div>

          <div class="stream-river" data-stream-list>
            {rows.map((row) => (
              row.row === 'article' ? (
                <a class={`river-card${row.index >= 10 ? ' is-hidden' : ''}`} data-kind={row.entry.data.type} data-bay={row.entry.data.bay} href={row.href}>
                  <div class:list={['river-art', row.art?.wide && 'is-wide-art']}>
                    {row.art && <img src={row.art.image} alt={row.art.alt} loading={row.index < 4 ? 'eager' : 'lazy'} decoding="async" />}
                    {row.art && <span>{row.art.label}</span>}
                  </div>
                  <div class="river-body">
                    <div class="river-kicker">
                      <img src={row.curator.image} alt={row.curator.alt} loading="lazy" decoding="async" />
                      <span>{row.bay?.name || row.entry.data.bay} · {row.entry.data.type.replace(/-/g, ' ')}</span>
                    </div>
                    <h2>{row.entry.data.title}</h2>
                    <p>{row.entry.data.excerpt || row.entry.data.description}</p>
                    <small>{row.games.length ? `${row.games.map((g) => g.name).join(' · ')} · ` : ''}{articleMeta(row.entry.data)}</small>
                  </div>
                </a>
              ) : (
                <aside class={`river-chime${row.index >= 10 ? ' is-hidden' : ''}`} data-before={row.index} data-bay={row.baySlug}>
                  <img src={row.curator.image} alt={row.curator.alt} loading="lazy" decoding="async" />
                  <div>
                    <span>{row.curator.name} · bench note</span>
                    <blockquote>{row.text}</blockquote>
                  </div>
                </aside>
              )
            ))}
          </div>

          <p class="stream-empty" data-stream-empty hidden>No rows in that filter yet.</p>
          <div class="stream-more-wrap" data-stream-more-wrap>
            <button class="stream-more" data-stream-more type="button">
              <span>the river keeps going</span>
              <b>Load 10 more</b>
              <small><span data-stream-shown>10</span> of <span data-stream-total>{articles.length}</span> visible</small>
            </button>
          </div>
        </main>

        <aside class="stream-rail right">
          <div class="rail-card top-routes">
            <h2>Top routes now</h2>
            {topRoutes.map((item, i) => (
              <a href={item.href}>
                <span>{String(i + 1).padStart(2, '0')}</span>
                {item.art && <img class:list={[item.art.wide && 'is-wide-art']} src={item.art.image} alt="" loading="lazy" decoding="async" />}
                <b>{item.entry.data.title}</b>
              </a>
            ))}
          </div>
          <div class="rail-card newsletter-card">
            <h2>Workbench Drop</h2>
            <p>Product moves, forum wisdom, weekend-killer warnings, and the occasional blunt “wait for version two.”</p>
            <a class="btn btn-primary" href="/#newsletter">Join the bench list</a>
          </div>
        </aside>
      </div>
    </div>
  </div>
</Base>

<style>
  .sim-stream {
    width: 100vw;
    margin-left: calc(50% - 50vw);
    padding: 22px 0 72px;
    background:
      radial-gradient(760px 360px at 6% 4%, rgba(255,94,26,.12), transparent 72%),
      radial-gradient(880px 420px at 96% 8%, rgba(56,189,248,.12), transparent 70%),
      linear-gradient(180deg, #f7fbff, #edf3f7);
  }
  .stream-wrap {
    max-width: 1320px;
    margin: 0 auto;
    padding: 0 28px;
  }
  .stream-head {
    max-width: 920px;
    margin: 18px 0 26px;
  }
  .stream-head .lbl { display: inline-flex; align-items: center; gap: 8px; }
  .live-dot {
    width: 9px;
    height: 9px;
    border-radius: 50%;
    background: var(--accent);
    box-shadow: 0 0 0 7px color-mix(in srgb, var(--accent) 16%, transparent);
  }
  .stream-head h1 {
    margin: 8px 0 10px;
    font-size: clamp(3.2rem, 8vw, 7.6rem);
    line-height: .84;
    text-transform: uppercase;
  }
  .stream-head p:last-child {
    max-width: 76ch;
    color: #435363;
    font-size: clamp(1rem, 1.7vw, 1.18rem);
  }
  .stream-grid {
    display: grid;
    grid-template-columns: 230px minmax(0, 1fr) 310px;
    gap: 26px;
    align-items: start;
  }
  .stream-rail {
    display: flex;
    flex-direction: column;
    gap: 18px;
    position: sticky;
    top: 88px;
  }
  .rail-card {
    padding: 16px;
    border: 2px solid rgba(16,24,32,.13);
    border-radius: 18px;
    background: rgba(255,255,255,.9);
    box-shadow: 0 8px 0 rgba(16,24,32,.08), 0 24px 52px rgba(16,24,32,.1);
  }
  .rail-card h2 {
    margin: 0 0 12px;
    font-size: 1.05rem;
    text-transform: uppercase;
  }
  .curator-rail a,
  .rail-link {
    display: flex;
    gap: 10px;
    align-items: center;
    padding: 9px 0;
    color: #101820;
    border-top: 1px solid rgba(16,24,32,.08);
  }
  .curator-rail img {
    width: 44px;
    height: 44px;
    border-radius: 50%;
    object-fit: cover;
    object-position: center top;
    border: 2px solid var(--accent);
  }
  .curator-rail b,
  .rail-link span {
    display: block;
    font-size: .9rem;
    line-height: 1.1;
  }
  .curator-rail small,
  .rail-link em {
    display: block;
    color: #71808c;
    font-family: var(--font-mono);
    font-size: .62rem;
    font-style: normal;
    letter-spacing: .04em;
  }
  .stream-filters {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-bottom: 18px;
  }
  .stream-chip {
    border: 2px solid rgba(16,24,32,.14);
    border-radius: 999px;
    background: #fff;
    color: #334155;
    padding: 8px 13px;
    font-family: var(--font-mono);
    font-size: .7rem;
    font-weight: 900;
    letter-spacing: .06em;
    text-transform: uppercase;
    cursor: pointer;
  }
  .stream-chip.on {
    border-color: #101820;
    background: #101820;
    color: #fff;
  }
  .stream-river {
    display: flex;
    flex-direction: column;
    gap: 18px;
  }
  .river-card {
    display: grid;
    grid-template-rows: auto 1fr;
    min-height: 0;
    overflow: hidden;
    border: 2px solid rgba(16,24,32,.14);
    border-radius: 22px;
    background: #fff;
    color: #101820;
    box-shadow: 0 10px 0 rgba(16,24,32,.09), 0 28px 60px rgba(16,24,32,.1);
  }
  .river-card.is-hidden,
  .river-chime.is-hidden { display: none; }
  .river-card:hover {
    transform: translateY(-4px);
    border-color: #101820;
  }
  .river-art {
    position: relative;
    display: grid;
    place-items: center;
    aspect-ratio: 16 / 9;
    padding: 24px;
    background:
      radial-gradient(420px 240px at 50% 100%, color-mix(in srgb, var(--accent) 14%, transparent), transparent 72%),
      linear-gradient(135deg, #fff, #eef4f8);
    border-right: 0;
    border-bottom: 2px solid rgba(16,24,32,.1);
  }
  .river-art img {
    width: 100%;
    height: min(235px, 82%);
    object-fit: contain;
    filter: drop-shadow(0 22px 30px rgba(16,24,32,.22));
    transition: transform .45s ease;
  }
  .river-art.is-wide-art {
    padding: 0;
    background: #101820;
  }
  .river-art.is-wide-art img {
    width: 100%;
    height: 100%;
    min-height: 0;
    object-fit: cover;
    filter: none;
  }
  .river-card:hover .river-art.is-wide-art img { transform: scale(1.025); }
  .river-card:hover .river-art img { transform: scale(1.045); }
  .river-art span {
    position: absolute;
    left: 16px;
    top: 16px;
    padding: 7px 9px;
    border: 1px solid #101820;
    border-radius: 8px;
    background: #ff5e1a;
    color: #101820;
    font-family: var(--font-mono);
    font-size: .52rem;
    font-weight: 900;
    letter-spacing: .12em;
    text-transform: uppercase;
  }
  .river-body {
    display: flex;
    flex-direction: column;
    justify-content: flex-start;
    padding: clamp(22px, 3vw, 34px);
  }
  .river-kicker {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 12px;
  }
  .river-kicker img {
    width: 42px;
    height: 42px;
    border-radius: 50%;
    object-fit: cover;
    object-position: center top;
    border: 2px solid var(--accent);
  }
  .river-kicker span,
  .river-body small,
  .river-chime span {
    color: var(--accent);
    font-family: var(--font-mono);
    font-size: .62rem;
    font-weight: 900;
    letter-spacing: .1em;
    text-transform: uppercase;
  }
  .river-body h2 {
    font-size: clamp(1.6rem, 3vw, 2.7rem);
    line-height: .96;
    text-transform: uppercase;
  }
  .river-body p {
    margin-top: 13px;
    color: #435363;
    font-size: 1rem;
    line-height: 1.58;
  }
  .river-body small { display: block; margin-top: 16px; }
  .river-chime {
    display: grid;
    grid-template-columns: 132px 1fr;
    overflow: hidden;
    border: 2px solid color-mix(in srgb, var(--accent) 36%, rgba(16,24,32,.12));
    border-radius: 20px;
    background:
      radial-gradient(480px 220px at 100% 0%, color-mix(in srgb, var(--accent) 16%, transparent), transparent 72%),
      #101820;
    color: #fff;
    box-shadow: 0 9px 0 rgba(16,24,32,.14), 0 26px 54px rgba(16,24,32,.13);
  }
  .river-chime img {
    width: 100%;
    height: 100%;
    min-height: 150px;
    object-fit: cover;
    object-position: center top;
  }
  .river-chime div {
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 20px 24px;
  }
  .river-chime blockquote {
    margin: 8px 0 0;
    color: #f8fafc;
    font-size: clamp(1.1rem, 2vw, 1.45rem);
    line-height: 1.35;
    font-weight: 800;
  }
  .stream-empty {
    padding: 20px;
    text-align: center;
    color: #71808c;
  }
  .stream-more-wrap {
    text-align: center;
    margin: 30px 0 0;
  }
  .stream-more {
    width: min(100%, 520px);
    min-height: 104px;
    border: 2px solid #101820;
    border-radius: 14px;
    background:
      linear-gradient(135deg, #101820, #233140);
    color: #fff;
    cursor: pointer;
    box-shadow: 0 10px 0 rgba(16,24,32,.16), 0 28px 60px rgba(16,24,32,.16);
  }
  .stream-more span,
  .stream-more small {
    display: block;
    font-family: var(--font-mono);
    font-size: .66rem;
    letter-spacing: .12em;
    text-transform: uppercase;
    color: color-mix(in srgb, var(--accent) 70%, #fff);
  }
  .stream-more b {
    display: block;
    margin: 5px 0;
    font-family: var(--font-disp);
    font-size: 1.55rem;
  }
  .stream-more[hidden],
  .stream-more-wrap[hidden] { display: none; }
  .top-routes a {
    display: grid;
    grid-template-columns: 24px 64px 1fr;
    gap: 10px;
    align-items: center;
    padding: 10px 0;
    border-top: 1px solid rgba(16,24,32,.08);
    color: #101820;
  }
  .top-routes span {
    color: var(--accent);
    font-family: var(--font-mono);
    font-weight: 900;
  }
  .top-routes img {
    width: 64px;
    height: 48px;
    object-fit: contain;
    background: #fff;
    border: 1px solid rgba(16,24,32,.08);
    border-radius: 8px;
  }
  .top-routes img.is-wide-art {
    object-fit: cover;
  }
  .top-routes b {
    font-size: .84rem;
    line-height: 1.25;
  }
  .newsletter-card p {
    color: #435363;
    margin-bottom: 14px;
  }
  @media (max-width: 1120px) {
    .stream-grid { grid-template-columns: minmax(0, 1fr) 300px; }
    .stream-rail.left { display: none; }
  }
  @media (max-width: 820px) {
    .stream-grid { grid-template-columns: 1fr; }
    .stream-rail { position: static; }
    .river-art { border-right: 0; border-bottom: 2px solid rgba(16,24,32,.1); }
    .river-chime { grid-template-columns: 96px 1fr; }
  }
  @media (max-width: 560px) {
    .stream-wrap { padding: 0 16px; }
    .stream-head h1 { font-size: clamp(3rem, 18vw, 4.8rem); }
    .river-art img { height: min(200px, 82%); }
    .river-art.is-wide-art img { height: 100%; min-height: 0; }
    .river-body { padding: 18px; }
    .river-body h2 { font-size: 1.38rem; }
    .river-body p {
      display: -webkit-box;
      -webkit-line-clamp: 2;
      -webkit-box-orient: vertical;
      overflow: hidden;
    }
    .river-chime { grid-template-columns: 1fr; }
    .river-chime img { height: 220px; }
  }
</style>

<script is:inline>
  (() => {
    const root = document.querySelector('[data-stream]');
    if (!root) return;
    const cards = Array.from(root.querySelectorAll('.river-card'));
    const chimes = Array.from(root.querySelectorAll('.river-chime'));
    const chips = Array.from(root.querySelectorAll('.stream-chip'));
    const more = root.querySelector('[data-stream-more]');
    const moreWrap = root.querySelector('[data-stream-more-wrap]');
    const shownNode = root.querySelector('[data-stream-shown]');
    const totalNode = root.querySelector('[data-stream-total]');
    const empty = root.querySelector('[data-stream-empty]');
    const STEP = 10;
    let kind = 'all';
    let limit = STEP;
    const matches = (el) => kind === 'all' || el.dataset.kind === kind;
    const render = () => {
      const filtered = cards.filter(matches);
      const visible = new Set(filtered.slice(0, limit));
      cards.forEach((el) => el.classList.toggle('is-hidden', !visible.has(el)));
      const shown = Math.min(limit, filtered.length);
      chimes.forEach((el) => el.classList.toggle('is-hidden', !(kind === 'all' && (+el.dataset.before || 0) < shown)));
      if (more) more.hidden = limit >= filtered.length;
      if (moreWrap) moreWrap.hidden = limit >= filtered.length;
      if (shownNode) shownNode.textContent = String(shown);
      if (totalNode) totalNode.textContent = String(filtered.length);
      if (empty) empty.hidden = filtered.length !== 0;
    };
    chips.forEach((chip) => chip.addEventListener('click', () => {
      chips.forEach((c) => c.classList.remove('on'));
      chip.classList.add('on');
      kind = chip.dataset.kind || 'all';
      limit = STEP;
      render();
    }));
    more?.addEventListener('click', () => {
      limit += STEP;
      render();
    });
    render();
  })();
</script>
