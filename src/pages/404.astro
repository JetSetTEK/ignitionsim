---
import Base from '../layouts/Base.astro';
---
<Base title="404 — Off the rig" description="That part isn't in the rig." noindex={true}>
  <div class="wrap">
    <section class="hero" style="padding:90px 0">
      <div class="lbl lbl-accent">// 404</div>
      <h1 style="font-size:clamp(2.4rem,6vw,4rem);margin:16px 0">Looks like that part<br>isn't in the rig.</h1>
      <p>Let's get you back to the build.</p>
      <div class="cta-row">
        <a class="btn btn-primary btn-lg" href="/">Back to home</a>
        <a class="btn btn-lg" href="/guides">Open the guides</a>
      </div>
    </section>
  </div>
</Base>
