---
import Base from '../../layouts/Base.astro';
import PanoSlider from '../../components/PanoSlider.astro';
import ArticleCard from '../../components/ArticleCard.astro';
import GearCarousel from '../../components/GearCarousel.astro';
import FAQ from '../../components/FAQ.astro';
import { getCollection } from 'astro:content';
import bays from '../../data/bays.json';
import site from '../../data/site.json';
import community from '../../data/community.json';
import stats from '../../data/stat-lists.json';
import signals from '../../data/research-signals.json';
import photography from '../../data/photography.json';
import { isCertifiedArticle, sortNewestArticles } from '../../lib/content';
const sentColor: Record<string, string> = { consensus: 'var(--cyan)', debate: 'var(--amber)', warning: 'var(--red)', tip: 'var(--green)' };
const commItems = ((community as any)[Astro.props.bay.slug] || []) as any[];
const bayStats = (stats as any[]).filter((s) => s.bay === Astro.props.bay.slug).slice(0, 4);

export async function getStaticPaths() {
  return bays.map((b) => ({ params: { bay: b.slug }, props: { bay: b } }));
}
const { bay } = Astro.props;
const baySignal = ((signals as any)[bay.slug] || {}) as any;

const articles = sortNewestArticles(await getCollection('articles', ({ data }) => data.bay === bay.slug && isCertifiedArticle(data)));
const slug = (a: any) => a.id.split('/').pop();
const starterGuideByBay: Record<string, string> = {
  racing: 'sim-rig-buyer-map-2026',
  flight: 'msfs-home-cockpit-buyer-map-2026',
  space: 'star-citizen-hosas-buyer-map-2026',
  golf: 'home-golf-simulator-build-sheet-2026',
  marine: 'marine-sim-hardware-reality',
};
const starterGuideSlug = starterGuideByBay[bay.slug] || (articles[0] ? slug(articles[0]) : '');
const starterGuideHref = starterGuideSlug ? `/${bay.slug}/${starterGuideSlug}` : `/${bay.slug}/gear`;

const typeOrder = ['buying-guide', 'comparison', 'ecosystem-upgrade-path', 'how-to', 'gear-explainer', 'diy'];
const typeLabel: Record<string, string> = {
  'buying-guide': 'Buying guides', 'comparison': 'Head-to-head comparisons',
  'ecosystem-upgrade-path': 'Upgrade paths', 'how-to': 'How-to guides',
  'gear-explainer': 'Gear, explained', 'diy': 'DIY & builds',
};
const byType = typeOrder
  .map((t) => ({ t, items: articles.filter((a) => a.data.type === t) }))
  .filter((g) => g.items.length);

// top gear for the carousel — all products in this bay, best-rated first
const amazonTag = (site as any).affiliate?.amazonTag;
const prodMods = import.meta.glob('/src/data/products/*.json', { eager: true });
const allProducts = Object.values(prodMods).flatMap((m: any) => (m.default || m)) as any[];
const buyUrl = (p: any) => p.amazonAsin
  ? `https://www.amazon.com/dp/${p.amazonAsin}/?tag=${amazonTag}`
  : `https://www.amazon.com/s?k=${encodeURIComponent(p.brand + ' ' + p.model)}${amazonTag ? `&tag=${amazonTag}` : ''}`;
const gearItems = allProducts
  .filter((p) => p.bay === bay.slug)
  .sort((a, b) => (b.rating?.overall || 0) - (a.rating?.overall || 0))
  .slice(0, 12)
  .map((p, i) => ({
    href: `/${bay.slug}/gear/${p.id}`,
    image: p.image || `/images/gear/${bay.slug}/${p.id}.jpg`,
    brand: p.brand, model: p.model, price: p.price, type: p.type,
    buyUrl: buyUrl(p),
    tag: i === 0 ? 'Top rated' : undefined,
  }));

const photoList = ((photography as any)[bay.slug] || []) as any[];
const realPhotos = photoList
  .filter((p: any) => p?.src)
  .sort((a: any, b: any) => (a.source === 'Pexels' ? -1 : 0) - (b.source === 'Pexels' ? -1 : 0))
  .slice(0, 3);
const slides: any[] = realPhotos.length
  ? realPhotos.map((p: any) => ({ src: p.src, alt: p.alt || `${bay.name} sim hardware`, credit: { by: p.by, byUrl: p.byUrl, photoUrl: p.photoUrl, source: p.source } }))
  : [1, 2, 3].map((n) => ({ src: `/images/${bay.slug}/slide-${n}.jpg`, alt: `${bay.name} sim hardware product bench ${n}` }));
slides[0] = { ...slides[0], eyebrow: `// ${bay.name} bay`, title: bay.tagline, caption: bay.descriptor };

const crumbName = `${bay.name} sim hardware`;
const schema = [
  {
    '@context': 'https://schema.org', '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: site.url },
      { '@type': 'ListItem', position: 2, name: crumbName, item: new URL(`/${bay.slug}`, site.url).href },
    ],
  },
  {
    '@context': 'https://schema.org', '@type': 'CollectionPage',
    name: crumbName, description: bay.intro, url: new URL(`/${bay.slug}`, site.url).href,
    isPartOf: { '@type': 'WebSite', name: site.name, url: site.url },
  },
];
---
<Base title={crumbName} description={bay.intro} bay={bay.slug} activeNav={bay.slug} schema={schema}
      image={`/images/${bay.slug}/hero.jpg`}>
  <div class="wrap">
    <div class="crumbs"><a href="/">Home</a><span>/</span>{bay.name}</div>

    <section style="margin-top:8px">
      <PanoSlider slides={slides} height="480px" id={`${bay.slug}-hero`} />
    </section>

    <section class="sec" style="padding-top:26px">
      <div class="accent-bar" style="height:4px;width:64px;background:var(--accent);border-radius:4px;box-shadow:0 0 18px var(--bayglow);margin-bottom:16px"></div>
      <h1 style="font-size:clamp(2rem,5vw,3rem);max-width:20ch">{bay.tagline}</h1>
      <p style="color:var(--dim);max-width:65ch;margin-top:14px;font-size:1.08rem">{bay.intro}</p>
      <p class="byline" style="margin-top:14px">Researched &amp; reviewed by <b>{site.author.name}</b> · {bay.theme} theme</p>
    </section>

    <section class="bay-reality">
      <div class="bay-real-main">
        <span class="lbl lbl-accent">// {bay.name} buying truth</span>
        <h2>{baySignal.buyFast}</h2>
      </div>
      <div class="bay-real-card"><span>Watch out</span><p>{baySignal.watchOut}</p></div>
      <div class="bay-real-card"><span>Weekend killer</span><p>{baySignal.weekendKiller}</p></div>
      <div class="bay-real-card"><span>Source shelf</span>
        <p>
          {(baySignal.officialSources || []).slice(0, 2).map((s: any, i: number) => (
            <><a href={s.url} target="_blank" rel="noopener nofollow">{s.label}</a>{i === 0 ? ' · ' : ''}</>
          ))}
        </p>
      </div>
    </section>

    <section class="cfg-cta">
      <div>
        <span class="lbl lbl-accent">// Start here</span>
        <h4 style="margin-top:6px">Read the {bay.name} buyer map first</h4>
        <p>Start with the practical path: what to buy first, what to avoid, what quietly adds setup work, and which products deserve a closer look.</p>
      </div>
      <a class="btn btn-primary btn-lg" href={starterGuideHref}>Open the buyer map ▸</a>
    </section>

    <section class="band" style="margin:10px 0 0">
      <div>
        <span class="lbl lbl-accent">// Gear database</span>
        <h3>Every {bay.name.toLowerCase()} product, decoded</h3>
        <p>Deep spec breakdowns, honest ratings, and pros &amp; cons for the gear in this bay — with a plain-English verdict on each.</p>
      </div>
      <a class="btn btn-primary btn-lg" href={`/${bay.slug}/gear`}>Browse {bay.name} gear ▸</a>
    </section>

    {gearItems.length > 0 && (
      <section class="sec" style="padding-top:8px">
        <div class="sec-head"><h2>Gear spotlight</h2><a class="lbl" href={`/${bay.slug}/gear`}>all {gearItems.length >= 12 ? '' : gearItems.length + ' '}{bay.name.toLowerCase()} gear →</a></div>
        <GearCarousel items={gearItems} id={`${bay.slug}-gear-rail`} />
      </section>
    )}

    {articles.length === 0 ? (
      <section class="sec"><p style="color:var(--dim)">Fresh {bay.name.toLowerCase()} guides are being written and will appear here shortly.</p></section>
    ) : (
      byType.map((g) => (
        <section class="sec">
          <div class="sec-head"><h2>{typeLabel[g.t]}</h2><span class="lbl">{g.items.length} guide{g.items.length > 1 ? 's' : ''}</span></div>
          <div class="card-grid">
            {g.items.map((a) => (
              <ArticleCard href={`/${bay.slug}/${slug(a)}`} title={a.data.title}
                excerpt={a.data.excerpt || a.data.description} type={a.data.type}
                image={a.data.heroImage} imageAlt={a.data.heroAlt}
                meta={`${a.data.readingTime || 6} min read`} />
            ))}
          </div>
        </section>
      ))
    )}

    {commItems.length > 0 && (
      <section class="sec">
        <div class="sec-head"><h2>What the {bay.name.toLowerCase()} community says</h2><span class="lbl">our read on the consensus · paraphrased, not quoted</span></div>
        <div class="comm-grid">
          {commItems.map((c) => (
            <div class="comm-card">
              <span class="comm-sent" style={`color:${sentColor[c.sentiment] || 'var(--accent)'};border-color:${sentColor[c.sentiment] || 'var(--accent)'}`}>{c.sentiment}</span>
              <p class="comm-point">{c.point}</p>
              <span class="comm-ctx">{c.context}</span>
            </div>
          ))}
        </div>
      </section>
    )}

    {bayStats.length > 0 && (
      <section class="sec" style="padding-top:0">
        <div class="sec-head"><h2>{bay.name} rankings</h2><a class="lbl" href="/best">all best-of lists →</a></div>
        <div class="card-grid">
          {bayStats.map((l) => (
            <a class="card" href={`/best/${l.slug}`} style="min-height:0"><div class="cbody"><span class="ctype">{bay.name} · ranking</span><h3 style="font-size:1.05rem">{l.title}</h3><p class="cexc">{l.intro}</p></div></a>
          ))}
        </div>
      </section>
    )}

    <section class="band">
      <div>
        <span class="lbl lbl-accent">// {bay.name} build notes</span>
        <h3>Keep the {bay.name.toLowerCase()} bench honest</h3>
        <p>{site.newsletter.blurb} Pick {bay.name} and we'll keep the signal practical: what to buy, what to skip, and what deserves another look.</p>
      </div>
      <form onsubmit="event.preventDefault(); window.toast && window.toast('beehiiv signup wires in at launch'); this.reset();">
        <input type="email" placeholder="pilot@callsign.gg" aria-label="Email address" required />
        <button class="btn btn-primary" type="submit">Join the bench list</button>
      </form>
    </section>
  </div>
</Base>

<style>
  .comm-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 14px; }
  .comm-card { border: 1px solid var(--line2); border-left: 3px solid var(--accent); border-radius: 12px; padding: 16px 18px; background: var(--panel); }
  .comm-sent { display: inline-block; font-family: var(--font-mono); font-size: .56rem; letter-spacing: .14em; text-transform: uppercase; border: 1px solid; border-radius: 20px; padding: 3px 9px; }
  .comm-point { color: #334155; font-size: .95rem; margin: 10px 0 8px; line-height: 1.55; }
  .comm-ctx { font-family: var(--font-mono); font-size: .64rem; color: var(--dimmer); letter-spacing: .03em; }
  .bay-reality { display: grid; grid-template-columns: 1.3fr repeat(3, 1fr); gap: 12px; margin: 8px 0 26px; }
  .bay-real-main, .bay-real-card { border: 1px solid var(--line2); border-radius: 14px; padding: 18px 20px; background: #fff; box-shadow: 0 12px 30px rgba(15,23,42,.06); }
  .bay-real-main h2 { font-size: 1.18rem; line-height: 1.35; margin-top: 8px; }
  .bay-real-card { border-left: 4px solid var(--accent); }
  .bay-real-card span { display:block; font-family:var(--font-mono); font-size:.58rem; letter-spacing:.12em; text-transform:uppercase; color:var(--accent); margin-bottom:8px; }
  .bay-real-card p { color:#475569; font-size:.86rem; line-height:1.55; }
  .bay-real-card a { color: var(--accent); }
  @media (max-width: 980px) { .bay-reality { grid-template-columns: 1fr 1fr; } .bay-real-main { grid-column: 1 / -1; } }
  @media (max-width: 620px) { .bay-reality { grid-template-columns: 1fr; } }
</style>
