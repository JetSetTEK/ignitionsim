---
import Base from '../../layouts/Base.astro';
import ArticleCard from '../../components/ArticleCard.astro';
import GearCarousel from '../../components/GearCarousel.astro';
import { getCollection } from 'astro:content';
import bays from '../../data/bays.json';
import site from '../../data/site.json';
import community from '../../data/community.json';
import systemMaps from '../../data/system-maps.json';
import editorialSurfaces from '../../data/editorial-surfaces.json';
import { articleMeta, articleSlug, isCertifiedArticle } from '../../lib/content';
import { getArticleCardArt } from '../../lib/articleArt';
import { hasVerifiedProductImage } from '../../lib/productMedia';
import { getWorldForBay } from '../../lib/worlds';
import { getCrewForBay, crewSlug } from '../../lib/crew';
import { canonicalAmazonProductUrl } from '../../lib/amazon';
import { clearsDiscoveryGate, evidenceLabels, qualityFor, sortByEditorialStrength } from '../../lib/editorial';

export async function getStaticPaths() {
  return bays.map((bay) => ({ params: { bay: bay.slug }, props: { bay } }));
}

const { bay } = Astro.props;
const world = getWorldForBay(bay.slug);
const bayCurator = getCrewForBay(bay.slug) as any;
const map = (systemMaps as any)[bay.slug];
const commItems = ((community as any)[bay.slug] || []).slice(0, 3) as any[];
const actionMap = (editorialSurfaces as any).curatorActions as Record<string, any[]>;
const curatorScenes = actionMap[crewSlug(bayCurator)] || [];
const primaryScene = curatorScenes[bay.slug === 'space' ? 1 : 0] || { image: bayCurator.scene, alt: bayCurator.sceneAlt, task: bayCurator.currentObsession };
const secondaryScene = curatorScenes[bay.slug === 'space' ? 0 : 1] || primaryScene;

const allBayArticles = await getCollection('articles', ({ data }) => data.bay === bay.slug && isCertifiedArticle(data));
const promotedArticles = sortByEditorialStrength(allBayArticles.filter((entry) => clearsDiscoveryGate(entry.id)));
const lead = promotedArticles[0];
const shelf = promotedArticles.slice(1, 5);
const leadHref = lead ? `/${bay.slug}/${articleSlug(lead)}` : '/guides';
const leadArt = lead ? getArticleCardArt(leadHref) : undefined;
const leadQuality = lead ? qualityFor(lead.id) : undefined;
const leadEvidence = lead ? evidenceLabels(lead.id) : [];

const amazonTag = (site as any).affiliate?.amazonTag;
const prodMods = import.meta.glob('/src/data/products/*.json', { eager: true });
const allProducts = Object.values(prodMods).flatMap((mod: any) => (mod.default || mod)) as any[];
const gearItems = allProducts
  .filter((product) => product.bay === bay.slug && hasVerifiedProductImage(product))
  .sort((a, b) => (b.rating?.overall || 0) - (a.rating?.overall || 0))
  .slice(0, 8)
  .map((product, index) => ({
    href: `/${bay.slug}/gear/${product.id}`,
    image: product.image || `/images/gear/${bay.slug}/${product.id}.jpg`,
    brand: product.brand,
    model: product.model,
    price: product.price,
    type: product.type,
    whoFor: product.whoFor,
    summary: product.summary,
    buyUrl: canonicalAmazonProductUrl(product, amazonTag),
    tag: index === 0 ? 'Bench pick' : undefined,
  }));

const schema = [
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: site.url },
      { '@type': 'ListItem', position: 2, name: `${bay.name} sim hardware`, item: new URL(`/${bay.slug}`, site.url).href },
    ],
  },
  {
    '@context': 'https://schema.org',
    '@type': 'CollectionPage',
    name: `${bay.name} simulator system hub`,
    description: `${map.dream} ${map.reality}`,
    url: new URL(`/${bay.slug}`, site.url).href,
    isPartOf: { '@type': 'WebSite', name: site.name, url: site.url },
  },
];
---
<Base title={`${bay.name} Simulator System Hub`} description={`${map.dream} ${map.reality}`} bay={bay.slug} activeNav={bay.slug} schema={schema} image={world.image}>
  <header class="bay-hero" data-bay={bay.slug}>
    <img src={world.image} alt={world.alt} loading="eager" decoding="async" />
    <div class="bay-hero-shade"></div>
    <div class="wrap bay-hero-inner">
      <nav class="crumbs" aria-label="Breadcrumb"><a href="/">Home</a><span>/</span>{bay.name}</nav>
      <div class="bay-hero-copy">
        <span class="lbl lbl-accent">{bay.name} system hub</span>
        <h1>{map.dream}</h1>
        <p>{map.reality}</p>
        <div class="bay-actions"><a class="btn btn-primary btn-lg" href="#system-map">Map the complete system</a>{lead && <a class="btn btn-lg" href={leadHref}>Open the strongest guide</a>}</div>
      </div>
      <a class="curator-on-shift" href={`/curator/${crewSlug(bayCurator)}`}>
        <div class="curator-shift-image"><img src={primaryScene.image} alt={primaryScene.alt} loading="eager" decoding="async" /><span>AI editorial scene</span></div>
        <div><small>{bayCurator.handle} · on shift</small><h2>{primaryScene.task}</h2><blockquote>“{bayCurator.favoriteWarning}”</blockquote></div>
      </a>
    </div>
  </header>

  <main>
    <section class="system-map-band" id="system-map" data-bay={bay.slug}>
      <div class="wrap">
        <div class="section-intro"><div><span class="lbl lbl-accent">The complete {bay.name.toLowerCase()} system</span><h2>Four decisions. One room that works together.</h2></div><p>Every stage is a dependency. Buying stage three before stage one is how boxes become expensive shelf decor.</p></div>
        <div class="system-map-grid">
          {map.stages.map((stage: any) => (
            <article><span>{stage.n}</span><h3>{stage.title}</h3><b>{stage.decision}</b><p>{stage.warning}</p></article>
          ))}
        </div>
      </div>
    </section>

    {lead && (
      <section class="authority-band" data-bay={bay.slug}>
        <div class="wrap authority-layout">
          <a class="authority-image" href={leadHref}>{leadArt && <img src={leadArt.image} alt={leadArt.alt} loading="eager" decoding="async" />}<span>{leadQuality?.grade} · {leadQuality?.score}/100 authority score</span></a>
          <div class="authority-copy">
            <span class="lbl lbl-accent">Start with this buyer map</span>
            <h2>{lead.data.title}</h2>
            <p>{lead.data.excerpt || lead.data.description}</p>
            <div class="authority-proof">{leadEvidence.map((label) => <span>{label}</span>)}</div>
            <small>{articleMeta(lead.data)}</small>
            <a class="btn btn-primary" href={leadHref}>Open the complete guide</a>
          </div>
        </div>
      </section>
    )}

    <section class="field-note-band" data-bay={bay.slug}>
      <div class="wrap field-note-layout">
        <div class="field-note-copy"><span class="lbl lbl-accent">{bayCurator.name}'s field note</span><h2>{secondaryScene.task}</h2><p>{bayCurator.origin}</p><blockquote>“{bayCurator.hillsToDieOn?.[0] || bayCurator.favoriteWarning}”</blockquote><a href={`/curator/${crewSlug(bayCurator)}`}>Open {bayCurator.name}'s current rig journal →</a></div>
        <div class="field-note-image"><img src={secondaryScene.image} alt={secondaryScene.alt} loading="lazy" decoding="async" /><span>AI editorial scene</span></div>
      </div>
    </section>

    {shelf.length > 0 && (
      <section class="route-band" data-bay={bay.slug}>
        <div class="wrap">
          <div class="section-intro"><div><span class="lbl lbl-accent">Next routes</span><h2>The rest of the {bay.name.toLowerCase()} bench, deliberately short.</h2></div><p>Only guides clearing the stronger discovery gate appear here. The full archive remains available without hijacking this page.</p></div>
          <div class="route-grid">
            {shelf.map((entry) => (
              <ArticleCard href={`/${bay.slug}/${articleSlug(entry)}`} title={entry.data.title} excerpt={entry.data.excerpt || entry.data.description} type={entry.data.type} meta={`${qualityFor(entry.id)?.grade} · ${qualityFor(entry.id)?.score}/100 · ${articleMeta(entry.data)}`} />
            ))}
          </div>
          <a class="archive-link" href="/guides">Browse the complete certified guide archive →</a>
        </div>
      </section>
    )}

    {commItems.length > 0 && (
      <section class="owner-signal-band" data-bay={bay.slug}>
        <div class="wrap owner-layout">
          <div><span class="lbl lbl-accent">Owner pattern</span><h2>What keeps coming back after launch week.</h2><p>Paraphrased patterns from builder conversations, never anonymous theater dressed up as a quote.</p></div>
          <div class="owner-list">
            {commItems.map((item: any, index: number) => <article><span>{String(index + 1).padStart(2,'0')} · {item.sentiment}</span><p>{item.point}</p><small>{item.context}</small></article>)}
          </div>
        </div>
      </section>
    )}

    {gearItems.length > 0 && (
      <section class="parts-band" id="parts-bench" data-bay={bay.slug}>
        <div class="wrap">
          <div class="section-intro"><div><span class="lbl lbl-accent">Technical parts bench</span><h2>Now inspect the boxes.</h2></div><p>Isolated product views belong here, where ports, prices, mounting, and direct purchase paths are the point.</p></div>
          <GearCarousel items={gearItems} id={`${bay.slug}-parts-bench`} />
        </div>
      </section>
    )}

    <section class="bay-newsletter" data-bay={bay.slug}>
      <div class="wrap newsletter-layout"><div><span class="lbl lbl-accent">{bay.name} Workbench Drop</span><h2>Useful updates, only when the bench moves.</h2><p>{site.newsletter.blurb} Firmware changes, fit warnings, owner patterns, and the products that earned another look.</p></div><form name={`${bay.slug}-bench-list`} method="POST" data-netlify="true" netlify-honeypot="bot-field"><input type="hidden" name="form-name" value={`${bay.slug}-bench-list`} /><p class="sr-only"><label>Do not fill this out: <input name="bot-field" /></label></p><input type="email" name="email" placeholder="builder@garage.net" aria-label="Email address" required /><button class="btn btn-primary" type="submit">Join the bench list</button></form></div>
    </section>
  </main>
</Base>

<style>
  .bay-hero { position:relative; min-height:720px; display:flex; align-items:flex-end; overflow:hidden; color:#fff; background:#101820; }
  .bay-hero > img { position:absolute; inset:0; width:100%; height:100%; object-fit:cover; filter:saturate(1.12) brightness(1.06); }
  .bay-hero-shade { position:absolute; inset:0; background:linear-gradient(90deg,rgba(8,15,22,.95),rgba(8,15,22,.5) 58%,rgba(8,15,22,.14)),linear-gradient(180deg,rgba(8,15,22,.04),rgba(8,15,22,.62)); }
  .bay-hero-inner { position:relative; z-index:1; width:100%; display:grid; grid-template-columns:minmax(0,1fr) 430px; gap:38px; align-items:end; padding-top:98px; padding-bottom:44px; }
  .bay-hero .crumbs { grid-column:1/-1; color:rgba(255,255,255,.72); }
  .bay-hero .crumbs a { color:inherit; }
  .bay-hero-copy h1 { max-width:13ch; margin:12px 0 18px; color:#fff; font-size:clamp(3.1rem,6.4vw,6rem); line-height:.9; text-transform:uppercase; }
  .bay-hero-copy > p { max-width:64ch; color:rgba(255,255,255,.84); font-size:1.06rem; line-height:1.65; }
  .bay-actions { display:flex; flex-wrap:wrap; gap:12px; margin-top:24px; }
  .curator-on-shift { overflow:hidden; color:#101820; background:rgba(255,255,255,.96); border:2px solid rgba(255,255,255,.45); box-shadow:0 14px 0 rgba(8,15,22,.25); }
  .curator-shift-image { position:relative; height:270px; overflow:hidden; }
  .curator-shift-image img { width:100%; height:100%; object-fit:cover; display:block; }
  .curator-shift-image span { position:absolute; left:12px; bottom:12px; padding:6px 8px; background:rgba(16,24,32,.82); color:#fff; font-family:var(--font-mono); font-size:.5rem; text-transform:uppercase; letter-spacing:.08em; }
  .curator-on-shift > div:last-child { padding:20px; }
  .curator-on-shift small { color:var(--accent); font-family:var(--font-mono); font-size:.55rem; font-weight:900; letter-spacing:.08em; text-transform:uppercase; }
  .curator-on-shift h2 { margin-top:8px; font-size:1.35rem; line-height:1.08; }
  .curator-on-shift blockquote { margin-top:10px; color:#435363; font-size:.9rem; line-height:1.5; }

  .section-intro { display:grid; grid-template-columns:minmax(0,1fr) minmax(260px,470px); gap:32px; align-items:end; margin-bottom:28px; }
  .section-intro h2 { max-width:17ch; margin-top:8px; font-size:clamp(2rem,4vw,3.7rem); line-height:.95; text-transform:uppercase; }
  .section-intro > p { color:#536272; line-height:1.65; }
  .system-map-band { padding:72px 0 82px; background:#f4f7f9; }
  .system-map-grid { display:grid; grid-template-columns:repeat(4,minmax(0,1fr)); border-top:2px solid #101820; border-bottom:2px solid #101820; }
  .system-map-grid article { padding:24px; border-right:1px solid rgba(16,24,32,.18); background:#fff; }
  .system-map-grid article:last-child { border-right:0; }
  .system-map-grid article > span { color:var(--accent); font-family:var(--font-disp); font-size:2.1rem; }
  .system-map-grid h3 { margin-top:12px; font-size:1.35rem; text-transform:uppercase; }
  .system-map-grid b { display:block; margin-top:10px; color:#263541; font-size:.9rem; line-height:1.45; }
  .system-map-grid p { margin-top:12px; color:#65727d; font-size:.84rem; line-height:1.55; }

  .authority-band { padding:82px 0; color:#fff; background:#101820; }
  .authority-layout { display:grid; grid-template-columns:1.12fr .88fr; gap:38px; align-items:center; }
  .authority-image { position:relative; min-height:480px; overflow:hidden; border:1px solid rgba(255,255,255,.24); }
  .authority-image img { position:absolute; inset:0; width:100%; height:100%; object-fit:cover; }
  .authority-image span { position:absolute; left:16px; top:16px; padding:8px 10px; color:#101820; background:#ff5e1a; border:1px solid #101820; font-family:var(--font-mono); font-size:.58rem; font-weight:900; }
  .authority-copy h2 { margin-top:11px; color:#fff; font-size:clamp(2rem,3.8vw,3.5rem); line-height:.96; }
  .authority-copy > p { margin-top:16px; color:rgba(255,255,255,.75); line-height:1.65; }
  .authority-proof { display:flex; flex-wrap:wrap; gap:8px; margin-top:18px; }
  .authority-proof span { padding:7px 9px; border:1px solid rgba(255,255,255,.24); color:rgba(255,255,255,.8); font-family:var(--font-mono); font-size:.52rem; text-transform:uppercase; letter-spacing:.06em; }
  .authority-copy > small { display:block; margin:16px 0; color:color-mix(in srgb,var(--accent) 70%,#fff); font-family:var(--font-mono); font-size:.56rem; text-transform:uppercase; }

  .field-note-band { padding:78px 0; background:#f4efe7; }
  .field-note-layout { display:grid; grid-template-columns:.9fr 1.1fr; gap:38px; align-items:center; }
  .field-note-copy h2 { max-width:16ch; margin-top:10px; font-size:clamp(2rem,4vw,3.7rem); line-height:.95; text-transform:uppercase; }
  .field-note-copy > p { margin-top:16px; color:#4b5b68; line-height:1.68; }
  .field-note-copy blockquote { margin:20px 0; padding-left:18px; border-left:4px solid var(--accent); font-family:var(--font-disp); font-size:1.28rem; line-height:1.3; }
  .field-note-copy > a { color:var(--accent); font-family:var(--font-mono); font-size:.62rem; font-weight:900; text-transform:uppercase; letter-spacing:.07em; }
  .field-note-image { position:relative; min-height:500px; overflow:hidden; box-shadow:0 14px 0 rgba(16,24,32,.12); }
  .field-note-image img { position:absolute; inset:0; width:100%; height:100%; object-fit:cover; }
  .field-note-image span { position:absolute; left:14px; bottom:14px; padding:7px 9px; color:#fff; background:rgba(16,24,32,.84); font-family:var(--font-mono); font-size:.5rem; text-transform:uppercase; }

  .route-band { padding:78px 0 88px; background:#fff; }
  .route-grid { display:grid; grid-template-columns:repeat(2,minmax(0,1fr)); gap:20px; }
  .archive-link { display:inline-block; margin-top:28px; color:var(--accent); font-family:var(--font-mono); font-size:.65rem; font-weight:900; text-transform:uppercase; letter-spacing:.07em; }

  .owner-signal-band { padding:78px 0; color:#fff; background:linear-gradient(135deg,#162533,#0c151d); }
  .owner-layout { display:grid; grid-template-columns:.68fr 1.32fr; gap:48px; }
  .owner-layout > div:first-child h2 { margin-top:9px; color:#fff; font-size:clamp(2rem,3.7vw,3.4rem); line-height:.96; text-transform:uppercase; }
  .owner-layout > div:first-child p { margin-top:14px; color:rgba(255,255,255,.7); line-height:1.6; }
  .owner-list { display:grid; gap:12px; }
  .owner-list article { padding:20px; color:#101820; background:#fff; border-left:5px solid var(--accent); }
  .owner-list span { color:var(--accent); font-family:var(--font-mono); font-size:.54rem; font-weight:900; text-transform:uppercase; letter-spacing:.08em; }
  .owner-list p { margin-top:8px; line-height:1.55; }
  .owner-list small { display:block; margin-top:9px; color:#6a7782; line-height:1.45; }

  .parts-band { padding:78px 0 88px; background:#eef4f7; }
  .bay-newsletter { padding:54px 0; background:#ff5e1a; border-top:3px solid #101820; }
  .newsletter-layout { display:grid; grid-template-columns:minmax(0,1fr) auto; gap:30px; align-items:center; }
  .newsletter-layout h2 { margin:8px 0; font-size:clamp(1.7rem,3.5vw,3rem); line-height:1; text-transform:uppercase; }
  .newsletter-layout p { max-width:65ch; color:#293641; }
  .newsletter-layout form { display:flex; gap:10px; }
  .newsletter-layout input { min-width:280px; padding:14px; border:2px solid #101820; background:#fff; font-family:var(--font-mono); }
  .newsletter-layout .btn { background:#101820; color:#fff; }

  @media (max-width:1000px) {
    .bay-hero-inner, .authority-layout, .field-note-layout, .owner-layout { grid-template-columns:1fr; }
    .curator-on-shift { max-width:720px; display:grid; grid-template-columns:44% 1fr; }
    .curator-shift-image { height:100%; min-height:260px; }
    .system-map-grid { grid-template-columns:1fr 1fr; }
    .system-map-grid article:nth-child(2) { border-right:0; }
    .system-map-grid article:nth-child(-n+2) { border-bottom:1px solid rgba(16,24,32,.18); }
  }
  @media (max-width:720px) {
    .bay-hero { min-height:900px; }
    .bay-hero-inner { padding-bottom:26px; }
    .bay-hero-copy h1 { font-size:clamp(3rem,14vw,4.6rem); }
    .curator-on-shift { grid-template-columns:1fr; }
    .section-intro { grid-template-columns:1fr; gap:12px; }
    .system-map-grid { grid-template-columns:1fr; }
    .system-map-grid article { border-right:0; border-bottom:1px solid rgba(16,24,32,.18); }
    .system-map-grid article:last-child { border-bottom:0; }
    .authority-image, .field-note-image { min-height:300px; }
    .route-grid { grid-template-columns:1fr; }
    .newsletter-layout { grid-template-columns:1fr; }
    .newsletter-layout form { flex-direction:column; }
    .newsletter-layout input { min-width:0; width:100%; }
  }
</style>
