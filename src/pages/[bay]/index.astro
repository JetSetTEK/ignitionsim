---
import Base from '../../layouts/Base.astro';
import ArticleCard from '../../components/ArticleCard.astro';
import GearCarousel from '../../components/GearCarousel.astro';
import { getCollection } from 'astro:content';
import bays from '../../data/bays.json';
import site from '../../data/site.json';
import community from '../../data/community.json';
import signals from '../../data/research-signals.json';
import growthPriorities from '../../data/growth-priorities.json';
import { articleMeta, isCertifiedArticle, sortNewestArticles } from '../../lib/content';
import { hasVerifiedProductImage } from '../../lib/productMedia';
import { getWorldForBay } from '../../lib/worlds';
import { getCrewForBay, crewSlug } from '../../lib/crew';

export async function getStaticPaths() {
  return bays.map((b) => ({ params: { bay: b.slug }, props: { bay: b } }));
}

const { bay } = Astro.props;
const baySignal = ((signals as any)[bay.slug] || {}) as any;
const world = getWorldForBay(bay.slug);
const bayCurator = getCrewForBay(bay.slug);
const commItems = ((community as any)[bay.slug] || []) as any[];
const commPreview = commItems.slice(0, 4);
const articles = sortNewestArticles(await getCollection('articles', ({ data }) => data.bay === bay.slug && isCertifiedArticle(data)));
const slug = (a: any) => a.id.split('/').pop();

const starterGuideByBay: Record<string, string> = (growthPriorities as any).starterGuideByBay || {};
const starterGuideSlug = starterGuideByBay[bay.slug] || (articles[0] ? slug(articles[0]) : '');
const starterGuideHref = starterGuideSlug ? `/${bay.slug}/${starterGuideSlug}` : '/guides';

const amazonTag = (site as any).affiliate?.amazonTag;
const prodMods = import.meta.glob('/src/data/products/*.json', { eager: true });
const allProducts = Object.values(prodMods).flatMap((m: any) => (m.default || m)) as any[];
const buyUrl = (p: any) => p.amazonAsin
  ? `https://www.amazon.com/dp/${p.amazonAsin}/?tag=${amazonTag}`
  : `https://www.amazon.com/s?k=${encodeURIComponent(p.brand + ' ' + p.model)}${amazonTag ? `&tag=${amazonTag}` : ''}`;
const gearItems = allProducts
  .filter((p) => p.bay === bay.slug && hasVerifiedProductImage(p))
  .sort((a, b) => (b.rating?.overall || 0) - (a.rating?.overall || 0))
  .slice(0, 12)
  .map((p, i) => ({
    href: `/${bay.slug}/gear/${p.id}`,
    image: p.image || `/images/gear/${bay.slug}/${p.id}.jpg`,
    brand: p.brand,
    model: p.model,
    price: p.price,
    type: p.type,
    whoFor: p.whoFor,
    summary: p.summary,
    buyUrl: buyUrl(p),
    tag: i === 0 ? 'Bench pick' : undefined,
  }));

const heroPhoto = { src: world.image, alt: world.alt, ai: true };
const schema = [
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: site.url },
      { '@type': 'ListItem', position: 2, name: `${bay.name} sim hardware`, item: new URL(`/${bay.slug}`, site.url).href },
    ],
  },
  {
    '@context': 'https://schema.org',
    '@type': 'CollectionPage',
    name: `${bay.name} sim hardware`,
    description: bay.intro,
    url: new URL(`/${bay.slug}`, site.url).href,
    isPartOf: { '@type': 'WebSite', name: site.name, url: site.url },
  },
];
---
<Base title={`${bay.name} Sim Hardware`} description={bay.intro} bay={bay.slug} activeNav={bay.slug} schema={schema}
      image={world.image}>
  <div class="bay-hero" style={`--world-bg: url('${world.image}')`}>
    <img src={heroPhoto.src} alt={heroPhoto.alt || `${bay.name} simulator setup`} loading="eager" decoding="async" />
    <div class="bay-hero-scrim"></div>
    {heroPhoto.ai && <span class="ai-scene-badge">AI world scene</span>}
    <div class="wrap bay-hero-inner">
      <div>
        <div class="crumbs"><a href="/">Home</a><span>/</span>{bay.name}</div>
        <span class="lbl lbl-accent">{bay.name} bench</span>
        <h1>{bay.tagline}</h1>
        <p>{bay.intro}</p>
        <div class="bay-hero-actions">
          <a class="btn btn-primary btn-lg" href={starterGuideHref}>{articles.length ? 'Open the buyer map' : 'See certified guides'}</a>
          {gearItems[0] && <a class="btn btn-lg" href="#parts-bench">Inspect parts bench</a>}
        </div>
      </div>
      <a class="bay-curator-card" href={`/curator/${crewSlug(bayCurator)}`}>
        <img src={bayCurator.image} alt={bayCurator.alt} loading="eager" decoding="async" />
        <div>
          <span>{bayCurator.handle}</span>
          <h2>{bayCurator.name}</h2>
          <p>{bayCurator.motto}</p>
          <small>{bayCurator.currentObsession}</small>
        </div>
      </a>
    </div>
  </div>

  <div class="wrap">
    {gearItems.length > 0 && (
      <section class="sec bay-world-section product-first" id="parts-bench" style={`--world-bg: url('${world.image}')`}>
        <div class="sec-head">
          <div>
            <span class="lbl lbl-accent">Product bench</span>
            <h2>The stuff people actually buy, mount, wire, and swear at.</h2>
          </div>
          <span class="lbl">{gearItems.length} verified product photos</span>
        </div>
        <GearCarousel items={gearItems} id={`${bay.slug}-parts-bench`} />
      </section>
    )}

    <section class="bay-truth world-panel" style={`--world-bg: url('${world.image}')`}>
      <article class="truth-main">
        <span class="lbl lbl-accent">Fast verdict</span>
        <h2>{baySignal.buyFast}</h2>
      </article>
      <article><span>Watch out</span><p>{baySignal.watchOut}</p></article>
      <article><span>Setup tax</span><p>{baySignal.weekendKiller}</p></article>
      <article><span>Maybe wait</span><p>{baySignal.waitFor}</p></article>
    </section>

    <section class="bay-dream-brief" style={`--world-bg: url('${world.image}')`}>
      <div>
        <span class="lbl lbl-accent">The dream · {world.label}</span>
        <h2>{bay.slug === 'golf' ? 'A room that makes practice feel like a private club.' : bay.slug === 'racing' ? 'A cockpit that makes every lap feel expensive.' : bay.slug === 'flight' ? 'A desk that stops being a desk and becomes a cockpit.' : bay.slug === 'space' ? 'A command station with six-axis control and no desk chaos.' : 'A bridge that feels built, not borrowed.'}</h2>
      </div>
      <p>{bay.slug === 'golf' ? 'Then the reality check starts: ceiling height, hitting width, projector throw, screen protection, and subscriptions.' : bay.slug === 'racing' ? 'Then the reality check starts: cockpit flex, brake consistency, monitor placement, and software profiles.' : bay.slug === 'flight' ? 'Then the reality check starts: USB power, bindings, rudder pedals, head tracking, and control curves.' : bay.slug === 'space' ? 'Then the reality check starts: mounts, bindings, button layers, and deciding HOSAS versus HOTAS.' : 'Then the reality check starts: software support, control mapping, DIY labels, and repurposed hardware.'}</p>
    </section>

    <section class="sec bay-world-section guide-shelf-world" style={`--world-bg: url('${world.image}')`}>
      <div class="sec-head">
          <div>
            <span class="lbl lbl-accent">Certified guides</span>
            <h2>{articles.length ? `The ${bay.name.toLowerCase()} maps worth opening before you buy.` : `${bay.name} guides stay dark until they have proof.`}</h2>
          </div>
        <span class="lbl">certified only</span>
      </div>
      {articles.length > 0 ? (
        <div class="card-grid">
          {articles.map((a) => (
            <ArticleCard href={`/${bay.slug}/${slug(a)}`} title={a.data.title}
              excerpt={a.data.excerpt || a.data.description} type={a.data.type}
              image={a.data.heroImage} imageAlt={a.data.heroAlt}
              meta={articleMeta(a.data)} />
          ))}
        </div>
      ) : (
        <div class="stowed-note">
          <h3>Nothing half-built is being shown here.</h3>
          <p>This bay stays lean until the guide has real photos, useful diagrams, current sources, affiliate paths, and a verdict strong enough to help a builder buy or wait.</p>
        </div>
      )}
    </section>

    {commPreview.length > 0 && (
      <section class="sec bay-world-section compact-signal" style={`--world-bg: url('${world.image}')`}>
        <div class="sec-head">
          <div>
            <span class="lbl lbl-accent">Builder signal</span>
            <h2>Four things the forums keep teaching the hard way.</h2>
          </div>
          <span class="lbl">paraphrased, not copied</span>
        </div>
        <div class="comm-grid">
          {commPreview.map((c) => (
            <article class="comm-card" data-sentiment={c.sentiment}>
              <span>{c.sentiment}</span>
              <p>{c.point}</p>
            </article>
          ))}
        </div>
      </section>
    )}

    <section class="workbench-drop" style={`--world-bg: url('${world.image}')`}>
      <div>
        <span class="lbl lbl-accent">{bay.name} workbench drop</span>
        <h2>Keep the bench honest.</h2>
        <p>{site.newsletter.blurb} We send buyer warnings, product moves, and setup notes when they actually matter.</p>
      </div>
      <form name={`${bay.slug}-bench-list`} method="POST" data-netlify="true" netlify-honeypot="bot-field">
        <input type="hidden" name="form-name" value={`${bay.slug}-bench-list`} />
        <p class="sr-only"><label>Do not fill this out: <input name="bot-field" /></label></p>
        <input type="email" placeholder="builder@garage.net" aria-label="Email address" required />
        <button class="btn btn-primary" type="submit">Join the bench list</button>
      </form>
    </section>
  </div>
</Base>

<style>
  .bay-hero {
    position: relative;
    min-height: 500px;
    display: flex;
    align-items: flex-end;
    overflow: hidden;
    border-bottom: 3px solid #101820;
  }
  .bay-hero > img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: saturate(1.08) contrast(1.04);
  }
  .bay-hero::after {
    content: "";
    position: absolute;
    inset: auto 0 0;
    height: 38%;
    pointer-events: none;
    background: linear-gradient(180deg, transparent, var(--baybg));
    opacity: .72;
  }
  .bay-hero-scrim {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(720px 420px at 78% 22%, color-mix(in srgb, var(--accent) 17%, transparent), transparent 72%),
      linear-gradient(90deg, rgba(16,24,32,.74), rgba(16,24,32,.36) 48%, rgba(16,24,32,.05)),
      linear-gradient(180deg, rgba(16,24,32,.02), rgba(16,24,32,.38));
  }
  .bay-hero-inner {
    position: relative;
    z-index: 2;
    max-width: 1180px;
    display: grid;
    grid-template-columns: minmax(0, 1fr) 340px;
    gap: 28px;
    align-items: end;
    padding-top: 84px;
    padding-bottom: 38px;
  }
  .bay-hero .crumbs,
  .bay-hero .crumbs a { color: rgba(255,255,255,.72); }
  .bay-hero h1 {
    color: #fff;
    max-width: 15ch;
    margin: 12px 0 16px;
    font-size: clamp(2.7rem, 5.6vw, 4.8rem);
    line-height: .92;
    text-transform: uppercase;
  }
  .bay-hero p {
    color: rgba(255,255,255,.86);
    max-width: 66ch;
    font-size: 1.05rem;
  }
  .bay-hero-actions { display: flex; flex-wrap: wrap; gap: 12px; margin-top: 22px; }
  .bay-curator-card {
    display: grid;
    grid-template-columns: 116px 1fr;
    gap: 14px;
    align-items: center;
    padding: 12px;
    color: #101820;
    background: rgba(255,255,255,.9);
    border: 2px solid rgba(255,255,255,.72);
    border-radius: 16px;
    box-shadow: 0 10px 0 rgba(16,24,32,.22), 0 28px 70px rgba(0,0,0,.26);
    -webkit-backdrop-filter: blur(10px);
    backdrop-filter: blur(10px);
  }
  .bay-curator-card:hover {
    transform: translateY(-4px);
    border-color: #fff;
  }
  .bay-curator-card img {
    width: 116px;
    height: 146px;
    object-fit: cover;
    object-position: center top;
    border-radius: 12px;
    border: 2px solid var(--accent);
  }
  .bay-curator-card span,
  .bay-curator-card small {
    display: block;
    font-family: var(--font-mono);
    color: var(--accent);
    font-size: .56rem;
    font-weight: 900;
    letter-spacing: .1em;
    text-transform: uppercase;
  }
  .bay-curator-card h2 {
    margin: 5px 0 7px;
    font-size: 1.3rem;
  }
  .bay-curator-card p {
    color: #253342;
    font-weight: 900;
    line-height: 1.32;
  }
  .bay-curator-card small {
    margin-top: 9px;
    color: #647484;
    letter-spacing: .04em;
    line-height: 1.35;
  }
  .curator-note {
    display: grid;
    grid-template-columns: 108px 1fr;
    gap: 14px;
    align-items: center;
    padding: 12px;
    color: #101820;
    background: rgba(255,255,255,.92);
    border: 2px solid rgba(255,255,255,.78);
    border-radius: 10px;
    -webkit-backdrop-filter: blur(8px);
    backdrop-filter: blur(8px);
  }
  .curator-note img {
    width: 108px;
    height: 132px;
    object-fit: cover;
    object-position: center top;
    border-radius: 8px;
    border: 1px solid rgba(16,24,32,.14);
  }
  .curator-note span {
    font-family: var(--font-mono);
    font-size: .56rem;
    color: var(--accent);
    text-transform: uppercase;
    letter-spacing: .1em;
    font-weight: 800;
  }
  .curator-note h2 { font-size: 1.35rem; margin: 5px 0; }
  .curator-note p { color: #435363; font-size: .86rem; line-height: 1.45; }
  .bay-proof-chip {
    justify-self: end;
    width: 220px;
    padding: 12px;
    color: #101820;
    background: rgba(255,255,255,.92);
    border: 2px solid rgba(255,255,255,.78);
    border-radius: 10px;
    box-shadow: 0 8px 0 rgba(16,24,32,.18);
    -webkit-backdrop-filter: blur(8px);
    backdrop-filter: blur(8px);
  }
  .bay-proof-chip span,
  .bay-proof-chip small {
    display: block;
    font-family: var(--font-mono);
    font-size: .52rem;
    letter-spacing: .08em;
    text-transform: uppercase;
    color: #5d6a76;
  }
  .bay-proof-chip img {
    display: block;
    width: 100%;
    aspect-ratio: 4 / 3;
    object-fit: contain;
    margin: 8px 0;
    border-radius: 8px;
    border: 1px solid rgba(16,24,32,.14);
    background: #fff;
  }
  .bay-proof-chip b { display: block; font-size: .9rem; line-height: 1.14; }
  .bay-proof-chip small { margin-top: 6px; line-height: 1.35; letter-spacing: .04em; color: #435363; }
  .bay-truth {
    position: relative;
    display: grid;
    grid-template-columns: 1.35fr repeat(3, 1fr);
    gap: 14px;
    margin: 28px 0 10px;
  }
  .bay-dream-brief {
    position: relative;
    display: grid;
    grid-template-columns: minmax(0, .95fr) minmax(0, 1fr);
    gap: 22px;
    align-items: end;
    margin: 28px 0 8px;
    padding: 26px;
    border: 2px solid #101820;
    border-radius: 22px;
    background:
      linear-gradient(90deg, rgba(16,24,32,.88), rgba(16,24,32,.52)),
      var(--world-bg) center / cover no-repeat;
    color: #fff;
    overflow: hidden;
    box-shadow: 0 12px 0 rgba(16,24,32,.18), 0 32px 72px color-mix(in srgb, var(--accent) 18%, transparent);
  }
  .bay-dream-brief::after,
  .bay-world-section::after,
  .workbench-drop::after {
    content: "";
    position: absolute;
    inset: 0;
    pointer-events: none;
    background:
      linear-gradient(rgba(255,255,255,.055) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255,255,255,.04) 1px, transparent 1px);
    background-size: 44px 44px;
    opacity: .42;
    mix-blend-mode: screen;
  }
  .bay-dream-brief h2 { margin-top: 8px; font-size: clamp(1.6rem, 3.2vw, 2.35rem); }
  .bay-dream-brief p { color: rgba(255,255,255,.86); font-size: 1.02rem; line-height: 1.65; }
  .bay-dream-brief > * { position: relative; z-index: 1; }
  .bay-dream-brief .lbl { color: color-mix(in srgb, var(--accent) 72%, #fff); }
  .bay-world-section {
    position: relative;
    margin: 34px -18px;
    padding: 34px 18px 40px;
    overflow: hidden;
    border: 2px solid color-mix(in srgb, var(--accent) 36%, rgba(16,24,32,.18));
    border-radius: 30px;
    background:
      radial-gradient(760px 340px at 80% 8%, color-mix(in srgb, var(--accent) 24%, transparent), transparent 70%),
      linear-gradient(90deg, rgba(16,24,32,.9), rgba(16,24,32,.52) 42%, rgba(16,24,32,.24)),
      var(--world-bg) center / cover no-repeat;
    box-shadow: 0 14px 0 rgba(16,24,32,.14), 0 38px 82px color-mix(in srgb, var(--accent) 16%, transparent);
  }
  .product-first {
    margin-top: 28px;
  }
  .product-first .sec-head h2 {
    max-width: 18ch;
  }
  .bay-world-section > * { position: relative; z-index: 1; }
  .bay-world-section .sec-head h2,
  .bay-world-section .sec-head .lbl {
    color: #fff;
    text-shadow: 0 2px 18px rgba(0,0,0,.32);
  }
  .bay-world-section .sec-head .lbl-accent,
  .bay-world-section .sec-head a {
    color: color-mix(in srgb, var(--accent) 72%, #fff);
  }
  .bay-world-section .card-grid,
  .bay-world-section .comm-grid {
    padding: 2px;
  }
  .guide-shelf-world .card-grid {
    grid-template-columns: repeat(auto-fit, minmax(min(100%, 560px), 1fr));
    gap: 22px;
  }
  .bay-truth article {
    border: 2px solid rgba(16,24,32,.14);
    border-radius: 10px;
    padding: 18px;
    background: rgba(255,255,255,.9);
    box-shadow: 0 8px 0 rgba(16,24,32,.1), 0 22px 42px rgba(16,24,32,.08);
    -webkit-backdrop-filter: blur(8px);
    backdrop-filter: blur(8px);
  }
  .bay-truth .truth-main h2 { margin-top: 9px; font-size: 1.3rem; line-height: 1.32; }
  .bay-truth article > span {
    display: block;
    font-family: var(--font-mono);
    color: var(--accent);
    text-transform: uppercase;
    letter-spacing: .11em;
    font-size: .58rem;
    font-weight: 800;
    margin-bottom: 8px;
  }
  .bay-truth p { color: #435363; font-size: .9rem; line-height: 1.55; }
  .stowed-note {
    border: 2px dashed rgba(16,24,32,.22);
    border-radius: 10px;
    padding: 24px;
    background: rgba(255,255,255,.9);
    -webkit-backdrop-filter: blur(8px);
    backdrop-filter: blur(8px);
  }
  .stowed-note h3 { font-size: 1.3rem; }
  .stowed-note p { color: #435363; margin-top: 8px; max-width: 70ch; }
  .compact-signal {
    background:
      radial-gradient(760px 340px at 80% 8%, color-mix(in srgb, var(--accent) 15%, transparent), transparent 70%),
      linear-gradient(90deg, rgba(16,24,32,.78), rgba(16,24,32,.3) 44%, rgba(16,24,32,.12)),
      var(--world-bg) center / cover no-repeat;
  }
  .comm-grid { display: grid; grid-template-columns: repeat(4, minmax(0, 1fr)); gap: 14px; }
  .comm-card {
    border: 2px solid rgba(16,24,32,.14);
    border-left: 6px solid var(--accent);
    border-radius: 10px;
    padding: 18px;
    background: rgba(255,255,255,.92);
    box-shadow: 0 8px 0 rgba(16,24,32,.08);
    -webkit-backdrop-filter: blur(8px);
    backdrop-filter: blur(8px);
  }
  .comm-card[data-sentiment="warning"] { border-left-color: var(--red); }
  .comm-card[data-sentiment="tip"] { border-left-color: var(--green); }
  .comm-card[data-sentiment="debate"] { border-left-color: var(--amber); }
  .comm-card span {
    font-family: var(--font-mono);
    color: var(--accent);
    font-size: .56rem;
    letter-spacing: .12em;
    text-transform: uppercase;
    font-weight: 800;
  }
  .comm-card p { color: #2d3a46; margin-top: 10px; line-height: 1.55; }
  .workbench-drop {
    position: relative;
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    gap: 24px;
    align-items: center;
    margin: 34px 0 60px;
    padding: 26px;
    border: 2px solid #101820;
    border-radius: 24px;
    color: #fff;
    overflow: hidden;
    background:
      linear-gradient(90deg, rgba(16,24,32,.94), rgba(16,24,32,.66)),
      var(--world-bg) center / cover no-repeat;
    box-shadow: 0 12px 0 rgba(16,24,32,.18), 0 32px 72px color-mix(in srgb, var(--accent) 18%, transparent);
  }
  .workbench-drop > * { position: relative; z-index: 1; }
  .workbench-drop h2 { font-size: clamp(1.5rem, 3.2vw, 2.2rem); margin: 8px 0; }
  .workbench-drop p { color: rgba(255,255,255,.84); max-width: 66ch; }
  .workbench-drop form { display: flex; gap: 10px; flex-wrap: wrap; justify-content: flex-end; }
  .workbench-drop input {
    min-width: 260px;
    border: 2px solid rgba(16,24,32,.14);
    border-radius: 8px;
    padding: 13px 14px;
    font-family: var(--font-mono);
  }
  @media (max-width: 980px) {
    .bay-hero-inner,
    .bay-truth, .bay-dream-brief, .workbench-drop, .comm-grid { grid-template-columns: 1fr; }
    .bay-curator-card,
    .curator-note { max-width: 520px; }
    .bay-proof-chip { display: none; }
  }
  @media (max-width: 620px) {
    .bay-hero { min-height: 760px; }
    .bay-hero h1 { font-size: clamp(3rem, 16vw, 4.8rem); }
    .curator-note { grid-template-columns: 86px 1fr; }
    .curator-note img { width: 86px; height: 108px; }
    .workbench-drop form { justify-content: stretch; }
    .workbench-drop input, .workbench-drop button { width: 100%; justify-content: center; }
  }
</style>
