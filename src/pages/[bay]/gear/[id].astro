---
import Base from '../../../layouts/Base.astro';
import FAQ from '../../../components/FAQ.astro';
import ArticleCard from '../../../components/ArticleCard.astro';
import ShareButtons from '../../../components/ShareButtons.astro';
import bays from '../../../data/bays.json';
import site from '../../../data/site.json';
import signals from '../../../data/research-signals.json';
import { getCollection } from 'astro:content';
import { articleMeta, isCertifiedArticle } from '../../../lib/content';
import { displayProductImage, hasVerifiedProductImage } from '../../../lib/productMedia';
import { canonicalAmazonProductUrl } from '../../../lib/amazon';

export async function getStaticPaths() {
  const mods = import.meta.glob('/src/data/products/*.json', { eager: true });
  const all = Object.values(mods).flatMap((m: any) => (m.default || []));
  const visible = all.filter((p: any) => hasVerifiedProductImage(p));
  return visible.map((p: any) => ({ params: { bay: p.bay, id: p.id }, props: { product: p, all: visible } }));
}
const { product, all } = Astro.props;
const p = product;
const imgs: string[] = Array.isArray(p.images) && p.images.length ? p.images : (displayProductImage(p) ? [displayProductImage(p)!] : []);
const hasRealGallery = imgs.length > 0;
const bay = bays.find((b) => b.slug === p.bay)!;
const url = new URL(`/${p.bay}/gear/${p.id}`, site.url).href;
const amazonTag = (site as any).affiliate?.amazonTag;
const buyUrl = canonicalAmazonProductUrl(p, amazonTag);
const brandMods = import.meta.glob('/src/data/brands.json', { eager: true });
const brandIds = new Set((((Object.values(brandMods)[0] as any)?.default) || []).map((b: any) => b.id));
const brandSlug = String(p.brand).toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/(^-|-$)/g, '');
const hasBrandPage = brandIds.has(brandSlug);
const related = all
  .filter((x: any) => x.bay === p.bay && x.type === p.type && x.id !== p.id)
  .map((x: any) => ({ ...x, amazonUrl: canonicalAmazonProductUrl(x, amazonTag) }))
  .filter((x: any) => x.amazonUrl)
  .slice(0, 4);
const guides = (await getCollection('articles', ({ data }) => data.bay === p.bay && isCertifiedArticle(data))).slice(0, 3);
const guideSlug = (a: any) => a.id.split('/').pop();
const specEntries = Object.entries(p.specs || {});
const ratingAxes = Object.entries(p.rating || {}).filter(([k]) => k !== 'overall');

const offers = p.price && buyUrl ? {
  '@type': 'Offer', price: String(p.price), priceCurrency: 'USD',
  availability: 'https://schema.org/InStock', url: buyUrl,
} : undefined;
const schema: Record<string, any>[] = [
  {
    '@context': 'https://schema.org', '@type': 'Product',
    name: `${p.brand} ${p.model}`, brand: { '@type': 'Brand', name: p.brand },
    description: p.summary, image: new URL(p.image, site.url).href, category: `${bay.name} sim hardware`,
    ...(offers ? { offers } : {}),
    ...(p.rating?.overall ? {
      review: {
        '@type': 'Review',
        name: `IgnitionSim Verdict: ${p.brand} ${p.model}`,
        reviewBody: p.summary,
        reviewRating: { '@type': 'Rating', ratingValue: String(p.rating.overall), bestRating: '10', worstRating: '1' },
        author: { '@type': 'Person', name: site.author.name, url: new URL('/about', site.url).href },
        publisher: { '@type': 'Organization', name: site.name },
      },
    } : {}),
  },
  {
    '@context': 'https://schema.org', '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: site.url },
      { '@type': 'ListItem', position: 2, name: `${bay.name} sim hardware`, item: new URL(`/${p.bay}`, site.url).href },
      { '@type': 'ListItem', position: 3, name: 'Gear', item: new URL(`/${p.bay}/gear`, site.url).href },
      { '@type': 'ListItem', position: 4, name: `${p.brand} ${p.model}`, item: url },
    ],
  },
];
if (p.faqs?.length) schema.push({
  '@context': 'https://schema.org', '@type': 'FAQPage',
  mainEntity: p.faqs.map((f: any) => ({ '@type': 'Question', name: f.q, acceptedAnswer: { '@type': 'Answer', text: f.a } })),
});
const typeLabel = (p.type || '').replace(/-/g, ' ');
const baySignal = ((signals as any)[p.bay] || {}) as any;
const verdictScore = Number(p.rating?.overall || 0);
const buyPulse = verdictScore >= 8.5
  ? { tone: 'buy', label: 'Buy with confidence', copy: 'This is one of the cleaner buys in its lane if the price and platform fit your setup.' }
  : verdictScore >= 7.5
    ? { tone: 'caveat', label: 'Buy with caveats', copy: 'Worth buying for the right builder, but read the warnings before it lands in your cart.' }
    : { tone: 'wait', label: 'Niche or wait', copy: 'There may be a better first purchase unless this solves a very specific problem for you.' };
---
<Base title={`${p.brand} ${p.model} — specs, rating & verdict`} description={p.summary} bay={p.bay} activeNav={p.bay} schema={schema} image={`/og/gear/${p.bay}/${p.id}.png`} noindex={true}>
  <div class="wrap">
    <div class="crumbs"><a href="/">Home</a><span>/</span><a href={`/${p.bay}`}>{bay.name}</a><span>/</span><a href={`/${p.bay}/gear`}>Gear</a><span>/</span>{p.model}</div>

    <section class="gear-hero">
      <div class="gh-left">
        <figure class={`gh-img ${hasRealGallery ? '' : 'gh-spec-card'}`} data-lightbox={hasRealGallery ? true : undefined} data-images={JSON.stringify(imgs)}>
          {hasRealGallery && buyUrl && <a class="gh-amazon-image" href={buyUrl} target="_blank" rel="sponsored nofollow noopener" data-buy-link="true" data-event="buy_click" data-buy-product={p.id}><img id="gh-main" src={imgs[0]} alt={`${p.brand} ${p.model}`} /></a>}
          {hasRealGallery && !buyUrl && <img id="gh-main" src={imgs[0]} alt={`${p.brand} ${p.model}`} />}
          {p.rating?.overall && <span class="gh-score">{p.rating.overall}<small>/10</small></span>}
        </figure>
        {imgs.length > 1 && (
          <div class="gallery-thumbs" id="gh-thumbs">
            {imgs.map((src, i) => (
              <button class={i === 0 ? 'on' : ''} data-src={src} aria-label={`View image ${i + 1}`}><img src={src} alt="" loading="lazy" /></button>
            ))}
          </div>
        )}
        <p class="gh-hint lbl">Click image to expand</p>
        <script>
          (() => {
            const main = document.getElementById('gh-main') as HTMLImageElement | null;
            const thumbs = document.getElementById('gh-thumbs');
            if (!main || !thumbs) return;
            thumbs.querySelectorAll('button').forEach((b) => b.addEventListener('click', () => {
              main.src = (b as HTMLElement).dataset.src!;
              thumbs.querySelectorAll('button').forEach((x) => x.classList.remove('on'));
              b.classList.add('on');
            }));
          })();
        </script>
      </div>
      <div class="gh-info">
        <span class="lbl lbl-accent">{p.brand} · {typeLabel}</span>
        <h1>{p.model}</h1>
        {p.whoFor && <p class="gh-who">{p.whoFor}</p>}
        <div class="gh-price">{p.price ? `~$${p.price.toLocaleString()}` : 'Price varies'} <small>{p.priceNote || ''}</small></div>
        <p style="color:#334155;margin-top:6px">{p.summary}</p>
        <div class={`buy-pulse ${buyPulse.tone}`}>
          <span>{buyPulse.label}</span>
          <p>{buyPulse.copy}</p>
          {p.cons?.[0] && <small>Known caution: {p.cons[0]}</small>}
        </div>
        <div class="gh-cta">
          {buyUrl && <a class="btn btn-primary" href={buyUrl} target="_blank" rel="sponsored nofollow noopener" data-event="buy_click">Check price on Amazon ▸</a>}
          {buyUrl && <a class="btn" href={buyUrl} target="_blank" rel="sponsored nofollow noopener" data-event="review_check">Check live seller reviews ↗</a>}
          {hasBrandPage && <a class="btn" href={`/brand/${brandSlug}`}>More {p.brand} →</a>}
          <a class="btn" href={`/${p.bay}/gear`}>All {bay.name} gear</a>
        </div>
        <p class="gh-disc">{site.disclosure}</p>
        <div style="margin-top:12px"><ShareButtons /></div>
      </div>
    </section>

    <section class="gear-body">
      <div class="gb-main">
        {specEntries.length > 0 && (
          <>
            <h2>Specs</h2>
            <table class="spec-table"><tbody>
              {specEntries.map(([k, v]) => <tr><th>{k}</th><td>{v}</td></tr>)}
            </tbody></table>
          </>
        )}
        {(p.pros?.length || p.cons?.length) && (
          <div class="proscons">
            {p.pros?.length > 0 && <div class="pc pros"><h3>Pros</h3><ul>{p.pros.map((x: string) => <li>{x}</li>)}</ul></div>}
            {p.cons?.length > 0 && <div class="pc cons"><h3>Cons</h3><ul>{p.cons.map((x: string) => <li>{x}</li>)}</ul></div>}
          </div>
        )}
        <div class="prose" style="max-width:none"><FAQ faqs={p.faqs || []} heading="Common questions" /></div>
      </div>
      <aside class="gb-side">
        {ratingAxes.length > 0 && (
          <div class="ratecard">
            <h3>IgnitionSim Verdict</h3>
            {ratingAxes.map(([k, v]) => (
              <div class="rate-row">
                <span class="rate-l">{k.replace(/([A-Z])/g, ' $1').replace(/^./, (c) => c.toUpperCase())}</span>
                <span class="rate-bar"><span style={`width:${(Number(v) / 10) * 100}%`}></span></span>
                <span class="rate-v">{v}</span>
              </div>
            ))}
            <a href="/methodology" class="rate-method">▸ How we score</a>
          </div>
        )}
        {p.platforms && <div class="ratecard"><h3>Platforms</h3><p style="color:var(--dim);font-family:var(--font-mono);font-size:.85rem">{p.platforms}</p></div>}
        <div class="ratecard review-pulse">
          <h3>Buyer pulse</h3>
          <p><b>Best use:</b> {p.whoFor || p.summary}</p>
          {p.pros?.[0] && <p><b>Why it works:</b> {p.pros[0]}</p>}
          {p.cons?.[0] && <p><b>Check before buying:</b> {p.cons[0]}</p>}
          {baySignal.weekendKiller && <p><b>Setup tax:</b> {baySignal.weekendKiller}</p>}
          {buyUrl && <a href={buyUrl} target="_blank" rel="sponsored nofollow noopener" data-event="seller_review_check">Verify current seller reviews ↗</a>}
        </div>
      </aside>
    </section>

    {related.length > 0 && (
      <section class="sec">
        <div class="sec-head"><h2>Compare with</h2></div>
        <div class="card-grid">
          {related.map((r: any) => (
            <article class="card commerce-card">
              <a class="cimg" href={r.amazonUrl} target="_blank" rel="sponsored nofollow noopener" data-buy-link="true" data-event="buy_click" data-buy-product={r.id}><img src={r.image} alt={`${r.brand} ${r.model}`} loading="lazy" /></a>
              <div class="cbody">
                <span class="ctype">{r.brand}{r.rating?.overall ? ` · ${r.rating.overall}/10` : ''}</span>
                <h3 style="font-size:1.05rem"><a href={r.amazonUrl} target="_blank" rel="sponsored nofollow noopener" data-buy-link="true" data-event="buy_click" data-buy-product={r.id}>{r.model}</a></h3>
                <span class="cmeta" style="color:var(--accent)">{r.price ? `~$${r.price.toLocaleString()}` : ''}</span>
                <div class="commerce-actions"><a class="btn btn-primary" href={r.amazonUrl} target="_blank" rel="sponsored nofollow noopener" data-buy-link="true" data-event="buy_click" data-buy-product={r.id}>Amazon</a><a class="btn" href={`/${r.bay}/gear/${r.id}`}>Specs</a></div>
              </div>
            </article>
          ))}
        </div>
      </section>
    )}

    {guides.length > 0 && (
      <section class="sec">
        <div class="sec-head"><h2>Related {bay.name} guides</h2></div>
        <div class="card-grid">
          {guides.map((a: any) => (
            <ArticleCard href={`/${a.data.bay}/${guideSlug(a)}`} title={a.data.title}
              excerpt={a.data.excerpt || a.data.description} type={a.data.type}
              image={a.data.heroImage} imageAlt={a.data.heroAlt}
              meta={articleMeta(a.data)} />
          ))}
        </div>
      </section>
    )}
  </div>
</Base>

<style>
  .gear-hero { display: grid; grid-template-columns: 1fr 1.2fr; gap: 30px; margin: 18px 0 36px; align-items: start; }
  .gh-img { position: relative; border: 1px solid var(--line2); border-radius: 16px; overflow: hidden; margin: 0; aspect-ratio: 16/10; }
  .gh-img img { width: 100%; height: 100%; object-fit: contain; background:#fff; }
  .gh-amazon-image { display: block; width: 100%; height: 100%; }
  .gh-left { display: flex; flex-direction: column; }
  .gh-hint { margin-top: 8px; color: var(--dimmer); font-size: .6rem; }
  .gh-score { position: absolute; top: 14px; right: 14px; font-family: var(--font-disp); font-weight: 800; font-size: 1.5rem; color: var(--accent); background: color-mix(in srgb, #ffffff 82%, transparent); border: 1px solid var(--accent); border-radius: 12px; padding: 6px 12px; -webkit-backdrop-filter: blur(6px); backdrop-filter: blur(6px); box-shadow: 0 8px 22px rgba(15,23,42,.12); }
  .gh-score small { font-size: .8rem; color: var(--dim); }
  .gh-info h1 { font-size: clamp(1.8rem, 4vw, 2.6rem); margin: 8px 0; }
  .gh-who { color: var(--dim); font-size: 1.05rem; }
  .gh-price { font-family: var(--font-disp); font-weight: 800; font-size: 1.6rem; color: var(--accent); margin-top: 12px; }
  .gh-price small { font-family: var(--font-mono); font-size: .62rem; color: var(--dimmer); font-weight: 400; letter-spacing: .04em; }
  .gh-cta { display: flex; flex-wrap: wrap; gap: 10px; margin-top: 18px; }
  .gh-disc { font-size: .72rem; color: var(--dimmer); margin-top: 14px; border-top: 1px dashed var(--line2); padding-top: 10px; }
  .gear-body { display: grid; grid-template-columns: 1fr 300px; gap: 30px; align-items: start; }
  .gb-main h2 { font-size: 1.5rem; margin: 0 0 14px; position: relative; padding-top: .4em; }
  .gb-main h2::before { content: ""; position: absolute; top: 0; left: 0; width: 44px; height: 3px; background: var(--accent); border-radius: 3px; }
  .proscons { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; margin: 24px 0; }
  .pc { border: 1px solid var(--line2); border-radius: 12px; padding: 16px 18px; }
  .pc h3 { font-size: 1rem; margin-bottom: 8px; }
  .pc.pros { border-left: 3px solid var(--green); } .pc.pros h3 { color: var(--green); }
  .pc.cons { border-left: 3px solid var(--red); } .pc.cons h3 { color: var(--red); }
  .pc ul { padding-left: 1.1em; color: #334155; font-size: .9rem; } .pc li { margin: 6px 0; }
  .ratecard { border: 1px solid var(--line2); border-radius: 12px; padding: 18px; margin-bottom: 16px; background: var(--panel); }
  .ratecard h3 { font-family: var(--font-mono); font-size: .64rem; letter-spacing: .14em; text-transform: uppercase; color: var(--accent); margin-bottom: 12px; }
  .rate-row { display: grid; grid-template-columns: 1fr 80px 24px; align-items: center; gap: 8px; margin: 9px 0; font-size: .8rem; }
  .rate-l { color: var(--dim); }
  .rate-bar { height: 6px; background: var(--line2); border-radius: 6px; overflow: hidden; }
  .rate-bar span { display: block; height: 100%; background: var(--accent); box-shadow: 0 0 8px var(--bayglow); }
  .rate-v { font-family: var(--font-mono); color: var(--txt); text-align: right; font-size: .78rem; }
  .rate-method { display: inline-block; margin-top: 12px; font-family: var(--font-mono); font-size: .62rem; letter-spacing: .08em; color: var(--accent); }
  .buy-pulse { margin-top: 14px; border: 1px solid var(--line2); border-left: 4px solid var(--accent); border-radius: 12px; padding: 14px 16px; background: #fff; }
  .buy-pulse span { display: block; font-family: var(--font-mono); font-size: .62rem; letter-spacing: .12em; text-transform: uppercase; color: var(--accent); font-weight: 800; }
  .buy-pulse p { color: #334155; margin-top: 6px; font-size: .92rem; }
  .buy-pulse small { display: block; margin-top: 6px; color: var(--dim); font-size: .78rem; line-height: 1.45; }
  .buy-pulse.wait { border-left-color: var(--red); }
  .buy-pulse.caveat { border-left-color: var(--amber); }
  .review-pulse p { color: #475569; font-size: .84rem; line-height: 1.55; margin: 9px 0; }
  .review-pulse b { color: var(--txt); }
  .review-pulse a { display: inline-block; margin-top: 8px; font-family: var(--font-mono); font-size: .62rem; letter-spacing: .08em; text-transform: uppercase; color: var(--accent); }
  .commerce-card { display: flex; flex-direction: column; }
  .commerce-card h3 a { color: inherit; }
  .commerce-actions { display: flex; flex-wrap: wrap; gap: 8px; margin-top: 12px; }
  .commerce-actions .btn { padding: 8px 10px; font-size: .62rem; }
  @media (max-width: 880px) { .gear-hero, .gear-body { grid-template-columns: 1fr; } .proscons { grid-template-columns: 1fr; } }
</style>
