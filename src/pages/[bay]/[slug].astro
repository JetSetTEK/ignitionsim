---
import Base from '../../layouts/Base.astro';
import FAQ from '../../components/FAQ.astro';
import ArticleCard from '../../components/ArticleCard.astro';
import { getCollection, render } from 'astro:content';
import ShareButtons from '../../components/ShareButtons.astro';
import bays from '../../data/bays.json';
import site from '../../data/site.json';
import signals from '../../data/research-signals.json';
import { isCertifiedArticle } from '../../lib/content';

export async function getStaticPaths() {
  const articles = await getCollection('articles', ({ data }) => isCertifiedArticle(data));
  return articles.map((entry) => ({
    params: { bay: entry.data.bay, slug: entry.id.split('/').pop() },
    props: { entry },
  }));
}
const { entry } = Astro.props;
const { Content } = await render(entry);
const d = entry.data;
const bay = bays.find((b) => b.slug === d.bay)!;
const slug = entry.id.split('/').pop();
const url = new URL(`/${d.bay}/${slug}`, site.url).href;

const fmtDate = (x: Date) => new Date(x).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });

// related
const related = (await getCollection('articles', ({ data }) => isCertifiedArticle(data)))
  .filter((a) => a.id !== entry.id && (d.related.includes(a.id.split('/').pop()!) || a.data.bay === d.bay))
  .slice(0, 3);

const typeLabel = d.type.replace(/-/g, ' ');
const baySignal = ((signals as any)[d.bay] || {}) as any;
const amazonTag = (site as any).affiliate?.amazonTag;
const prodMods = import.meta.glob('/src/data/products/*.json', { eager: true });
const allProducts = Object.values(prodMods).flatMap((m: any) => (m.default || m)) as any[];
const buyUrl = (p: any) => p.amazonAsin
  ? `https://www.amazon.com/dp/${p.amazonAsin}/?tag=${amazonTag}`
  : `https://www.amazon.com/s?k=${encodeURIComponent(p.brand + ' ' + p.model)}${amazonTag ? `&tag=${amazonTag}` : ''}`;
const displayImage = (p: any) => Array.isArray(p.images) && p.images.length ? p.images[0] : p.image;
const hasRealImage = (src?: string) => Boolean(src && (/^https?:/.test(src) || /-\d+\.(jpe?g|png|webp)$/i.test(src)));
const rankProduct = (p: any) => (p.rating?.overall || 0) * 100 + Math.min(p.price || 0, 3000) / 1000;
const articleProducts = allProducts
  .filter((p) => p.bay === d.bay)
  .sort((a, b) => rankProduct(b) - rankProduct(a))
  .slice(0, 5);
const sourceLinks = [
  ...(baySignal.officialSources || []).slice(0, 3),
  ...(baySignal.communitySources || []).slice(0, 2),
];

const schema: Record<string, any>[] = [
  {
    '@context': 'https://schema.org', '@type': 'Article',
    headline: d.title, description: d.description,
    image: d.heroImage ? new URL(d.heroImage, site.url).href : new URL('/og-default.png', site.url).href,
    datePublished: new Date(d.publishDate).toISOString(),
    dateModified: new Date(d.updatedDate || d.publishDate).toISOString(),
    author: { '@type': 'Person', name: d.author, url: new URL('/about', site.url).href },
    publisher: { '@type': 'Organization', name: site.name, logo: { '@type': 'ImageObject', url: new URL('/favicon.svg', site.url).href } },
    mainEntityOfPage: { '@type': 'WebPage', '@id': url },
    articleSection: `${bay.name} sim hardware`,
    keywords: d.primaryKeyword,
    about: [
      { '@type': 'Thing', name: `${bay.name} sim hardware` },
      ...articleProducts.slice(0, 4).map((p: any) => ({ '@type': 'Product', name: `${p.brand} ${p.model}` })),
    ],
  },
  {
    '@context': 'https://schema.org', '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: site.url },
      { '@type': 'ListItem', position: 2, name: `${bay.name} sim hardware`, item: new URL(`/${d.bay}`, site.url).href },
      { '@type': 'ListItem', position: 3, name: d.title, item: url },
    ],
  },
];
if (d.faqs.length) {
  schema.push({
    '@context': 'https://schema.org', '@type': 'FAQPage',
    mainEntity: d.faqs.map((f) => ({
      '@type': 'Question', name: f.q,
      acceptedAnswer: { '@type': 'Answer', text: f.a },
    })),
  });
}
---
<Base title={d.title} description={d.description} bay={d.bay} activeNav={d.bay} schema={schema}
      image={`/og/${d.bay}/${slug}.png`}>
  <article class="wrap">
    <div class="crumbs"><a href="/">Home</a><span>/</span><a href={`/${d.bay}`}>{bay.name}</a><span>/</span>{typeLabel}</div>

    <header style="max-width:760px;margin:0 auto 8px">
      <span class="lbl lbl-accent">{typeLabel}</span>
      <h1 style="font-size:clamp(2rem,4.6vw,3rem);margin:12px 0 16px;line-height:1.12">{d.title}</h1>
      <p style="color:var(--dim);font-size:1.12rem">{d.description}</p>
      <p class="byline" style="margin-top:16px">By <b>{d.author}</b> · {fmtDate(d.publishDate)}{d.updatedDate ? ` · Updated ${fmtDate(d.updatedDate)}` : ''} · {d.readingTime || 7} min read</p>
      <div style="margin-top:14px"><ShareButtons /></div>
    </header>

    {d.heroImage && (
      <figure class="pano" style="min-height:380px;margin:24px auto;max-width:1000px">
        <img src={d.heroImage} alt={d.heroAlt || d.title} />
        <div class="scrim"></div>
      </figure>
    )}

    <section class="article-evidence" data-bay={d.bay}>
      <div class="reality-grid">
        <div class="reality-main">
          <span class="lbl lbl-accent">// Build reality check</span>
          <h2>Fast verdict before you buy</h2>
          <p>{baySignal.buyFast}</p>
        </div>
        <div class="reality-note">
          <span>Watch out</span>
          <p>{baySignal.watchOut}</p>
        </div>
        <div class="reality-note">
          <span>Weekend killer</span>
          <p>{baySignal.weekendKiller}</p>
        </div>
        <div class="reality-note">
          <span>Maybe wait</span>
          <p>{baySignal.waitFor}</p>
        </div>
      </div>
      {articleProducts.length > 0 && (
        <div class="parts-bench">
          <div class="bench-head">
            <span class="lbl lbl-accent">// Parts bench</span>
            <p>Related products to inspect while reading this guide. Ratings are IgnitionSim editorial scores; seller ratings should be checked live before checkout.</p>
          </div>
          <div class="bench-products">
            {articleProducts.map((p: any) => (
              <a class="bench-product" href={`/${p.bay}/gear/${p.id}`}>
                {hasRealImage(displayImage(p))
                  ? <img src={displayImage(p)} alt={`${p.brand} ${p.model}`} loading="lazy" decoding="async" />
                  : <span class="bench-spec"><b>{p.brand}</b><em>{p.model}</em></span>}
                <span>{p.brand}</span>
                <strong>{p.model}</strong>
                <small>{p.rating?.overall ? `${p.rating.overall}/10` : 'review'} · {p.price ? `~$${p.price.toLocaleString()}` : 'price varies'}</small>
              </a>
            ))}
          </div>
        </div>
      )}
      {sourceLinks.length > 0 && (
        <div class="source-shelf">
          <span class="lbl lbl-accent">// Evidence shelf</span>
          <div>
            {sourceLinks.map((s: any) => <a href={s.url} target="_blank" rel="noopener nofollow">{s.label}</a>)}
          </div>
        </div>
      )}
    </section>

    <nav class="toc" id="article-toc" aria-label="On this page" style="display:none">
      <h4>On this page</h4>
      <ol></ol>
    </nav>

    <div class="prose">
      <Content />
    </div>

    <script>
      (() => {
        const toc = document.getElementById('article-toc');
        const prose = document.querySelector('article .prose');
        if (!toc || !prose) return;
        const h2s = [...prose.querySelectorAll('h2')];
        if (h2s.length < 3) return;
        const ol = toc.querySelector('ol');
        h2s.forEach((h, i) => {
          if (!h.id) h.id = 'sec-' + (i + 1);
          const li = document.createElement('li');
          const a = document.createElement('a');
          a.href = '#' + h.id;
          a.textContent = h.textContent || ('Section ' + (i + 1));
          li.appendChild(a);
          ol!.appendChild(li);
        });
        (toc as HTMLElement).style.display = '';
      })();
    </script>

    <div class="prose">
      <FAQ faqs={d.faqs} heading="Key takeaways & quick answers" />
    </div>

    <div class="prose">
      <div class="review-standard">
        <span class="lbl lbl-accent">// Review standard</span>
        <h4>How this guide treats reviews and ratings</h4>
        <p>We use official spec pages for hard claims, our product database for editorial scores, and community research for recurring buyer warnings. Marketplace star ratings change constantly, so use the Amazon/seller links in the product cards to verify the current rating, return window, and low-star complaints before you buy.</p>
        {articleProducts.length > 0 && (
          <div class="review-links">
            {articleProducts.slice(0, 4).map((p: any) => (
              <a href={buyUrl(p)} target="_blank" rel="sponsored nofollow noopener" data-event="article_review_check">Check live reviews: {p.brand} {p.model} ↗</a>
            ))}
          </div>
        )}
      </div>
      <div class="cfg-cta">
        <div>
          <span class="lbl lbl-accent">// Check the parts</span>
          <h4 style="margin-top:6px">Inspect the {bay.name.toLowerCase()} gear bench</h4>
          <p>Open the product pages behind this guide for specs, caveats, live review checks, and buy links before you commit money.</p>
        </div>
        <a class="btn btn-primary" href={`/${d.bay}/gear`}>Browse {bay.name} gear ▸</a>
      </div>
      <p class="disclosure">{site.disclosure}</p>
    </div>

    {related.length > 0 && (
      <section class="sec" style="max-width:1000px;margin:0 auto">
        <div class="sec-head"><h2>Keep reading</h2></div>
        <div class="card-grid">
          {related.map((a) => (
            <ArticleCard href={`/${a.data.bay}/${a.id.split('/').pop()}`} title={a.data.title}
              excerpt={a.data.excerpt || a.data.description} type={a.data.type}
              image={a.data.heroImage} imageAlt={a.data.heroAlt}
              meta={`${a.data.bay.toUpperCase()} · ${a.data.readingTime || 6} min read`} />
          ))}
        </div>
      </section>
    )}
  </article>
</Base>

<style>
  .article-evidence {
    max-width: 1000px;
    margin: 24px auto 28px;
    display: grid;
    gap: 16px;
  }
  .reality-grid {
    display: grid;
    grid-template-columns: 1.25fr repeat(3, 1fr);
    gap: 12px;
  }
  .reality-main,
  .reality-note,
  .parts-bench,
  .source-shelf,
  .review-standard {
    border: 1px solid var(--line2);
    border-radius: 14px;
    background: #fff;
    box-shadow: 0 12px 30px rgba(15, 23, 42, .06);
  }
  .reality-main { padding: 20px 22px; }
  .reality-main h2 { font-size: 1.35rem; margin: 7px 0 8px; }
  .reality-main p,
  .reality-note p,
  .parts-bench p,
  .review-standard p { color: #334155; font-size: .92rem; line-height: 1.6; }
  .reality-note { padding: 18px; border-left: 4px solid var(--accent); }
  .reality-note span {
    display: block;
    font-family: var(--font-mono);
    color: var(--accent);
    text-transform: uppercase;
    letter-spacing: .12em;
    font-size: .58rem;
    margin-bottom: 8px;
  }
  .parts-bench { padding: 18px; }
  .bench-head { display: flex; justify-content: space-between; gap: 18px; align-items: end; margin-bottom: 14px; flex-wrap: wrap; }
  .bench-head p { max-width: 60ch; font-size: .82rem; margin: 0; }
  .bench-products {
    display: grid;
    grid-template-columns: repeat(5, minmax(0, 1fr));
    gap: 10px;
  }
  .bench-product {
    color: inherit;
    display: flex;
    flex-direction: column;
    gap: 4px;
    border: 1px solid var(--line);
    border-radius: 12px;
    padding: 10px;
    background: var(--panel2);
  }
  .bench-product:hover { border-color: var(--accent); background: #fff; }
  .bench-product img {
    width: 100%;
    aspect-ratio: 1 / 1;
    object-fit: contain;
    background: #fff;
    border-radius: 8px;
    border: 1px solid var(--line);
  }
  .bench-spec {
    width: 100%;
    aspect-ratio: 1 / 1;
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 6px;
    background: #fff;
    border-radius: 8px;
    border: 1px solid var(--line);
    padding: 10px;
  }
  .bench-spec b { font-family: var(--font-disp); color: var(--txt); line-height: 1; }
  .bench-spec em { font-style: normal; color: var(--dim); font-size: .74rem; line-height: 1.2; }
  .bench-product span,
  .bench-product small {
    font-family: var(--font-mono);
    font-size: .58rem;
    letter-spacing: .06em;
    color: var(--dim);
    text-transform: uppercase;
  }
  .bench-product strong { font-size: .88rem; line-height: 1.22; }
  .source-shelf { display: flex; justify-content: space-between; gap: 16px; padding: 15px 18px; align-items: center; flex-wrap: wrap; }
  .source-shelf div,
  .review-links { display: flex; flex-wrap: wrap; gap: 8px; }
  .source-shelf a,
  .review-links a {
    font-family: var(--font-mono);
    font-size: .64rem;
    letter-spacing: .04em;
    color: var(--accent);
    border: 1px solid var(--line2);
    border-radius: 999px;
    padding: 7px 10px;
    background: #fff;
  }
  .source-shelf a:hover,
  .review-links a:hover { border-color: var(--accent); }
  .review-standard { padding: 18px 20px; margin: 2em 0; }
  .review-standard h4 { margin: 8px 0; font-size: 1.1rem; }
  @media (max-width: 900px) {
    .reality-grid,
    .bench-products { grid-template-columns: 1fr 1fr; }
    .reality-main { grid-column: 1 / -1; }
  }
  @media (max-width: 620px) {
    .reality-grid,
    .bench-products { grid-template-columns: 1fr; }
  }
</style>
