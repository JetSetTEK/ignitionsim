---
import Base from '../../layouts/Base.astro';
import FAQ from '../../components/FAQ.astro';
import ArticleCard from '../../components/ArticleCard.astro';
import ArticleNextSteps from '../../components/ArticleNextSteps.astro';
import { getCollection, render } from 'astro:content';
import ShareButtons from '../../components/ShareButtons.astro';
import CuratorFieldBrief from '../../components/CuratorFieldBrief.astro';
import bays from '../../data/bays.json';
import site from '../../data/site.json';
import { articleMeta, isCertifiedArticle } from '../../lib/content';
import { displayProductImage, hasVerifiedProductImage } from '../../lib/productMedia';
import { getWorldForBay } from '../../lib/worlds';
import { getCuratorByName, crewSlug } from '../../lib/crew';

export async function getStaticPaths() {
  const articles = await getCollection('articles', ({ data }) => isCertifiedArticle(data));
  return articles.map((entry) => ({
    params: { bay: entry.data.bay, slug: entry.id.split('/').pop() },
    props: { entry },
  }));
}
const { entry } = Astro.props;
const { Content } = await render(entry);
const d = entry.data;
const bay = bays.find((b) => b.slug === d.bay)!;
const world = getWorldForBay(d.bay);
const slug = entry.id.split('/').pop();
const url = new URL(`/${d.bay}/${slug}/`, site.url).href;

const fmtDate = (x: Date) => new Date(x).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
const freshnessItems = [
  d.updatedDate ? `Updated ${fmtDate(d.updatedDate)}` : `Published ${fmtDate(d.publishDate)}`,
  d.sourceReviewDate ? `Sources reviewed ${fmtDate(d.sourceReviewDate)}` : '',
  d.goldCertifiedDate ? `Gold certified ${fmtDate(d.goldCertifiedDate)}` : '',
  d.revenueTier ? `Revenue tier ${d.revenueTier}` : '',
].filter(Boolean);

// Resolve the article author to a curator record for linked byline + author box.
const bylineCurator = getCuratorByName(d.author) as any;
const curatorHref = bylineCurator ? `/curator/${crewSlug(bylineCurator)}` : null;
const authorFirst = String(d.author).split(' ')[0];

// Related guides are scored instead of merely sliced so every article gets a
// strong internal path back into its bay, buying intent, and declared siblings.
const relatedIds = new Set((d.related || []).flatMap((item: string) => item.includes('/') ? [item, item.split('/').pop()] : [item, `${d.bay}/${item}`]));
const scoreRelated = (candidate: any) => {
  const cSlug = candidate.id.split('/').pop();
  let score = 0;
  if (relatedIds.has(candidate.id) || relatedIds.has(cSlug)) score += 100;
  if (candidate.data.bay === d.bay) score += 36;
  if (candidate.data.contentCluster && candidate.data.contentCluster === d.contentCluster) score += 24;
  if (candidate.data.revenueTier === d.revenueTier) score += 8;
  if (candidate.data.revenueTier === 'A') score += 12;
  if (candidate.data.featured) score += 8;
  if (candidate.data.type === d.type) score += 6;
  const fresh = +new Date(candidate.data.updatedDate || candidate.data.publishDate || 0);
  score += Math.max(0, Math.min(10, Math.floor((fresh - Date.UTC(2026, 0, 1)) / 1000 / 60 / 60 / 24 / 14)));
  return score;
};
const related = (await getCollection('articles', ({ data }) => isCertifiedArticle(data)))
  .filter((a) => a.id !== entry.id)
  .map((a) => ({ a, score: scoreRelated(a) }))
  .filter(({ score }) => score > 0)
  .sort((x, y) => y.score - x.score)
  .map(({ a }) => a)
  .slice(0, 4);

const typeLabel = d.type.replace(/-/g, ' ');
const worldHeroByBay: Record<string, { image: string; alt: string }> = {
  golf: {
    image: getWorldForBay('golf').image,
    alt: getWorldForBay('golf').alt,
  },
  racing: {
    image: getWorldForBay('racing').image,
    alt: getWorldForBay('racing').alt,
  },
  flight: {
    image: getWorldForBay('flight').image,
    alt: getWorldForBay('flight').alt,
  },
  space: {
    image: getWorldForBay('space').image,
    alt: getWorldForBay('space').alt,
  },
  marine: {
    image: getWorldForBay('marine').image,
    alt: getWorldForBay('marine').alt,
  },
};
let worldHero = worldHeroByBay[d.bay];
if (d.bay === 'golf' && /launch monitor|skytrak|garmin|mlm2pro|square/i.test(d.title)) {
  worldHero = {
    image: getWorldForBay('golf').image,
    alt: getWorldForBay('golf').alt,
  };
}
const prodMods = import.meta.glob('/src/data/products/*.json', { eager: true });
const allProducts = Object.values(prodMods).flatMap((m: any) => (m.default || m)) as any[];
const rankProduct = (p: any) => (p.rating?.overall || 0) * 100 + Math.min(p.price || 0, 3000) / 1000;
const productByPath = new Map(allProducts.map((p: any) => [`/${p.bay}/gear/${p.id}`, p]));
const linkedProductPaths = [...new Set([
  ...String(entry.body || '').matchAll(/href=["'](\/[a-z]+\/gear\/[a-z0-9-]+)["']/g),
  ...String(entry.body || '').matchAll(/\]\((\/[a-z]+\/gear\/[a-z0-9-]+)\)/g),
].map((match) => match[1]))];
const linkedProducts = linkedProductPaths
  .map((path) => productByPath.get(path))
  .filter((p) => p && hasVerifiedProductImage(p));
const fallbackProducts = allProducts
  .filter((p) => p.bay === d.bay && hasVerifiedProductImage(p))
  .sort((a, b) => rankProduct(b) - rankProduct(a))
  .slice(0, 5);
const articleProducts = (linkedProducts.length ? linkedProducts : fallbackProducts).slice(0, 5);
const heroProofProduct = articleProducts[0];
const heroProofImage = heroProofProduct ? displayProductImage(heroProofProduct) : '';
const fieldProofProduct = linkedProducts[0];
const fieldProof = fieldProofProduct ? {
  image: displayProductImage(fieldProofProduct),
  name: `${fieldProofProduct.brand} ${fieldProofProduct.model}`,
  href: `/${fieldProofProduct.bay}/gear/${fieldProofProduct.id}`,
} : null;
const articleHeroImage = d.heroImage || heroProofImage || worldHero?.image;
const articleHeroAlt = d.heroAlt || (heroProofProduct ? `${heroProofProduct.brand} ${heroProofProduct.model}` : worldHero?.alt || d.title);
const isWorldHero = Boolean(worldHero && articleHeroImage === worldHero.image);
const socialImage = d.heroImage || articleHeroImage || `/og/${d.bay}/${slug}.png`;

const schema: Record<string, any>[] = [
  {
    '@context': 'https://schema.org', '@type': 'Article',
    headline: d.title, description: d.description,
    image: new URL(socialImage, site.url).href,
    datePublished: new Date(d.publishDate).toISOString(),
    dateModified: new Date(d.updatedDate || d.publishDate).toISOString(),
    author: { '@type': 'Person', name: site.author.name, url: new URL('/about', site.url).href },
    contributor: { '@type': 'Thing', name: d.author, description: 'AI-assisted IgnitionSim editorial bench persona', url: new URL(curatorHref || '/curators', site.url).href },
    editor: { '@type': 'Person', name: site.author.name, url: new URL('/about', site.url).href },
    publisher: { '@type': 'Organization', name: site.name, logo: { '@type': 'ImageObject', url: new URL('/favicon.svg', site.url).href } },
    mainEntityOfPage: { '@type': 'WebPage', '@id': url },
    articleSection: `${bay.name} sim hardware`,
    keywords: d.primaryKeyword,
    about: [
      { '@type': 'Thing', name: `${bay.name} sim hardware` },
      ...articleProducts.slice(0, 4).map((p: any) => ({ '@type': 'Product', name: `${p.brand} ${p.model}` })),
    ],
  },
  {
    '@context': 'https://schema.org', '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: site.url },
      { '@type': 'ListItem', position: 2, name: `${bay.name} sim hardware`, item: new URL(`/${d.bay}`, site.url).href },
      { '@type': 'ListItem', position: 3, name: d.title, item: url },
    ],
  },
];
if (d.faqs.length) {
  schema.push({
    '@context': 'https://schema.org', '@type': 'FAQPage',
    mainEntity: d.faqs.map((f) => ({
      '@type': 'Question', name: f.q,
      acceptedAnswer: { '@type': 'Answer', text: f.a },
    })),
  });
}
---
<Base title={d.title} description={d.description} bay={d.bay} activeNav={d.bay} schema={schema}
      image={socialImage} ogType="article">
  <article class="wrap">
    <header class="article-topper" data-bay={d.bay} style={`--world-bg: url('${world.image}')`}>
      {articleHeroImage && <img src={articleHeroImage} alt={articleHeroAlt} loading="eager" decoding="async" />}
      <div class="article-topper-scrim"></div>
      {isWorldHero && <span class="ai-scene-badge">AI world scene</span>}
      <div class="article-topper-copy">
        <div class="crumbs article-crumbs"><a href="/">Home</a><span>/</span><a href={`/${d.bay}`}>{bay.name}</a><span>/</span>{typeLabel}</div>
        <span class="lbl lbl-accent">{typeLabel}</span>
        <h1>{d.title}</h1>
        <p class="article-deck">{d.description}</p>
        <p class="byline">Presented by {curatorHref ? <a class="byline-link" href={curatorHref}><b>{d.author}</b></a> : <b>{d.author}</b>} · Editorial responsibility: <a class="byline-link" href="/about"><b>{site.author.name}</b></a> · {fmtDate(d.publishDate)}{d.updatedDate ? ` · Updated ${fmtDate(d.updatedDate)}` : ''} · {d.readingTime || 7} min read</p>
        <p class="persona-disclosure">{d.author} is an AI-assisted editorial bench persona. Product claims, sources, and verdicts are reviewed under IgnitionSim's published methodology.</p>
        {freshnessItems.length > 0 && (
          <p class="article-freshness">
            {freshnessItems.map((item) => <span>{item}</span>)}
          </p>
        )}
        <div class="article-share"><ShareButtons /></div>
      </div>
      {isWorldHero && heroProofProduct && (
        <aside class="article-proof-chip">
          <span>Real product proof</span>
          <img src={displayProductImage(heroProofProduct)} alt={`${heroProofProduct.brand} ${heroProofProduct.model}`} loading="eager" decoding="async" />
          <b>{heroProofProduct.brand} {heroProofProduct.model}</b>
          <small>Verified photo. Live seller reviews below.</small>
        </aside>
      )}
    </header>

    <nav class="toc" id="article-toc" aria-label="On this page" style="display:none">
      <h4>On this page</h4>
      <ol></ol>
    </nav>

    {bylineCurator && <CuratorFieldBrief entry={entry} person={bylineCurator} proof={fieldProof} />}

    <div class="prose">
      <Content />
    </div>

    <script>
      (() => {
        const toc = document.getElementById('article-toc');
        const prose = document.querySelector('article .prose');
        if (!toc || !prose) return;
        const h2s = [...prose.querySelectorAll('h2')];
        if (h2s.length < 3) return;
        const ol = toc.querySelector('ol');
        h2s.forEach((h, i) => {
          if (!h.id) h.id = 'sec-' + (i + 1);
          const li = document.createElement('li');
          const a = document.createElement('a');
          a.href = '#' + h.id;
          a.textContent = h.textContent || ('Section ' + (i + 1));
          li.appendChild(a);
          ol!.appendChild(li);
        });
        (toc as HTMLElement).style.display = '';
      })();
    </script>

    <div class="prose">
      <FAQ faqs={d.faqs} heading="Key takeaways & quick answers" />
    </div>

    <div class="prose">
      <p class="disclosure">{site.disclosure}</p>
    </div>

    <ArticleNextSteps entry={entry} related={related} placement="bottom" />

    {bylineCurator && (
      <aside class="author-card" data-bay={d.bay}>
        <a class="author-portrait" href={curatorHref}>
          <img src={bylineCurator.image} alt={bylineCurator.alt} loading="lazy" decoding="async" />
        </a>
        <div class="author-copy">
          <span class="lbl lbl-accent">Bench perspective · {bylineCurator.handle}</span>
          <h3><a href={curatorHref}>{d.author}</a></h3>
          <p class="author-catch">&ldquo;{bylineCurator.catchphrase || bylineCurator.motto}&rdquo;</p>
          <p>{bylineCurator.authorBio}</p>
          <p class="persona-disclosure">AI-assisted editorial persona · research and final editorial responsibility: {site.author.name}.</p>
          <div class="author-tags">
            {(((bylineCurator.expertise || []) as string[]).slice(0, 4)).map((e) => <span>{e}</span>)}
          </div>
          <a class="btn btn-primary" href={curatorHref}>More from {authorFirst} &#9656;</a>
        </div>
      </aside>
    )}

    {related.length > 0 && (
      <section class="sec article-world-related" style={`--world-bg: url('${world.image}')`}>
        <div class="sec-head"><h2>Keep reading</h2></div>
        <div class="card-grid">
          {related.map((a) => (
            <ArticleCard href={`/${a.data.bay}/${a.id.split('/').pop()}`} title={a.data.title}
              excerpt={a.data.excerpt || a.data.description} type={a.data.type}
              image={a.data.heroImage} imageAlt={a.data.heroAlt}
              meta={articleMeta(a.data)} />
          ))}
        </div>
      </section>
    )}
  </article>
</Base>

<style>
  .byline-link { color: color-mix(in srgb, var(--accent) 82%, #fff); text-decoration: none; border-bottom: 1px solid color-mix(in srgb, var(--accent) 46%, transparent); }
  .byline-link:hover { color: #fff; }
  .persona-disclosure { max-width: 76ch; margin: 8px 0 0; color: rgba(255,255,255,.74); font-size: .78rem; line-height: 1.45; }
  .article-freshness {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    max-width: 72ch;
    margin: 12px 0 0;
  }
  .article-freshness span {
    display: inline-flex;
    align-items: center;
    min-height: 28px;
    padding: 6px 10px;
    border: 1px solid color-mix(in srgb, var(--accent) 48%, rgba(255,255,255,.26));
    border-radius: 999px;
    background: rgba(255,255,255,.9);
    color: #101820;
    font-family: var(--font-mono);
    font-size: .58rem;
    font-weight: 900;
    letter-spacing: .08em;
    text-transform: uppercase;
    box-shadow: 0 8px 20px rgba(16,24,32,.18);
  }
  .author-card {
    max-width: 1000px; margin: 30px auto; display: grid; grid-template-columns: 150px 1fr; gap: 22px; align-items: center;
    padding: 22px; border: 2px solid color-mix(in srgb, var(--accent) 30%, rgba(16,24,32,.14)); border-radius: 22px;
    background: linear-gradient(135deg, color-mix(in srgb, var(--accent) 8%, #fff), #fff 60%);
    box-shadow: 0 10px 0 rgba(16,24,32,.07), 0 30px 60px rgba(16,24,32,.08);
  }
  .author-portrait { display: block; overflow: hidden; border-radius: 16px; border: 2px solid color-mix(in srgb, var(--accent) 34%, rgba(16,24,32,.14)); background: #101820; }
  .author-portrait img { display: block; width: 100%; aspect-ratio: 4 / 4.6; object-fit: cover; object-position: center top; }
  .author-copy h3 { margin: 6px 0; font-size: 1.5rem; }
  .author-copy h3 a { color: #101820; text-decoration: none; }
  .author-copy .author-catch { color: color-mix(in srgb, var(--accent) 58%, #101820); font-weight: 800; font-style: italic; }
  .author-copy > p { color: #334155; line-height: 1.6; margin-top: 6px; }
  .author-tags { display: flex; flex-wrap: wrap; gap: 8px; margin: 12px 0 14px; }
  .author-tags span { padding: 6px 11px; border: 1px solid color-mix(in srgb, var(--accent) 34%, var(--line)); border-radius: 999px; background: color-mix(in srgb, var(--accent) 7%, #fff); font-size: .74rem; font-weight: 700; color: #223; }
  @media (max-width: 640px) { .author-card { grid-template-columns: 1fr; } .author-portrait { max-width: 180px; } }

  .article-evidence {
    max-width: 1000px;
    margin: 24px auto 28px;
    display: grid;
    gap: 16px;
    position: relative;
    padding: 22px;
    overflow: hidden;
    border: 2px solid color-mix(in srgb, var(--accent) 34%, rgba(16,24,32,.16));
    border-radius: 28px;
    background:
      radial-gradient(760px 340px at 86% 6%, color-mix(in srgb, var(--accent) 22%, transparent), transparent 70%),
      linear-gradient(90deg, rgba(16,24,32,.92), rgba(16,24,32,.5)),
      var(--world-bg) center / cover no-repeat;
    box-shadow: 0 14px 0 rgba(16,24,32,.14), 0 38px 82px color-mix(in srgb, var(--accent) 14%, transparent);
  }
  .article-evidence::after,
  .visual-proof-wall::after,
  .article-world-related::after {
    content: "";
    position: absolute;
    inset: 0;
    pointer-events: none;
    background:
      linear-gradient(rgba(255,255,255,.055) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255,255,255,.04) 1px, transparent 1px);
    background-size: 46px 46px;
    opacity: .34;
    mix-blend-mode: screen;
  }
  .article-evidence > *,
  .visual-proof-wall > *,
  .article-world-related > * {
    position: relative;
    z-index: 1;
  }
  .article-topper {
    position: relative;
    min-height: 680px;
    display: flex;
    align-items: flex-end;
    margin: 28px auto 30px;
    overflow: hidden;
    border: 2px solid #101820;
    border-radius: 24px;
    box-shadow: 0 12px 0 rgba(16,24,32,.2), 0 36px 82px color-mix(in srgb, var(--accent) 18%, transparent);
  }
  .article-topper > img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .article-topper-scrim {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(820px 420px at 80% 10%, color-mix(in srgb, var(--accent) 18%, transparent), transparent 72%),
      linear-gradient(90deg, rgba(16,24,32,.94), rgba(16,24,32,.58) 48%, rgba(16,24,32,.14)),
      linear-gradient(180deg, rgba(16,24,32,.08), rgba(16,24,32,.68));
  }
  .article-topper-copy {
    position: relative;
    z-index: 2;
    width: 100%;
    max-width: 780px;
    padding: 42px;
    color: #fff;
  }
  .article-crumbs,
  .article-crumbs a {
    color: rgba(255,255,255,.72);
  }
  .article-topper-copy h1 {
    margin: 12px 0 16px;
    color: #fff;
    font-size: clamp(2.1rem, 4.8vw, 3.7rem);
    line-height: 1;
    text-transform: uppercase;
  }
  .article-deck {
    color: rgba(255,255,255,.88);
    font-size: 1.05rem;
    line-height: 1.6;
    max-width: 66ch;
  }
  .article-topper-note {
    margin-top: 20px;
    max-width: 620px;
    padding: 16px 18px;
    border: 1px solid rgba(255,255,255,.28);
    border-left: 5px solid var(--accent);
    border-radius: 12px;
    background: rgba(255,255,255,.12);
    -webkit-backdrop-filter: blur(10px);
    backdrop-filter: blur(10px);
  }
  .article-topper-note b {
    display: block;
    font-family: var(--font-disp);
    color: #fff;
    font-size: 1.22rem;
    line-height: 1.15;
  }
  .article-topper-note p {
    margin-top: 8px;
    color: rgba(255,255,255,.84);
    font-size: .92rem;
    line-height: 1.55;
  }
  .article-topper-note small {
    display: inline-block;
    margin-top: 12px;
    padding: 9px 12px;
    border-radius: 999px;
    background: rgba(255,255,255,.9);
    color: #101820;
    font-family: var(--font-mono);
    font-size: .68rem;
    font-weight: 900;
    letter-spacing: .03em;
  }
  .article-topper .byline {
    margin-top: 16px;
    color: rgba(255,255,255,.72);
  }
  .article-topper .byline b { color: rgba(255,255,255,.92); }
  .article-share { margin-top: 14px; }
  .article-proof-chip {
    position: absolute;
    right: 28px;
    bottom: 28px;
    z-index: 3;
    width: 220px;
    padding: 12px;
    border: 1px solid rgba(255,255,255,.3);
    border-radius: 14px;
    background: rgba(255,255,255,.92);
    color: #101820;
    box-shadow: 0 8px 0 rgba(16,24,32,.18);
    -webkit-backdrop-filter: blur(10px);
    backdrop-filter: blur(10px);
  }
  .article-proof-chip span,
  .article-proof-chip small {
    display: block;
    font-family: var(--font-mono);
    font-size: .52rem;
    letter-spacing: .08em;
    text-transform: uppercase;
    color: #5d6a76;
  }
  .article-proof-chip img {
    display: block;
    width: 100%;
    aspect-ratio: 4 / 3;
    object-fit: contain;
    margin: 8px 0;
    border-radius: 9px;
    border: 1px solid rgba(16,24,32,.12);
    background: #fff;
  }
  .article-proof-chip b {
    display: block;
    font-size: .9rem;
    line-height: 1.14;
  }
  .article-proof-chip small {
    margin-top: 6px;
    line-height: 1.35;
    letter-spacing: .04em;
    color: #435363;
  }
  .reality-grid {
    display: grid;
    grid-template-columns: 1.25fr repeat(3, 1fr);
    gap: 12px;
  }
  .reality-main,
  .reality-note,
  .parts-bench,
  .source-shelf,
  .review-standard {
    border: 1px solid rgba(255,255,255,.28);
    border-radius: 14px;
    background: rgba(255,255,255,.92);
    box-shadow: 0 12px 30px rgba(15, 23, 42, .12);
    -webkit-backdrop-filter: blur(8px);
    backdrop-filter: blur(8px);
  }
  .reality-main { padding: 20px 22px; }
  .reality-main h2 { font-size: 1.35rem; margin: 7px 0 8px; }
  .reality-main p,
  .reality-note p,
  .parts-bench p,
  .review-standard p { color: #334155; font-size: .92rem; line-height: 1.6; }
  .reality-note { padding: 18px; border-left: 4px solid var(--accent); }
  .reality-note span {
    display: block;
    font-family: var(--font-mono);
    color: var(--accent);
    text-transform: uppercase;
    letter-spacing: .12em;
    font-size: .58rem;
    margin-bottom: 8px;
  }
  .parts-bench { padding: 22px; overflow: hidden; }
  .bench-head {
    display: flex;
    justify-content: space-between;
    gap: 18px;
    align-items: end;
    margin-bottom: 18px;
    flex-wrap: wrap;
  }
  .bench-head h2 { margin-top: 7px; font-size: clamp(1.45rem, 3vw, 2.1rem); }
  .bench-head p { max-width: 58ch; font-size: .9rem; margin: 0; }
  .product-theater {
    width: 100%;
    max-width: 100%;
    min-width: 0;
    display: grid;
    grid-auto-flow: column;
    grid-auto-columns: minmax(330px, 42%);
    gap: 16px;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    padding: 4px 2px 18px;
    -ms-overflow-style: none;
    scrollbar-width: none;
  }
  .product-theater::-webkit-scrollbar { display: none; }
  .theater-card {
