---
import Base from '../layouts/Base.astro';
import credits from '../data/photo-credits.json';
const bySource: Record<string, any[]> = {};
(credits as any[]).forEach((c) => { (bySource[c.source] = bySource[c.source] || []).push(c); });
---
<Base title="Photo Credits" description="Attribution for licensed photography used on IgnitionSim.">
  <div class="wrap">
    <div class="crumbs"><a href="/">Home</a><span>/</span>Photo credits</div>
    <div class="prose" style="padding-top:24px">
      <h1>Photo credits</h1>
      <p>IgnitionSim uses a mix of original art and licensed photography. Where we use Creative-Commons or stock photography that requires attribution, the photographers are credited below, as their licenses require. Product specs, ratings and editorial are our own.</p>
      {(credits as any[]).length === 0 ? (
        <p style="color:var(--dim)">Licensed third-party photography hasn't been added yet — most imagery here is original. Credits will appear here automatically as licensed photos are added.</p>
      ) : (
        Object.entries(bySource).map(([source, list]) => (
          <>
            <h2>{source}</h2>
            <ul>
              {list.map((c) => (
                <li>Photo by <a href={c.url} target="_blank" rel="noopener nofollow">{c.photographer}</a> on {c.source}{c.query ? ` (${c.query})` : ''}</li>
              ))}
            </ul>
          </>
        ))
      )}
    </div>
  </div>
</Base>
