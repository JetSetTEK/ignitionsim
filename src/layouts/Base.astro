---
import site from '../data/site.json';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  bay?: 'racing' | 'flight' | 'space' | 'marine' | 'golf' | null;
  image?: string;                 // OG image path (absolute or site-relative)
  noindex?: boolean;
  schema?: Record<string, any>[]; // extra JSON-LD blocks for this page
  activeNav?: string;
}
const {
  title,
  description = site.descriptor,
  bay = null,
  image = '/og-default.png',
  noindex = false,
  schema = [],
  activeNav,
} = Astro.props;

const canonical = new URL(Astro.url.pathname, site.url).href.replace(/\/$/, '') || site.url;
const ogImage = image.startsWith('http') ? image : new URL(image, site.url).href;
const fullTitle = title === site.name ? `${site.name} — ${site.descriptor}` : `${title} · ${site.name}`;

// Organization + WebSite schema render on every page
const orgSchema = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: site.name,
  url: site.url,
  slogan: site.tagline,
  description: site.descriptor,
  logo: new URL('/favicon.svg', site.url).href,
  founder: { '@type': 'Person', name: site.author.name },
};
const siteSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: site.name,
  url: site.url,
  description: site.descriptor,
};
const allSchema = [orgSchema, siteSchema, ...schema];
---
<!DOCTYPE html>
<html lang="en" data-bay={bay ?? undefined}>
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{fullTitle}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonical} />
  {noindex && <meta name="robots" content="noindex, nofollow" />}
  <meta name="theme-color" content="#0A0E17" />
  <meta name="author" content={site.author.name} />
  <meta name="generator" content={Astro.generator} />

  <!-- Open Graph -->
  <meta property="og:type" content="website" />
  <meta property="og:site_name" content={site.name} />
  <meta property="og:title" content={fullTitle} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={canonical} />
  <meta property="og:image" content={ogImage} />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={fullTitle} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={ogImage} />

  <!-- Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Saira:wght@500;600;700;800&family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500;700&display=swap" rel="stylesheet" />

  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="apple-touch-icon" href="/favicon.svg" />
  <link rel="sitemap" href="/sitemap-index.xml" />
  <link rel="alternate" type="application/rss+xml" title={`${site.name} — Drops & Deals`} href="/feeds/drops.xml" />

  {allSchema.map((s) => (
    <script type="application/ld+json" set:html={JSON.stringify(s)} />
  ))}
</head>
<body data-bay={bay ?? undefined}>
  <div class="grid-bg"></div>
  <Header activeNav={activeNav} />
  <main>
    <slot />
  </main>
  <Footer />
  <div class="toast" id="toast"></div>
  <script>
    // shared toast helper
    (window as any).toast = (m: string) => {
      const t = document.getElementById('toast');
      if (!t) return;
      t.textContent = m; t.classList.add('show');
      clearTimeout((window as any)._tt);
      (window as any)._tt = setTimeout(() => t.classList.remove('show'), 2400);
    };
  </script>
</body>
</html>
