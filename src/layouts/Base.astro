---
import site from '../data/site.json';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';
import CrewChat from '../components/CrewChat.astro';
import { getCollection } from 'astro:content';
import { articleSlug, isCertifiedArticle, sortNewestArticles } from '../lib/content';
import { getCrewForBay } from '../lib/crew';

interface Props {
  title: string;
  description?: string;
  bay?: 'racing' | 'flight' | 'space' | 'marine' | 'golf' | null;
  image?: string;                 // OG image path (absolute or site-relative)
  ogType?: 'website' | 'article';
  noindex?: boolean;
  schema?: Record<string, any>[]; // extra JSON-LD blocks for this page
  activeNav?: string;
}
const {
  title,
  description = site.descriptor,
  bay = null,
  image = '/og-default.png',
  ogType = 'website',
  noindex = false,
  schema = [],
  activeNav,
} = Astro.props;

const canonicalPath = Astro.url.pathname === '/' || Astro.url.pathname.endsWith('/')
  ? Astro.url.pathname
  : `${Astro.url.pathname}/`;
const canonical = new URL(canonicalPath, site.url).href;
const ogImage = image.startsWith('http') ? image : new URL(image, site.url).href;
const fullTitle = title === site.name ? `${site.name} — ${site.descriptor}` : `${title} · ${site.name}`;
const ga4MeasurementId = site.analytics?.ga4MeasurementId || (site.analytics?.provider === 'ga4' ? site.analytics.websiteId : '');
const googleSiteVerification = site.analytics?.googleSiteVerification || '';

// Organization + WebSite schema render on every page
const orgSchema = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: site.name,
  url: site.url,
  slogan: site.tagline,
  description: site.descriptor,
  logo: new URL('/favicon.svg', site.url).href,
  founder: { '@type': 'Person', name: site.author.name },
};
const siteSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: site.name,
  url: site.url,
  description: site.descriptor,
};
const allSchema = [orgSchema, siteSchema, ...schema];
const chatPerson = getCrewForBay(bay || 'racing') as any;
const currentArticleSlug = Astro.url.pathname.split('/').filter(Boolean).at(-1) || '';
const certifiedArticles = await getCollection('articles', ({ data }) => isCertifiedArticle(data));
const currentArticle = certifiedArticles.find((entry) => entry.data.bay === bay && articleSlug(entry) === currentArticleSlug);
const chatContext = currentArticle ? {
  title: currentArticle.data.title,
  summary: currentArticle.data.excerpt || currentArticle.data.description,
  type: currentArticle.data.type,
  updated: (currentArticle.data.updatedDate || currentArticle.data.publishDate).toISOString().slice(0, 10),
} : null;
const chatRecommendations = sortNewestArticles(certifiedArticles)
  .filter((entry) => entry.data.bay === (bay || 'racing') && articleSlug(entry) !== currentArticleSlug)
  .slice(0, 3)
  .map((entry) => ({ label: entry.data.title, href: `/${entry.data.bay}/${articleSlug(entry)}` }));
---
<!DOCTYPE html>
<html lang="en" data-bay={bay ?? undefined}>
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{fullTitle}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonical} />
  {noindex && <meta name="robots" content="noindex, nofollow" />}
  <meta name="theme-color" content="#0A0E17" />
  <meta name="author" content={site.author.name} />
  <meta name="generator" content={Astro.generator} />
  {googleSiteVerification && <meta name="google-site-verification" content={googleSiteVerification} />}

  <!-- Open Graph -->
  <meta property="og:type" content={ogType} />
  <meta property="og:site_name" content={site.name} />
  <meta property="og:title" content={fullTitle} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={canonical} />
  <meta property="og:image" content={ogImage} />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={fullTitle} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={ogImage} />

  <!-- Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Saira:wght@500;600;700;800&family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500;700&display=swap" rel="stylesheet" />

  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="apple-touch-icon" href="/favicon.svg" />
  <link rel="sitemap" href="/sitemap-index.xml" />
  <link rel="alternate" type="application/rss+xml" title="IgnitionSim — New Simulator Buyer Guides" href="/rss.xml" />

  {allSchema.map((s) => (
    <script type="application/ld+json" set:html={JSON.stringify(s)} />
  ))}

  {site.analytics?.provider === 'umami' && site.analytics.src && (
    <script is:inline defer src={site.analytics.src} data-website-id={site.analytics.websiteId}></script>
  )}
  {site.analytics?.provider === 'plausible' && site.analytics.src && (
    <script is:inline defer data-domain={site.analytics.websiteId} src={site.analytics.src}></script>
  )}
  {ga4MeasurementId && (
    <script async src={`https://www.googletagmanager.com/gtag/js?id=${encodeURIComponent(ga4MeasurementId)}`}></script>
  )}
  {ga4MeasurementId && (
    <script is:inline define:vars={{ ga4MeasurementId }}>
      window.dataLayer = window.dataLayer || [];
      function gtag(){ dataLayer.push(arguments); }
      window.gtag = gtag;
      gtag('js', new Date());
      gtag('config', ga4MeasurementId, { send_page_view: true });
    </script>
  )}

  {/* Amazon OneLink — international link localization. Paste the snippet from
      Associates Central → Tools → OneLink into site.json affiliate.amazonOneLinkScript */}
  {site.affiliate?.amazonOneLinkScript && <Fragment set:html={site.affiliate.amazonOneLinkScript} />}
</head>
<body data-bay={bay ?? undefined}>
  <div class="grid-bg"></div>
  <div class="read-progress" id="readbar"></div>
  <Header activeNav={activeNav} />
  <main>
    <slot />
  </main>
  <Footer />
  {!Astro.url.pathname.startsWith('/curator/') && <CrewChat person={chatPerson} recommendations={chatRecommendations} context={chatContext} />}
  <div class="toast" id="toast"></div>
  <div class="lightbox" id="lightbox" aria-hidden="true">
    <button class="lb-close" aria-label="Close image">×</button>
    <button class="lb-nav prev" aria-label="Previous image">‹</button>
    <img alt="" />
    <button class="lb-nav next" aria-label="Next image">›</button>
    <div class="lb-cap"></div>
  </div>
  <script>
    // lightbox — click any framed/product/article image to expand
    (() => {
      const lb = document.getElementById('lightbox'); if (!lb) return;
      const lbImg = lb.querySelector('img') as HTMLImageElement;
      const cap = lb.querySelector('.lb-cap') as HTMLElement;
      const prev = lb.querySelector('.lb-nav.prev') as HTMLElement;
      const next = lb.querySelector('.lb-nav.next') as HTMLElement;
      let group: string[] = [], gi = 0, caption = '';
      const show = () => { lbImg.src = group[gi]; lbImg.alt = caption; cap.textContent = caption + (group.length > 1 ? `  ·  ${gi + 1}/${group.length}` : ''); const multi = group.length > 1; prev.style.display = next.style.display = multi ? '' : 'none'; };
      const open = (list: string[], idx: number, capText: string) => { group = list; gi = idx; caption = capText; lb.classList.add('open'); lb.setAttribute('aria-hidden', 'false'); show(); };
      const close = () => { lb.classList.remove('open'); lb.setAttribute('aria-hidden', 'true'); lbImg.src = ''; };
      const nav = (d: number) => { if (group.length < 2) return; gi = (gi + d + group.length) % group.length; show(); };
      document.addEventListener('click', (e) => {
        const tgt = e.target as HTMLElement;
        if (tgt.closest('#lightbox .lb-close')) { close(); return; }
        if (tgt.closest('#lightbox .lb-nav.next')) { nav(1); return; }
        if (tgt.closest('#lightbox .lb-nav.prev')) { nav(-1); return; }
        if (tgt.id === 'lightbox') { close(); return; }
        const img = tgt.closest('[data-lightbox] img, .prose img, .pano img, img.zoomable') as HTMLImageElement | null;
        // linked images (e.g. inline gear-pick product shots) should follow their link, not zoom
        if (img && img.closest('a') && !img.classList.contains('zoomable')) return;
        if (img && img.tagName === 'IMG') {
          const cont = img.closest('[data-images]') as HTMLElement | null;
          let list = [img.currentSrc || img.src], idx = 0;
          if (cont) { try { const arr = JSON.parse(cont.dataset.images || '[]'); if (arr.length) { list = arr; idx = Math.max(0, arr.indexOf(img.getAttribute('src'))); } } catch {} }
          open(list, idx, img.alt || '');
        }
      });
      document.addEventListener('keydown', (e) => { if (!lb.classList.contains('open')) return; if (e.key === 'Escape') close(); else if (e.key === 'ArrowRight') nav(1); else if (e.key === 'ArrowLeft') nav(-1); });
    })();
  </script>
  <script>
    // shared toast helper
    (window as any).toast = (m: string) => {
      const t = document.getElementById('toast');
      if (!t) return;
      t.textContent = m; t.classList.add('show');
      clearTimeout((window as any)._tt);
      (window as any)._tt = setTimeout(() => t.classList.remove('show'), 2400);
    };
  </script>
  <script>
    // reading progress bar
    (() => {
      const bar = document.getElementById('readbar');
      if (!bar) return;
      const onScroll = () => {
        const h = document.documentElement;
        const max = h.scrollHeight - h.clientHeight;
        bar.style.width = max > 0 ? (h.scrollTop / max) * 100 + '%' : '0%';
      };
      document.addEventListener('scroll', onScroll, { passive: true });
      onScroll();
    })();
    // scroll reveal — class added here so no-JS users always see content
    (() => {
      if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;
      const targets = document.querySelectorAll('main .sec, main .feat, main .band, main .portal-grid, main .card-grid, main .statband, main .marquee, main .rigfinder, main .pslider, main .cfg-cta');
      const io = new IntersectionObserver((entries) => {
        entries.forEach((e) => { if (e.isIntersecting) { e.target.classList.add('in'); io.unobserve(e.target); } });
      }, { threshold: 0.12, rootMargin: '0px 0px -40px 0px' });
      targets.forEach((t) => { t.classList.add('reveal'); io.observe(t); });
    })();
    // analytics event helper (no-op until a provider is configured) + delegation
    (() => {
      const normEventName = (value: string) =>
        String(value || '')
          .trim()
          .toLowerCase()
          .replace(/[^a-z0-9]+/g, '_')
          .replace(/^_+|_+$/g, '')
          .slice(0, 40) || 'event';
      const datasetParams = (el: HTMLElement | null) => {
        const out: Record<string, string> = {};
        if (!el) return out;
        for (const [key, value] of Object.entries(el.dataset)) {
          if (!key.startsWith('event') || key === 'event') continue;
          const param = key.replace(/^event/, '').replace(/^[A-Z]/, (m) => m.toLowerCase()).replace(/[A-Z]/g, (m) => `_${m.toLowerCase()}`);
          if (param) out[param] = String(value || '').slice(0, 160);
        }
        return out;
      };
      (window as any).ig = {
        track: (event: string, data?: any) => {
          try {
            const eventName = normEventName(event);
            const payload = {
              page_path: location.pathname,
              page_title: document.title,
              ...(data || {}),
            };
            const u = (window as any).umami;
            const p = (window as any).plausible;
            const g = (window as any).gtag;
            if (u && u.track) u.track(eventName, payload);
            if (p) p(eventName, { props: payload });
            if (g) g('event', eventName, payload);
          } catch {}
        },
      };
      document.addEventListener('click', (e) => {
        const el = (e.target as HTMLElement).closest('[data-event], a[rel~="sponsored"], a[href^="/racing/"], a[href^="/golf/"], a[href^="/flight/"], a[href^="/space/"], a[href^="/marine/"], a[href^="/games"], a[href^="/build-stream"], a[href^="/guides"]') as HTMLElement | null;
        if (!el) return;
        const link = el instanceof HTMLAnchorElement ? el : (el.closest('a') || el.querySelector('a[href]'));
        const sponsored = !!(link && link.rel && link.rel.split(/\s+/).includes('sponsored'));
        const eventName = el.dataset.event || (sponsored ? 'buy_click' : 'internal_recommendation_click');
        (window as any).ig.track(eventName, link ? {
          href: link.href,
          text: link.textContent?.trim().replace(/\s+/g, ' ').slice(0, 120),
          outbound: link.origin !== location.origin,
          ...datasetParams(el),
        } : datasetParams(el));
      }, { capture: true });
      document.addEventListener('submit', (e) => {
        const form = e.target as HTMLFormElement | null;
        if (!form || !form.matches('form[data-netlify="true"]')) return;
        (window as any).ig.track('newsletter_signup', {
          form_name: form.getAttribute('name') || form.querySelector('input[name="form-name"]')?.getAttribute('value') || 'newsletter',
          page_path: location.pathname,
        });
      }, { capture: true });
      const sent: Record<number, boolean> = {};
      const marks = [25, 50, 75, 90];
      const onScrollDepth = () => {
        const h = document.documentElement;
        const max = h.scrollHeight - h.clientHeight;
        if (max <= 0) return;
        const pct = Math.floor((h.scrollTop / max) * 100);
        marks.forEach((mark) => {
          if (sent[mark] || pct < mark) return;
          sent[mark] = true;
          (window as any).ig.track('scroll_depth', { percent: mark, page_path: location.pathname });
        });
      };
      document.addEventListener('scroll', onScrollDepth, { passive: true });
      onScrollDepth();
      let engagedSent = false;
      const sendEngaged = (trigger: string) => {
        if (engagedSent) return;
        engagedSent = true;
        (window as any).ig.track('engaged_reader_45s', { trigger });
      };
      window.setTimeout(() => sendEngaged('timer'), 45000);
      document.addEventListener('click', (event) => {
        const target = event.target as HTMLElement | null;
        if (target?.closest('.article-next, .river-card, .latest-slide, .brief-card')) sendEngaged('next_step');
      }, { capture: true });
    })();
  </script>
</body>
</html>
