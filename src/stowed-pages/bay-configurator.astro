---
import Base from '../layouts/Base.astro';
import BaySetup from '../components/BaySetup.astro';
import bays from '../data/bays.json';
import configs from '../data/build-configs.json';
import site from '../data/site.json';

// Stowed from public routing until the builder data and UX meet the IgnitionSim Gold Standard.
export async function getStaticPaths() {
  // racing has its own dedicated compatibility-engine configurator
  return bays.filter((b) => b.slug !== 'racing').map((b) => ({ params: { bay: b.slug }, props: { bay: b } }));
}
const { bay } = Astro.props;
const cfg = (configs as any)[bay.slug];
const title = `${cfg?.title || bay.name + ' Builder'} — spec your ${bay.name.toLowerCase()} setup`;
const description = cfg?.intro || `Build your ${bay.name.toLowerCase()} sim setup with live pricing and compatibility notes.`;

const schema = [
  {
    '@context': 'https://schema.org', '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: site.url },
      { '@type': 'ListItem', position: 2, name: `${bay.name} sim hardware`, item: new URL(`/${bay.slug}`, site.url).href },
      { '@type': 'ListItem', position: 3, name: cfg?.title || 'Builder', item: new URL(`/${bay.slug}/configurator`, site.url).href },
    ],
  },
  {
    '@context': 'https://schema.org', '@type': 'WebApplication',
    name: `IgnitionSim ${cfg?.title || bay.name + ' Builder'}`, applicationCategory: 'UtilitiesApplication',
    operatingSystem: 'Web', url: new URL(`/${bay.slug}/configurator`, site.url).href,
    offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' }, description,
  },
];
---
<Base title={title} description={description} bay={bay.slug} activeNav={bay.slug} schema={schema} image={`/images/${bay.slug}/hero.jpg`} noindex={true}>
  <div class="wrap">
    <div class="crumbs"><a href="/">Home</a><span>/</span><a href={`/${bay.slug}`}>{bay.name}</a><span>/</span>Builder</div>
    <section class="hero" style="padding:36px 0 8px;text-align:left">
      <div class="lbl lbl-accent">// {bay.name} build tool</div>
      <h1 style="font-size:clamp(2rem,5vw,3rem);max-width:20ch;margin:12px 0">{cfg?.title || `${bay.name} Builder`}</h1>
      <p style="margin:0;max-width:64ch">{cfg?.intro}</p>
    </section>

    <BaySetup bay={bay.slug} />

    <div class="byline" style="text-align:center;margin:16px 0">Pricing is approximate and changes often · curated by <b>{site.author.name}</b></div>

    <section class="cfg-cta">
      <div><span class="lbl lbl-accent">// Go deeper</span><h4 style="margin-top:6px">Read the full breakdown on any part</h4><p>Every product here has a deep gear page — specs, ratings, pros and cons, and a verdict.</p></div>
      <a class="btn btn-primary btn-lg" href={`/${bay.slug}/gear`}>Browse {bay.name} gear ▸</a>
    </section>
  </div>
</Base>
