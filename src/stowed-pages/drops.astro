---
import Base from '../layouts/Base.astro';
import site from '../data/site.json';
import events from '../data/events.json';
import bays from '../data/bays.json';

// Stowed from public routing until drops are backed by live, verified product data.
const sorted = [...(events as any[])].sort((a, b) => +new Date(b.date) - +new Date(a.date));
const typeMeta: Record<string, { label: string; cls: string }> = {
  NEW: { label: '✦ New', cls: 'green' }, RESTOCK: { label: '● Restock', cls: 'green' },
  PRICE_DROP: { label: '▼ Price drop', cls: 'ember' }, SOLD_OUT: { label: '○ Sold out', cls: 'red' },
  UPDATE: { label: '↻ Update', cls: 'cyan' },
};
const fmt = (d: string) => new Date(d).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });

const schema = [{
  '@context': 'https://schema.org', '@type': 'ItemList', name: 'IgnitionSim sim-hardware drops & market moves',
  itemListElement: sorted.slice(0, 25).map((e, i) => ({ '@type': 'ListItem', position: i + 1, name: e.title })),
}];
---
<Base title="Stock & Deal Tracker — sim hardware drops & market moves" description="New releases, price drops and restocks across sim racing, flight, space, marine and golf hardware. Automated tracking + curated market intel." activeNav="drops" schema={schema} noindex={true}>
  <div class="wrap">
    <div class="crumbs"><a href="/">Home</a><span>/</span>Drops</div>
    <section class="hero" style="text-align:left;padding:38px 0 12px">
      <div class="lbl lbl-accent">// The wick is lit</div>
      <h1 style="font-size:clamp(2rem,5vw,3.2rem);max-width:20ch;margin:12px 0">Stock &amp; Deal Tracker</h1>
      <p style="max-width:64ch;font-size:1.04rem">New releases, price drops and the market moves that matter — across every bay. An automated tracker watches vendor stock + price twice a day (public price/stock data, polite, robots-respected); curated market intel fills in the bigger moves.</p>
    </section>

    <section class="sec" style="padding-top:14px">
      <div class="drop-filters" id="drop-filters">
        <button class="chip on" data-f="all">All</button>
        {bays.map((b) => <button class="chip" data-f={b.slug}>{b.name}</button>)}
      </div>
      <div class="card-grid" id="drop-grid" style="margin-top:18px">
        {sorted.map((e) => {
          const t = typeMeta[e.type] || { label: e.type, cls: 'cyan' };
          return (
            <div class="card drop" data-bay={e.bay} style="cursor:default">
              <div class="cbody">
                <span class={`drop-badge ${t.cls}`}>{t.label}</span>
                <span class="ctype" style="margin-top:6px">{e.bay} · {fmt(e.date)}</span>
                <h3 style="font-size:1.04rem">{e.title}</h3>
                <p class="cexc">{e.note}</p>
                <div style="display:flex;gap:10px;align-items:center;margin-top:4px">
                  <span class="cmeta">{e.brand}{e.model ? ` · ${e.model}` : ''}</span>
                  {e.productId && <a class="cmeta" style="color:var(--accent)" href={`/${e.bay}/gear/${e.productId}`} data-event="drops_click">View gear →</a>}
                </div>
              </div>
            </div>
          );
        })}
      </div>
    </section>

    <section class="band">
      <div>
        <span class="lbl lbl-accent">// Restock + deal alerts</span>
        <h3>Get pinged when it's back</h3>
        <p>{site.newsletter.blurb} Segmentable by bay — only the drops you actually care about.</p>
      </div>
      <a class="btn btn-primary btn-lg" href="/alerts">Arm alerts ▸</a>
    </section>
  </div>
</Base>

<style>
  .drop-filters { display: flex; gap: 8px; flex-wrap: wrap; }
  .chip { font-family: var(--font-mono); font-size: .7rem; letter-spacing: .06em; text-transform: uppercase; color: var(--dim); border: 1px solid var(--line2); background: var(--panel); border-radius: 20px; padding: 8px 16px; cursor: pointer; }
  .chip.on, .chip:hover { color: var(--accent); border-color: var(--accent); }
  .drop-badge { display: inline-block; font-family: var(--font-mono); font-size: .58rem; letter-spacing: .12em; text-transform: uppercase; padding: 3px 9px; border-radius: 20px; border: 1px solid; width: fit-content; }
  .drop-badge.green { color: var(--green); border-color: rgba(52,211,153,.4); background: rgba(52,211,153,.08); }
  .drop-badge.ember { color: var(--ember-2); border-color: rgba(255,94,26,.4); background: rgba(255,94,26,.08); }
  .drop-badge.cyan { color: var(--cyan); border-color: rgba(34,211,238,.4); background: rgba(34,211,238,.08); }
  .drop-badge.red { color: var(--red); border-color: rgba(248,113,113,.4); background: rgba(248,113,113,.08); }
</style>

<script>
  const grid = document.getElementById('drop-grid');
  document.querySelectorAll<HTMLElement>('#drop-filters .chip').forEach((c) => c.addEventListener('click', () => {
    document.querySelectorAll('#drop-filters .chip').forEach((x) => x.classList.remove('on'));
    c.classList.add('on');
    const f = c.dataset.f;
    grid?.querySelectorAll<HTMLElement>('.drop').forEach((d) => { d.style.display = (f === 'all' || d.dataset.bay === f) ? '' : 'none'; });
  }));
</script>
